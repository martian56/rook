import std/string
import std/test { assert_true, assert_eq_int, assert_eq_str }
import std/time { sleep_millis }
import std/env { os_name }
import "./shells" { ShellInfo, run_background, shell_count, list_shells, read_shell, shells_list_text, kill_shell, shell_tail, shells_note, cap_output, kill_all_shells, Capped }

fun test_background_command_returns_an_id_immediately() {
    let before = shell_count()
    let r = run_background("echo bg-hello")
    assert_true(r.starts_with("started shell "))
    assert_true(r.contains("echo bg-hello"))
    assert_true(shell_count() == before + 1)
}

fun test_empty_command_is_an_error() {
    assert_true(run_background("   ").starts_with("error:"))
}

fun test_each_shell_gets_its_own_id() {
    let a = run_background("echo one")
    let b = run_background("echo two")
    assert_true(a != b)
}

// Find a shell by id in a snapshot; -1 when absent.
fun _index_of(infos: List<ShellInfo>, id: Int) -> Int {
    let i = 0
    while i < infos.len() {
        if infos[i].id == id {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

fun _id_of(started: String) -> Int {
    // "started shell N: ..." -> N
    let rest = started.substring(14, started.length())
    let colon = rest.index_of(":")
    return match rest.substring(0, colon).parse_int() {
        Some(n) -> n,
        None -> 0 - 1,
    }
}

// Wait until shell `id` shows exited in the registry.
fun _wait_exit(id: Int) {
    let tries = 0
    while tries < 400 {
        let infos = list_shells()
        let at = _index_of(infos, id)
        if at >= 0 && !infos[at].running {
            return
        }
        sleep_millis(10)
        tries = tries + 1
    }
    return
}

fun test_read_shell_is_incremental() {
    let id = _id_of(run_background("echo incremental-probe"))
    assert_true(id > 0)
    // Wait for the exit first: the final drain has then run, so the one
    // read below deterministically carries the whole output. The probe is
    // asserted on the body, not the header, since the header repeats the
    // command text.
    _wait_exit(id)
    let got = read_shell("${id}")
    assert_true(got.starts_with("shell ${id} (exited 0)"))
    let nl = got.index_of("\n")
    assert_true(nl > 0)
    assert_true(got.substring(nl + 1, got.length()).contains("incremental-probe"))
    // Nothing new arrives after exit; the second read says so.
    let again = read_shell("${id}")
    assert_true(again.contains("(no new output)"))
}

fun test_read_shell_rejects_bad_ids() {
    assert_true(read_shell("not-a-number").starts_with("error:"))
    assert_true(read_shell("99999").starts_with("error:"))
}

fun test_list_text_names_every_shell() {
    run_background("echo list-probe")
    let text = shells_list_text()
    assert_true(text.contains("echo list-probe"))
    assert_true(text.contains("shell "))
}

fun test_kill_stops_a_running_shell() {
    let cmd = "sleep 30"
    if os_name() == "windows" {
        cmd = "ping -n 31 127.0.0.1"
    }
    let id = _id_of(run_background(cmd))
    assert_true(id > 0)
    let r = kill_shell("${id}")
    assert_true(r.starts_with("killed shell ${id}"))
    // The registry shows it exited, and killing again reports that.
    let infos = list_shells()
    let at = _index_of(infos, id)
    assert_true(at >= 0)
    assert_true(!infos[at].running)
    assert_true(kill_shell("${id}").contains("already exited"))
}

fun test_tail_returns_the_newest_output_without_moving_the_read_marker() {
    let id = _id_of(run_background("echo tail-probe"))
    _wait_exit(id)
    let tail = shell_tail(id, 4000)
    assert_true(tail.contains("tail-probe"))
    // A tiny cap keeps only the newest bytes.
    let tiny = shell_tail(id, 4)
    assert_true(tiny.length() <= 4)
    // The pane read did not consume the agent's incremental read.
    let got = read_shell("${id}")
    assert_true(got.contains("tail-probe"))
    assert_true(shell_tail(99999, 100) == "")
}

fun test_note_names_unread_shells_and_clears_after_reading() {
    let id = _id_of(run_background("echo note-probe"))
    _wait_exit(id)
    let note = shells_note()
    assert_true(note.contains("[background shell state]"))
    assert_true(note.contains("shell ${id}"))
    assert_true(note.contains("bytes unread"))
    assert_true(note.contains("not instructions"))
    read_shell("${id}")
    // Everything read: this shell no longer appears in the note.
    assert_true(!shells_note().contains("shell ${id} ("))
}

fun test_cap_keeps_the_tail_and_slides_the_read_marker() {
    // Under the cap: untouched.
    let same = cap_output("abcdef", 2, 10)
    assert_eq_str(same.output, "abcdef")
    assert_eq_int(same.read_pos, 2)
    // Over the cap: the newest bytes stay, and a marker inside the trimmed
    // prefix clamps to the new start.
    let trimmed = cap_output("0123456789", 3, 4)
    assert_eq_str(trimmed.output, "6789")
    assert_eq_int(trimmed.read_pos, 0)
    // A marker past the cut slides down by the trimmed amount.
    let slid = cap_output("0123456789", 8, 4)
    assert_eq_str(slid.output, "6789")
    assert_eq_int(slid.read_pos, 2)
}

fun test_kill_all_stops_every_running_shell() {
    let cmd = "sleep 30"
    if os_name() == "windows" {
        cmd = "ping -n 31 127.0.0.1"
    }
    let a = _id_of(run_background(cmd))
    let b = _id_of(run_background(cmd))
    kill_all_shells()
    let infos = list_shells()
    let ia = _index_of(infos, a)
    let ib = _index_of(infos, b)
    assert_true(ia >= 0 && ib >= 0)
    assert_true(!infos[ia].running)
    assert_true(!infos[ib].running)
}

fun test_kill_rejects_unknown_shells() {
    assert_true(kill_shell("99999").starts_with("error:"))
}

fun test_registry_moves_a_shell_from_running_to_exited() {
    let started = run_background("echo registry-probe")
    let id = _id_of(started)
    assert_true(id > 0)
    // Wait for the child to finish; refresh happens inside list_shells.
    let tries = 0
    let done = false
    while tries < 400 && !done {
        let infos = list_shells()
        let at = _index_of(infos, id)
        assert_true(at >= 0)
        if !infos[at].running {
            done = true
            assert_eq_int(infos[at].code, 0)
            assert_true(infos[at].output_len > 0)
            assert_eq_str(infos[at].command, "echo registry-probe")
            assert_true(infos[at].runtime_ms >= 0)
        } else {
            sleep_millis(10)
            tries = tries + 1
        }
    }
    assert_true(done)
}
