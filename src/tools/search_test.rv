import std/string
import std/test { assert_true }
import std/fs { create_dir_all, remove_file, remove_dir, write as fs_write }
import "./search" { grep }

fun test_grep_finds_matching_lines() {
    create_dir_all("_rook_gr")
    fs_write("_rook_gr/f.txt", "alpha\nbeta needle here\ngamma")
    let out = grep("needle", "_rook_gr", "")
    assert_true(out.contains("beta needle here"))
    assert_true(out.contains("f.txt"))
    remove_file("_rook_gr/f.txt")
    remove_dir("_rook_gr")
    return
}

fun test_grep_reports_no_matches() {
    create_dir_all("_rook_gr2")
    fs_write("_rook_gr2/f.txt", "nothing to see")
    assert_true(grep("zzzz", "_rook_gr2", "").starts_with("no matches"))
    remove_file("_rook_gr2/f.txt")
    remove_dir("_rook_gr2")
    return
}

fun test_grep_without_pattern_is_error() {
    assert_true(grep("", ".", "").starts_with("error:"))
}

fun test_grep_matches_regex_pattern() {
    create_dir_all("_rook_gr3")
    fs_write("_rook_gr3/f.txt", "order 7\nno digits here\norder 42")
    let out = grep("order [0-9]+", "_rook_gr3", "")
    assert_true(out.contains("order 7"))
    assert_true(out.contains("order 42"))
    assert_true(!out.contains("no digits here"))
    remove_file("_rook_gr3/f.txt")
    remove_dir("_rook_gr3")
    return
}

fun test_grep_case_insensitive_flag() {
    create_dir_all("_rook_gr4")
    fs_write("_rook_gr4/f.txt", "ERROR: boom\nfine")
    let out = grep("(?i)error", "_rook_gr4", "")
    assert_true(out.contains("ERROR: boom"))
    remove_file("_rook_gr4/f.txt")
    remove_dir("_rook_gr4")
    return
}

fun test_grep_invalid_pattern_is_error() {
    assert_true(grep("(unclosed", ".", "").starts_with("error: invalid pattern:"))
}

fun test_grep_glob_filters_files() {
    create_dir_all("_rook_gr5")
    fs_write("_rook_gr5/keep.rv", "needle here")
    fs_write("_rook_gr5/skip.txt", "needle here too")
    let out = grep("needle", "_rook_gr5", "*.rv")
    assert_true(out.contains("keep.rv"))
    assert_true(!out.contains("skip.txt"))
    remove_file("_rook_gr5/keep.rv")
    remove_file("_rook_gr5/skip.txt")
    remove_dir("_rook_gr5")
    return
}

fun test_grep_skips_noise_directories_by_default() {
    create_dir_all("_rook_gr6/src")
    create_dir_all("_rook_gr6/target/debug")
    create_dir_all("_rook_gr6/node_modules/pkg")
    create_dir_all("_rook_gr6/.git")
    fs_write("_rook_gr6/src/main.rv", "needle in source")
    fs_write("_rook_gr6/target/debug/app.txt", "needle in build output")
    fs_write("_rook_gr6/node_modules/pkg/index.js", "needle in dependency")
    fs_write("_rook_gr6/.git/config", "needle in metadata")

    let out = grep("needle", "_rook_gr6", "")
    assert_true(out.contains("src/main.rv"))
    assert_true(!out.contains("target"))
    assert_true(!out.contains("node_modules"))
    assert_true(!out.contains(".git"))

    remove_file("_rook_gr6/src/main.rv")
    remove_file("_rook_gr6/target/debug/app.txt")
    remove_file("_rook_gr6/node_modules/pkg/index.js")
    remove_file("_rook_gr6/.git/config")
    remove_dir("_rook_gr6/src")
    remove_dir("_rook_gr6/target/debug")
    remove_dir("_rook_gr6/target")
    remove_dir("_rook_gr6/node_modules/pkg")
    remove_dir("_rook_gr6/node_modules")
    remove_dir("_rook_gr6/.git")
    remove_dir("_rook_gr6")
    return
}

fun test_grep_can_search_explicit_ignored_directory() {
    create_dir_all("_rook_gr7/target")
    fs_write("_rook_gr7/target/out.txt", "needle in build output")

    let out = grep("needle", "_rook_gr7/target", "")
    assert_true(out.contains("target/out.txt"))
    assert_true(out.contains("needle in build output"))

    remove_file("_rook_gr7/target/out.txt")
    remove_dir("_rook_gr7/target")
    remove_dir("_rook_gr7")
    return
}

fun test_grep_rejects_workspace_escape() {
    assert_true(grep("needle", "..", "").contains("workspace"))
}
