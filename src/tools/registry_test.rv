import std/string
import std/json { stringify }
import std/test { assert_eq_str, assert_eq_int, assert_true, assert_false }
import "github.com/martian56/aviary/message" { ToolCall }
import "./registry" { tools, needs_approval, call_needs_approval, dispatch, label }

fun call(name: String, args: String) -> ToolCall {
    return ToolCall { id: "1", name, arguments: args }
}

fun test_all_tools_are_defined() {
    assert_eq_int(tools().len(), 21)
}

fun test_approval_policy() {
    assert_true(needs_approval("write_file"))
    assert_true(needs_approval("edit_file"))
    assert_true(needs_approval("multi_edit"))
    assert_true(needs_approval("run_command"))
    assert_true(needs_approval("run_background"))
    assert_true(needs_approval("kill_shell"))
    assert_true(needs_approval("git_commit"))
    assert_false(needs_approval("read_shell"))
    assert_false(needs_approval("list_shells"))
    assert_false(needs_approval("ask_user"))
    assert_false(needs_approval("file_tree"))
    assert_false(needs_approval("set_todos"))
    assert_false(needs_approval("git_status"))
    assert_false(needs_approval("git_diff"))
    assert_false(needs_approval("web_search"))
    assert_false(needs_approval("web_fetch"))
    assert_false(needs_approval("read_file"))
    assert_false(needs_approval("list_dir"))
    assert_false(needs_approval("grep"))
    assert_false(needs_approval("use_skill"))
}

fun test_call_approval_policy_gates_sensitive_web_fetches() {
    assert_false(call_needs_approval(call("web_fetch", "{\"url\":\"https://8.8.8.8/dns-query\"}")))
    assert_true(call_needs_approval(call("web_fetch", "{\"url\":\"https://example.com/docs\"}")))
    assert_true(call_needs_approval(call("web_fetch", "{\"url\":\"http://127.0.0.1:11434\"}")))
    assert_true(call_needs_approval(call("web_fetch", "{\"url\":\"http://169.254.169.254/\"}")))
    assert_true(call_needs_approval(call("run_command", "{\"command\":\"rvpm test\"}")))
}

fun test_label_reads_arguments() {
    assert_eq_str(label(call("read_file", "{\"path\":\"src/main.rv\"}")), "read_file(src/main.rv)")
    assert_eq_str(
        label(call("run_command", "{\"command\":\"rvpm test\"}")),
        "run_command(rvpm test)",
    )
    assert_eq_str(label(call("grep", "{\"pattern\":\"needle\"}")), "grep(needle)")
    assert_eq_str(
        label(call("multi_edit", "{\"path\":\"src/main.rv\",\"edits\":[]}")),
        "multi_edit(src/main.rv)",
    )
    assert_eq_str(
        label(call("write_file", "{\"path\":\"src\\\\app/../main.rv\",\"content\":\"x\"}")),
        "write_file(src\\app/../main.rv -> src/main.rv)",
    )
}

fun test_dispatch_routes_read_command() {
    // read_file on a missing file returns its error string, proving dispatch
    // reached the executor with the parsed path.
    assert_true(
        dispatch(call("read_file", "{\"path\":\"_rook_absent.txt\"}")).starts_with("error:"),
    )
}

fun test_dispatch_unknown_tool() {
    assert_true(dispatch(call("nope", "{}")).starts_with("error:"))
}

// The git tools are advertised to the model, so dispatch must run them
// instead of falling through to the unknown-tool error. git_commit with an
// empty message is rejected before anything is staged or committed, so this
// is safe against the live checkout.
fun test_dispatch_routes_git_tools() {
    // The precise regression is the unknown-tool fall-through; check the error
    // prefix, not a substring, since a real diff can contain those words.
    assert_true(!dispatch(call("git_status", "{}")).starts_with("error: unknown tool"))
    assert_true(!dispatch(call("git_diff", "{}")).starts_with("error: unknown tool"))
    let c = dispatch(call("git_commit", "{\"message\":\"\"}"))
    assert_true(!c.starts_with("error: unknown tool"))
    assert_true(c.starts_with("error:"))
}

fun test_use_skill_routes_and_labels() {
    // With no .agents folder in the repo, any skill lookup is the
    // no-skills error, proving dispatch reached the skills module.
    assert_true(dispatch(call("use_skill", "{\"name\":\"x\"}")).starts_with("error:"))
    assert_eq_str(label(call("use_skill", "{\"name\":\"release\"}")), "use_skill(release)")
}

fun test_ask_user_is_labeled_and_turn_only() {
    assert_eq_str(
        label(call("ask_user", "{\"question\":\"Which way?\",\"options\":\"a, b\"}")),
        "ask_user(Which way?)",
    )
    // Only the turn loop may run it; the registry router refuses.
    assert_true(dispatch(call("ask_user", "{}")).starts_with("error:"))
}

fun test_ask_user_schema_uses_structured_options() {
    let schema = _tool_schema("ask_user")
    assert_true(schema.contains("\"options\""))
    assert_true(schema.contains("\"type\":\"array\""))
    assert_true(schema.contains("\"minItems\":2"))
    assert_true(schema.contains("\"maxItems\":5"))
    assert_true(schema.contains("\"label\""))
    return
}

fun test_dispatch_tool_is_auto_run_and_labeled() {
    assert_false(needs_approval("dispatch"))
    assert_eq_str(
        label(call("dispatch", "{\"agent\":\"reviewer\",\"task\":\"t\"}")),
        "dispatch(reviewer)",
    )
    // The registry itself refuses dispatch: only the turn loop may run it.
    assert_true(dispatch(call("dispatch", "{}")).starts_with("error:"))
}

fun _tool_schema(name: String) -> String {
    let ts = tools()
    let i = 0
    while i < ts.len() {
        if ts[i].name == name {
            return stringify(ts[i].parameters)
        }
        i = i + 1
    }
    return ""
}
