import std/string
import std/test { assert_eq_str, assert_eq_int, assert_true }
import "./todos" { Todo, set_todos, parse_todos, current_todos, clear_todos }

fun test_parse_reads_the_markers() {
    let items = parse_todos("[x] shipped\n[>] building\nplanned\n[ ] also planned\n\n")
    assert_eq_int(items.len(), 4)
    assert_eq_int(items[0].state, 2)
    assert_eq_str(items[0].text, "shipped")
    assert_eq_int(items[1].state, 1)
    assert_eq_str(items[1].text, "building")
    assert_eq_int(items[2].state, 0)
    assert_eq_int(items[3].state, 0)
    assert_eq_str(items[3].text, "also planned")
}

fun test_set_reports_progress_and_store_round_trips() {
    let r = set_todos("[x] one\n[>] two\nthree")
    assert_eq_str(r, "todo list updated: 1 of 3 done")
    let items = current_todos()
    assert_eq_int(items.len(), 3)
    assert_eq_str(items[1].text, "two")
    clear_todos()
    assert_eq_int(current_todos().len(), 0)
}

fun test_empty_input_clears() {
    set_todos("[x] a")
    assert_eq_str(set_todos(""), "todo list cleared")
    assert_eq_int(current_todos().len(), 0)
}
