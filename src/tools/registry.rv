// The tool catalog: the schemas the model sees, which tools change things
// (and so need approval), and the dispatch from a tool call to its result.

import std/string
import std/json { JsonValue }
import "github.com/martian56/aviary/message" { ToolDef, ToolCall }
import "github.com/martian56/aviary/jsonutil" { Obj }
import "./args" { arg }
import "./files" { read_file, list_dir, write_file, edit_file }
import "./search" { grep }
import "./shell" { run_command }
import "./shells" { run_background, read_shell, shells_list_text, kill_shell }
import "./tree" { file_tree }
import "./todos" { set_todos }
import "../agents/dir" { roots }
import "../agents/skills" { skill_body }

// One schema field: a string property and its description.
struct Prop {
    name: String,
    desc: String,
}

// The tool definitions offered to the model.
fun tools() -> List<ToolDef> {
    let no_props: List<Prop> = []
    return [
        ToolDef.new(
            "read_file",
            "Read a UTF-8 text file and return its contents.",
            _schema(
                [Prop { name: "path", desc: "path to the file, relative to the working directory" }],
            ),
        ),
        ToolDef.new(
            "list_dir",
            "List the entries of a directory (defaults to the working directory).",
            _schema([Prop { name: "path", desc: "directory path; defaults to '.'" }]),
        ),
        ToolDef.new(
            "file_tree",
            "An indented tree of the project structure, depth-limited, with build and dependency noise skipped. The fast way to orient in a repository.",
            _schema(
                [
                    Prop { name: "path", desc: "directory to show; defaults to '.'" },
                    Prop { name: "depth", desc: "levels to descend; defaults to 3" },
                ],
            ),
        ),
        ToolDef.new(
            "grep",
            "Search files under a directory with a regex (RE2 syntax: no backreferences or lookaround); returns matching lines as path:line: text. Prefix the pattern with (?i) for case-insensitive matching, e.g. (?i)error.",
            _schema2(
                [
                    Prop {
                        name: "pattern",
                        desc: "the regex pattern to search for; prefix with (?i) for case-insensitive matching",
                    },
                    Prop { name: "path", desc: "directory to search; defaults to '.'" },
                ],
                [
                    Prop {
                        name: "glob",
                        desc: "only search files whose name matches this glob, e.g. '*.rv'",
                    },
                ],
            ),
        ),
        ToolDef.new(
            "write_file",
            "Create or overwrite a file with the given contents.",
            _schema(
                [
                    Prop { name: "path", desc: "file path to write" },
                    Prop { name: "content", desc: "the full new contents of the file" },
                ],
            ),
        ),
        ToolDef.new(
            "edit_file",
            "Replace the first exact occurrence of old_text with new_text in a file.",
            _schema(
                [
                    Prop { name: "path", desc: "file path to edit" },
                    Prop { name: "old_text", desc: "exact text to find and replace once" },
                    Prop { name: "new_text", desc: "replacement text" },
                ],
            ),
        ),
        ToolDef.new(
            "run_command",
            "Run a shell command in the working directory and return its stdout, stderr, and exit code.",
            _schema([Prop { name: "command", desc: "the shell command to run" }]),
        ),
        ToolDef.new(
            "run_background",
            "Start a long-running shell command (a dev server, a watcher, an app) without waiting for it. Returns a shell id immediately; the output accumulates in the background.",
            _schema([Prop { name: "command", desc: "the shell command to start" }]),
        ),
        ToolDef.new(
            "read_shell",
            "Read a background shell's output since the last read, with its status. Call it again later for what arrived in between.",
            _schema([Prop { name: "id", desc: "the shell id from run_background" }]),
        ),
        ToolDef.new(
            "list_shells",
            "List the background shells with their status, runtime, and command.",
            _schema(no_props),
        ),
        ToolDef.new(
            "kill_shell",
            "Stop a running background shell and report its exit code.",
            _schema([Prop { name: "id", desc: "the shell id to stop" }]),
        ),
        ToolDef.new(
            "use_skill",
            "Load the full instructions of a skill listed in the system prompt. Call it when a skill matches the task, before doing that work.",
            _schema([Prop { name: "name", desc: "the skill's name, as listed" }]),
        ),
        ToolDef.new(
            "set_todos",
            "Replace your visible checklist for the current work, one item per line: prefix [x] for done, [>] for the one in progress, nothing for pending. Keep it updated as steps finish.",
            _schema([Prop { name: "todos", desc: "the full checklist, one item per line" }]),
        ),
        ToolDef.new(
            "ask_user",
            "Ask the user one multiple-choice question when a decision is theirs to make and guessing would be wrong. They pick one option in the UI.",
            _schema(
                [
                    Prop { name: "question", desc: "the question, one sentence" },
                    Prop { name: "options", desc: "two to five short options, comma-separated" },
                ],
            ),
        ),
        ToolDef.new(
            "dispatch",
            "Delegate one scoped task to a subagent listed in the system prompt and get its final answer back. The subagent works in isolation with its own tools; give it a complete, self-contained task.",
            _schema(
                [
                    Prop { name: "agent", desc: "the subagent's name, as listed" },
                    Prop { name: "task", desc: "the full task, with all the context it needs" },
                ],
            ),
        ),
    ]
}

// Whether a tool changes the repo or the machine and so must be approved.
fun needs_approval(name: String) -> Bool {
    return name == "write_file" || name == "edit_file" || name == "run_command" || name == "run_background" || name == "kill_shell"
}

// Run a tool call and return its result string.
fun dispatch(call: ToolCall) -> String {
    let a = call.arguments
    if call.name == "read_file" {
        return read_file(arg(a, "path"))
    }
    if call.name == "list_dir" {
        return list_dir(arg(a, "path"))
    }
    if call.name == "grep" {
        return grep(arg(a, "pattern"), arg(a, "path"), arg(a, "glob"))
    }
    if call.name == "write_file" {
        return write_file(arg(a, "path"), arg(a, "content"))
    }
    if call.name == "edit_file" {
        return edit_file(arg(a, "path"), arg(a, "old_text"), arg(a, "new_text"))
    }
    if call.name == "run_command" {
        return run_command(arg(a, "command"))
    }
    if call.name == "run_background" {
        return run_background(arg(a, "command"))
    }
    if call.name == "read_shell" {
        return read_shell(arg(a, "id"))
    }
    if call.name == "list_shells" {
        return shells_list_text()
    }
    if call.name == "kill_shell" {
        return kill_shell(arg(a, "id"))
    }
    if call.name == "use_skill" {
        return skill_body(roots(), arg(a, "name"))
    }
    if call.name == "set_todos" {
        return set_todos(arg(a, "todos"))
    }
    if call.name == "dispatch" {
        // The turn loop intercepts dispatch before it reaches here; a
        // subagent asking to dispatch lands on this instead.
        return "error: only the main agent can dispatch subagents"
    }
    if call.name == "ask_user" {
        // Same shape: the turn loop intercepts ask_user; only a subagent
        // ends up here.
        return "error: only the main agent can ask the user"
    }
    return "error: unknown tool '${call.name}'"
}

// A one-line label for a call, shown as the tool bullet and in the approval
// prompt: "read_file(src/main.rv)", "run_command(rvpm test)".
fun label(call: ToolCall) -> String {
    let a = call.arguments
    if call.name == "read_file" || call.name == "list_dir" {
        return "${call.name}(${arg(a, "path")})"
    }
    if call.name == "grep" {
        return "grep(${arg(a, "pattern")})"
    }
    if call.name == "file_tree" {
        return "file_tree(${arg(a, "path")})"
    }
    if call.name == "write_file" || call.name == "edit_file" {
        return "${call.name}(${arg(a, "path")})"
    }
    if call.name == "run_command" {
        return "run_command(${arg(a, "command")})"
    }
    if call.name == "run_background" {
        return "run_background(${arg(a, "command")})"
    }
    if call.name == "read_shell" {
        return "read_shell(${arg(a, "id")})"
    }
    if call.name == "kill_shell" {
        return "kill_shell(${arg(a, "id")})"
    }
    if call.name == "use_skill" {
        return "use_skill(${arg(a, "name")})"
    }
    if call.name == "set_todos" {
        return "set_todos"
    }
    if call.name == "dispatch" {
        return "dispatch(${arg(a, "agent")})"
    }
    if call.name == "ask_user" {
        return "ask_user(${arg(a, "question")})"
    }
    return call.name
}

fun _schema(props: List<Prop>) -> JsonValue {
    let no_optional: List<Prop> = []
    return _schema2(props, no_optional)
}

// Like _schema, but props in `optional` are added to the schema without
// being listed as required (a missing one just reads back as "" via arg()).
fun _schema2(required: List<Prop>, optional: List<Prop>) -> JsonValue {
    let properties = Obj.new()
    let required_names: List<JsonValue> = []
    let i = 0
    while i < required.len() {
        let p = required[i]
        properties = properties.set(
            p.name,
            Obj.new().str("type", "string").str("description", p.desc).build(),
        )
        required_names.push(JsonValue.Str(p.name))
        i = i + 1
    }
    let j = 0
    while j < optional.len() {
        let p = optional[j]
        properties = properties.set(
            p.name,
            Obj.new().str("type", "string").str("description", p.desc).build(),
        )
        j = j + 1
    }
    return Obj.new().str("type", "object").set("properties", properties.build()).set(
        "required",
        JsonValue.Array(required_names),
    ).build()
}
