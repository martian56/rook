// Rough token pricing for the cost estimate in the status bar. Prices are
// approximate USD per 1M tokens for the mid-2026 catalog, stored as
// micro-dollars per 1000 tokens so the cost math stays in integers. An
// unknown model reports no price, and the UI then shows tokens without a
// dollar figure. These are estimates for at-a-glance spend, not billing.

import std/string

struct Price {
    known: Bool,
    // Micro-dollars ($1e-6) per 1000 tokens, input and output.
    in_1k: Int,
    out_1k: Int,
}

// Dollars-per-million to micro-dollars-per-1000: multiply by 1000. So a
// $3 / 1M model is 3000 here.
struct Rate {
    needle: String,
    in_1k: Int,
    out_1k: Int,
}

// Matched by the first needle contained in the model id, most specific
// first. The id is a "provider/model" string, so matching on the model
// name works across providers (openrouter/anthropic/claude-sonnet-5 and
// anthropic/claude-sonnet-5 both hit "claude-sonnet-5").
fun _rates() -> List<Rate> {
    return [
        Rate { needle: "claude-haiku", in_1k: 800, out_1k: 4000 },
        Rate { needle: "claude-sonnet", in_1k: 3000, out_1k: 15000 },
        Rate { needle: "claude-opus", in_1k: 15000, out_1k: 75000 },
        Rate { needle: "claude-fable", in_1k: 15000, out_1k: 75000 },
        Rate { needle: "gpt-5", in_1k: 5000, out_1k: 15000 },
        Rate { needle: "gpt-4o-mini", in_1k: 150, out_1k: 600 },
        Rate { needle: "gpt-4o", in_1k: 2500, out_1k: 10000 },
        Rate { needle: "gemini-3.1-flash", in_1k: 300, out_1k: 2500 },
        Rate { needle: "gemini-3.1-pro", in_1k: 2500, out_1k: 10000 },
        Rate { needle: "deepseek", in_1k: 500, out_1k: 1500 },
        Rate { needle: "kimi", in_1k: 600, out_1k: 2500 },
        Rate { needle: "minimax", in_1k: 400, out_1k: 1600 },
        Rate { needle: "glm", in_1k: 500, out_1k: 2000 },
        Rate { needle: "llama-5", in_1k: 500, out_1k: 1500 },
        Rate { needle: "qwen", in_1k: 2500, out_1k: 7500 },
        Rate { needle: "grok-4", in_1k: 3000, out_1k: 15000 },
        Rate { needle: "mistral-large", in_1k: 2000, out_1k: 6000 },
    ]
}

// Built once at startup, not rebuilt on every status-bar draw. The table is
// constant, and price_for runs on the per-frame render path.
let RATES: List<Rate> = _rates()

fun price_for(model: String) -> Price {
    let rates = RATES
    let i = 0
    while i < rates.len() {
        if model.contains(rates[i].needle) {
            return Price { known: true, in_1k: rates[i].in_1k, out_1k: rates[i].out_1k }
        }
        i = i + 1
    }
    return Price { known: false, in_1k: 0, out_1k: 0 }
}

// Cost in micro-dollars for `prompt` input and `completion` output tokens
// under `model`, or -1 when the model has no known price.
fun cost_micros(model: String, prompt: Int, completion: Int) -> Int {
    let p = price_for(model)
    if !p.known {
        return 0 - 1
    }
    return (prompt * p.in_1k + completion * p.out_1k) / 1000
}

// Micro-dollars as "$0.0042" (four decimal places, rounded).
fun format_usd(micros: Int) -> String {
    // Ten-thousandths of a dollar, rounded.
    let tt = (micros + 50) / 100
    let whole = tt / 10000
    let frac = tt % 10000
    return "$${whole}.${_pad4(frac)}"
}

// A compact token count: "1.2k" past a thousand, else the raw number.
fun format_tokens(n: Int) -> String {
    if n < 1000 {
        return "${n}"
    }
    let whole = n / 1000
    let tenths = (n % 1000) / 100
    return "${whole}.${tenths}k"
}

// The status-bar usage label for a session: "" when nothing spent, else the
// token total with the cost when the model has a price.
fun usage_label(model: String, prompt: Int, completion: Int) -> String {
    let total = prompt + completion
    if total == 0 {
        return ""
    }
    let toks = "${format_tokens(total)} tok"
    let micros = cost_micros(model, prompt, completion)
    if micros < 0 {
        return toks
    }
    return "${toks} · ${format_usd(micros)}"
}

fun _pad4(n: Int) -> String {
    let s = "${n}"
    while s.length() < 4 {
        s = "0".concat(s)
    }
    return s
}
