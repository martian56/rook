import std/string
import std/test { assert_true, assert_eq_str }
import std/fs { read, write, exists, remove_file }
import "./checkpoints" { begin_checkpoint_batch, checkpoint_file, rewind_last_batch, checkpoint_batches, clear_checkpoints }

fun test_rewind_restores_edits_and_deletes_created_files() {
    clear_checkpoints()
    write("_rook_ckpt_a.txt", "original")
    begin_checkpoint_batch()
    checkpoint_file("_rook_ckpt_a.txt")
    write("_rook_ckpt_a.txt", "changed")
    // A file the turn created: no pre-image, so rewind deletes it.
    checkpoint_file("_rook_ckpt_b.txt")
    write("_rook_ckpt_b.txt", "new file")
    let summary = rewind_last_batch()
    assert_true(summary.contains("2 file(s)"))
    match read("_rook_ckpt_a.txt") {
        Ok(t) -> assert_eq_str(t, "original"),
        Err(e) -> assert_true(false),
    }
    assert_true(!exists("_rook_ckpt_b.txt"))
    remove_file("_rook_ckpt_a.txt")
    return
}

fun test_batches_rewind_newest_first() {
    clear_checkpoints()
    write("_rook_ckpt_c.txt", "one")
    begin_checkpoint_batch()
    checkpoint_file("_rook_ckpt_c.txt")
    write("_rook_ckpt_c.txt", "two")
    begin_checkpoint_batch()
    checkpoint_file("_rook_ckpt_c.txt")
    write("_rook_ckpt_c.txt", "three")
    assert_true(checkpoint_batches() == 2)
    let _ = rewind_last_batch()
    match read("_rook_ckpt_c.txt") {
        Ok(t) -> assert_eq_str(t, "two"),
        Err(e) -> assert_true(false),
    }
    let _ = rewind_last_batch()
    match read("_rook_ckpt_c.txt") {
        Ok(t) -> assert_eq_str(t, "one"),
        Err(e) -> assert_true(false),
    }
    assert_eq_str(rewind_last_batch(), "")
    remove_file("_rook_ckpt_c.txt")
    return
}
