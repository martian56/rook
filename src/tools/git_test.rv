import std/string
import std/fs { write, remove_file }
import std/process { run }
import std/test { assert_true }
import "./git" { git_status, git_diff, git_commit, git_commit_preview }

// These run against the real repository the suite executes in, which is a
// git checkout, so only the read-only tools are exercised for real; the
// commit path is checked through its validation, never committing.

fun test_status_reports_a_branch() {
    let s = git_status()
    assert_true(!s.starts_with("error:"))
    assert_true(s.contains("On branch "))
}

fun test_diff_runs_without_error() {
    let d = git_diff("", "")
    assert_true(!d.starts_with("error:"))
    let staged = git_diff("true", "")
    assert_true(!staged.starts_with("error:"))
}

fun test_diff_rejects_a_path_outside_the_workspace() {
    // The pathspec is confined, so an escaping path is refused before git runs.
    // resolve_path rejects it with an "error: path ..." message before git runs.
    let out = git_diff("", "../outside.txt")
    assert_true(out.starts_with("error:"))
    assert_true(out.contains("workspace") || out.contains("symlink"))
}

fun test_commit_rejects_an_empty_message() {
    assert_true(git_commit("").starts_with("error:"))
    assert_true(git_commit("   ").starts_with("error:"))
}

fun test_commit_preview_shows_message_status_and_staged_diff() {
    let p = git_commit_preview("test message")
    assert_true(p.contains("message:"))
    assert_true(p.contains("test message"))
    assert_true(p.contains("status:"))
    assert_true(p.contains("staged diff:"))
}

// Stage a scratch file and leave another untracked, then confirm the preview
// reflects exactly what would be committed. The index and files are restored
// BEFORE any assertion, so a failed assertion never leaves the repo dirty,
// and git_commit is never called with a real message (which would commit).
// The scratch names avoid the _rook_* gitignore so they are visible to git.
fun test_preview_reflects_staged_and_surfaces_untracked() {
    write("zz_rook_staged_probe.txt", "STAGED_PROBE")
    write("zz_rook_untracked_probe.txt", "UNTRACKED_PROBE")
    _run_git(["add", "--", "zz_rook_staged_probe.txt"])

    let staged_diff = git_diff("true", "")
    let preview = git_commit_preview("scratch")

    _run_git(["reset", "-q", "HEAD", "--", "zz_rook_staged_probe.txt"])
    remove_file("zz_rook_staged_probe.txt")
    remove_file("zz_rook_untracked_probe.txt")

    // The staged file is in the staged diff; the untracked one is not.
    assert_true(staged_diff.contains("zz_rook_staged_probe.txt"))
    assert_true(!staged_diff.contains("zz_rook_untracked_probe.txt"))
    // The preview shows the staged file and surfaces the untracked one as
    // something that will not be committed.
    assert_true(preview.contains("zz_rook_staged_probe.txt"))
    assert_true(preview.contains("untracked"))
    assert_true(preview.contains("zz_rook_untracked_probe.txt"))
}

fun _run_git(args: List<String>) {
    match run("git", args) {
        Ok(o) -> {},
        Err(e) -> {},
    }
    return
}
