import std/string
import std/test { assert_true }
import std/fs { write, remove_file }
import "./git" { git_status, git_diff, git_commit, commit_preview }

// These run against the real repository the suite executes in, which is a
// git checkout, so only the read-only tools are exercised for real; the
// commit path is checked through its validation, never committing.

fun test_status_reports_a_branch() {
    let s = git_status()
    assert_true(!s.starts_with("error:"))
    assert_true(s.contains("On branch "))
}

fun test_diff_runs_without_error() {
    let d = git_diff("", "")
    assert_true(!d.starts_with("error:"))
    let staged = git_diff("true", "")
    assert_true(!staged.starts_with("error:"))
}

fun test_commit_rejects_an_empty_message() {
    assert_true(git_commit("", "").starts_with("error:"))
    assert_true(git_commit("   ", "").starts_with("error:"))
}

// Naming a path that does not exist fails at the staging step and never
// reaches the commit, so this is safe to run against the live checkout.
fun test_commit_rejects_unknown_paths() {
    let r = git_commit("a real message", "definitely_not_a_real_file_zzz")
    assert_true(r.starts_with("error:"))
}

// The preview is read-only and describes what a commit would include without
// running it. Empty paths describes the staged changes; a named path
// describes that path.
fun test_commit_preview_is_read_only_and_never_errors() {
    let staged = commit_preview("")
    assert_true(!staged.starts_with("error:"))
    assert_true(staged.length() > 0)
    let named = commit_preview("definitely_not_a_real_file_zzz")
    assert_true(!named.starts_with("error:"))
    assert_true(named.contains("no changes"))
}

// An untracked file named for the commit shows its contents in the preview,
// not just its name, so a new file cannot be committed sight unseen. Reading a
// preview never stages or commits, so this is safe against the live checkout.
fun test_commit_preview_shows_untracked_file_contents() {
    // A name that git does not ignore (the repo ignores _rook_*), so it shows
    // as untracked and exercises the added-file preview.
    write("preview_untracked_tmp.txt", "a brand new line")
    let p = commit_preview("preview_untracked_tmp.txt")
    // Remove the temp file before asserting so a failed assertion cannot leave
    // it behind (the language has no defer/finally).
    remove_file("preview_untracked_tmp.txt")
    assert_true(p.contains("preview_untracked_tmp.txt"))
    assert_true(p.contains("a brand new line"))
    return
}
