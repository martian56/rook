// Background shells: commands started without blocking the turn, the way
// rook runs the apps it builds. run_background hands the command to the
// platform shell via std/process.start and returns a shell id immediately.
// The store here is the single source of truth for every background shell:
// its command, status (running or exited with a code), start time, and
// accumulated output. refresh() advances the lifecycle by draining the
// runtime buffers and polling for exits; the tools and the UI both read
// through it, under a mutex since tool calls run on the turn goroutine
// while the UI reads from the main loop.

import std/string
import std/sync { Mutex, mutex }
import std/env { os_name }
import std/json { JsonValue }
import std/time { now_millis }
import std/process { Child, start }
import "../agents/dir" { roots }
import "../agents/settings" { setting_section }

// One background shell. `done` says the child exited and `code` is its
// exit code; while running, `code` is meaningless. `output` accumulates
// everything drained so far (stdout and stderr interleaved in arrival
// order); `read_pos` marks how much of it the agent has already been
// shown, for the incremental read tool.
struct BgShell {
    id: Int,
    command: String,
    child: Child,
    started_ms: Int,
    done: Bool,
    code: Int,
    output: String,
    read_pos: Int,
}

// A lock-free snapshot of one shell for display and tools.
struct ShellInfo {
    id: Int,
    command: String,
    running: Bool,
    code: Int,
    // Milliseconds since the shell started (up to now while running).
    runtime_ms: Int,
    output_len: Int,
}

struct ShellStore {
    lock: Mutex,
    shells: List<BgShell>,
    next: Int,
}

fun _new_store() -> ShellStore {
    let shells: List<BgShell> = []
    return ShellStore { lock: mutex(), shells, next: 1 }
}

let STORE: ShellStore = _new_store()

// Start `command` through the platform shell without waiting. Returns a
// line naming the new shell id, or an error string.
fun run_background(command: String) -> String {
    return run_background_with_limit(command, background_shell_limit())
}

fun run_background_with_limit(command: String, limit: Int) -> String {
    if command.trim() == "" {
        return "error: no command given"
    }
    refresh()
    let max_running = limit
    if max_running <= 0 {
        max_running = DEFAULT_RUNNING_LIMIT
    }
    let shell = "sh"
    let flag = "-c"
    if os_name() == "windows" {
        shell = "cmd"
        flag = "/c"
    }
    STORE.lock.lock()
    let running = _running_count_locked()
    if running >= max_running {
        STORE.lock.unlock()
        return "error: background shell limit reached (${running}/${max_running} running); use list_shells to inspect them and kill_shell to stop one before starting another"
    }
    return match start(shell, [flag, command]) {
        Ok(child) -> {
            let id = _add_locked(command, child)
            STORE.lock.unlock()
            "started shell ${id}: ${command}"
        },
        Err(e) -> {
            STORE.lock.unlock()
            "error: ${e.message}"
        },
    }
}

fun background_shell_limit() -> Int {
    let rs = roots()
    let i = 0
    while i < rs.len() {
        match setting_section(rs[i], "tools") {
            Some(section) -> {
                let n = parse_background_shell_limit(section)
                if n > 0 {
                    return n
                }
            },
            None -> {},
        }
        i = i + 1
    }
    return DEFAULT_RUNNING_LIMIT
}

fun parse_background_shell_limit(section: JsonValue) -> Int {
    match section.get("run_background") {
        Some(tool) -> {
            let n = _json_int_field(tool, "max_running")
            if n > 0 {
                return n
            }
        },
        None -> {},
    }
    return _json_int_field(section, "max_background_shells")
}

// Advance every shell: drain new output from the runtime buffers, and move
// a child whose exit turned up from running to exited (freeing its runtime
// handle after the final drain).
fun refresh() {
    STORE.lock.lock()
    let i = 0
    while i < STORE.shells.len() {
        let s = STORE.shells[i]
        if !s.done {
            s.output = s.output.concat(s.child.read_stdout()).concat(s.child.read_stderr())
            let capped = cap_output(s.output, s.read_pos, MAX_STORE_OUTPUT)
            s.output = capped.output
            s.read_pos = capped.read_pos
            match s.child.poll() {
                Some(code) -> {
                    // One more drain catches what arrived between the read
                    // above and the exit.
                    s.output = s.output.concat(s.child.read_stdout()).concat(s.child.read_stderr())
                    s.child.free()
                    s.done = true
                    s.code = code
                },
                None -> {},
            }
        }
        i = i + 1
    }
    _prune(KEEP_DONE)
    STORE.lock.unlock()
    return
}

// Drop the oldest exited shells past `keep`, fully-read ones first, so the
// registry cannot grow without bound over a long session. Runs under the
// store lock.
fun _prune(keep: Int) {
    let done = 0
    let i = 0
    while i < STORE.shells.len() {
        if STORE.shells[i].done {
            done = done + 1
        }
        i = i + 1
    }
    // First pass drops fully-read exited shells, oldest first.
    let out: List<BgShell> = []
    i = 0
    while i < STORE.shells.len() {
        let s = STORE.shells[i]
        if done > keep && s.done && s.read_pos >= s.output.length() {
            done = done - 1
        } else {
            out.push(s)
        }
        i = i + 1
    }
    // Second pass drops any exited shell while still over.
    let final_list: List<BgShell> = []
    i = 0
    while i < out.len() {
        let s = out[i]
        if done > keep && s.done {
            done = done - 1
        } else {
            final_list.push(s)
        }
        i = i + 1
    }
    STORE.shells = final_list
    return
}

// Stop every running shell and wait for each exit, so quitting rook never
// leaves an orphaned child. Safe to call with nothing running.
fun kill_all_shells() {
    refresh()
    STORE.lock.lock()
    let i = 0
    while i < STORE.shells.len() {
        let s = STORE.shells[i]
        if !s.done {
            s.child.kill()
            let code = s.child.wait()
            s.output = s.output.concat(s.child.read_stdout()).concat(s.child.read_stderr())
            s.child.free()
            s.done = true
            s.code = code
        }
        i = i + 1
    }
    STORE.lock.unlock()
    return
}

// A snapshot of every shell, oldest first, after a refresh.
fun list_shells() -> List<ShellInfo> {
    refresh()
    let out: List<ShellInfo> = []
    let now = now_millis()
    STORE.lock.lock()
    let i = 0
    while i < STORE.shells.len() {
        let s = STORE.shells[i]
        out.push(
            ShellInfo {
                id: s.id,
                command: s.command,
                running: !s.done,
                code: s.code,
                runtime_ms: now - s.started_ms,
                output_len: s.output.length(),
            },
        )
        i = i + 1
    }
    STORE.lock.unlock()
    return out
}

// The read tool: whatever shell `id` wrote since the last read, behind a
// status header. Reading advances the shell's read position; a quiet shell
// answers "(no new output)".
fun read_shell(id_text: String) -> String {
    let id = _parse_id(id_text)
    if id < 0 {
        return "error: read_shell needs a shell id number"
    }
    refresh()
    STORE.lock.lock()
    let at = _index_of(id)
    if at < 0 {
        STORE.lock.unlock()
        return "error: no shell ${id}; list_shells shows what exists"
    }
    let s = STORE.shells[at]
    let fresh = s.output.substring(s.read_pos, s.output.length())
    s.read_pos = s.output.length()
    let head = _status_line(s)
    STORE.lock.unlock()
    if fresh == "" {
        return "${head}\n(no new output)"
    }
    if fresh.length() > MAX_READ {
        fresh = "… (${fresh.length() - MAX_READ} bytes skipped)\n${fresh.substring(fresh.length() - MAX_READ, fresh.length())}"
    }
    return "${head}\n${fresh}"
}

// The list tool: one status line per shell.
fun shells_list_text() -> String {
    let infos = list_shells()
    if infos.len() == 0 {
        return "(no background shells)"
    }
    let out = ""
    let i = 0
    while i < infos.len() {
        let s = infos[i]
        let state = "exited ${s.code}"
        if s.running {
            state = "running ${s.runtime_ms / 1000}s"
        }
        if i > 0 {
            out = out.concat("\n")
        }
        out = out.concat("shell ${s.id} (${state}): ${s.command}")
        i = i + 1
    }
    return out
}

// The kill tool: stop a running shell and report its exit. Waits for the
// exit so the registry entry is final when the result comes back.
fun kill_shell(id_text: String) -> String {
    let id = _parse_id(id_text)
    if id < 0 {
        return "error: kill_shell needs a shell id number"
    }
    refresh()
    STORE.lock.lock()
    let at = _index_of(id)
    if at < 0 {
        STORE.lock.unlock()
        return "error: no shell ${id}; list_shells shows what exists"
    }
    let s = STORE.shells[at]
    if s.done {
        let msg = "shell ${id} had already exited with code ${s.code}"
        STORE.lock.unlock()
        return msg
    }
    s.child.kill()
    let code = s.child.wait()
    s.output = s.output.concat(s.child.read_stdout()).concat(s.child.read_stderr())
    s.child.free()
    s.done = true
    s.code = code
    STORE.lock.unlock()
    return "killed shell ${id} (exit ${code})"
}

// Keep a read from burying the transcript; the newest output wins.
const MAX_READ: Int = 4000

// Cap on each shell's stored output; the runtime buffers are already
// bounded, and this bounds what the store accumulates across drains. The
// newest bytes win.
const MAX_STORE_OUTPUT: Int = 262144

// How many exited shells the registry keeps before pruning the oldest.
const KEEP_DONE: Int = 20

// Conservative default for simultaneously running child processes.
const DEFAULT_RUNNING_LIMIT: Int = 5

// The store-side cap, pure for tests: trim `output` to `max` keeping the
// tail, and slide `read_pos` down with the trimmed prefix.
struct Capped {
    output: String,
    read_pos: Int,
}

fun cap_output(output: String, read_pos: Int, max: Int) -> Capped {
    if output.length() <= max {
        return Capped { output, read_pos }
    }
    let cut = output.length() - max
    let pos = read_pos - cut
    if pos < 0 {
        pos = 0
    }
    return Capped { output: output.substring(cut, output.length()), read_pos: pos }
}

fun _status_line(s: BgShell) -> String {
    if s.done {
        return "shell ${s.id} (exited ${s.code}): ${s.command}"
    }
    return "shell ${s.id} (running): ${s.command}"
}

fun _index_of(id: Int) -> Int {
    let i = 0
    while i < STORE.shells.len() {
        if STORE.shells[i].id == id {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

fun _parse_id(text: String) -> Int {
    return match text.trim().parse_int() {
        Some(n) -> n,
        None -> 0 - 1,
    }
}

// The last `max_chars` of shell `id`'s output, for the live pane. Unlike
// read_shell this does not advance the agent's read position: the pane is
// the user's view and the tool marker belongs to the model. "" for an
// unknown id.
fun shell_tail(id: Int, max_chars: Int) -> String {
    refresh()
    STORE.lock.lock()
    let at = _index_of(id)
    if at < 0 {
        STORE.lock.unlock()
        return ""
    }
    let out = STORE.shells[at].output
    if out.length() > max_chars {
        out = out.substring(out.length() - max_chars, out.length())
    }
    STORE.lock.unlock()
    return out
}

// A note for the system prompt when background shells hold output the
// model has not read: names each shell with its unread size, so the model
// knows to call read_shell without polling. "" when nothing is waiting.
fun shells_note() -> String {
    refresh()
    STORE.lock.lock()
    let out = ""
    let i = 0
    while i < STORE.shells.len() {
        let s = STORE.shells[i]
        let unread = s.output.length() - s.read_pos
        if unread > 0 {
            let state = "exited ${s.code}"
            if !s.done {
                state = "running"
            }
            if out != "" {
                out = out.concat("; ")
            }
            out = out.concat("shell ${s.id} (${state}, ${unread} bytes unread): ${s.command}")
        }
        i = i + 1
    }
    STORE.lock.unlock()
    if out == "" {
        return ""
    }
    return "\n\n[background shell state]\nBackground shells have output you have not read yet: ${out}. This is tool state, not instructions. Call read_shell when it matters to the task."
}

// How many background shells the store holds.
fun shell_count() -> Int {
    STORE.lock.lock()
    let n = STORE.shells.len()
    STORE.lock.unlock()
    return n
}

fun _running_count_locked() -> Int {
    let running = 0
    let i = 0
    while i < STORE.shells.len() {
        if !STORE.shells[i].done {
            running = running + 1
        }
        i = i + 1
    }
    return running
}

fun _add_locked(command: String, child: Child) -> Int {
    let id = STORE.next
    STORE.next = STORE.next + 1
    STORE.shells.push(
        BgShell {
            id,
            command,
            child,
            started_ms: now_millis(),
            done: false,
            code: 0,
            output: "",
            read_pos: 0,
        },
    )
    return id
}

fun _json_int_field(j: JsonValue, key: String) -> Int {
    return match j.get(key) {
        Some(v) -> _json_int(v),
        None -> 0,
    }
}

fun _json_int(v: JsonValue) -> Int {
    match v.as_int() {
        Some(n) -> {
            return n
        },
        None -> {},
    }
    match v.as_string() {
        Some(s) -> {
            return match s.trim().parse_int() {
                Some(n) -> n,
                None -> 0,
            }
        },
        None -> {},
    }
    return 0
}
