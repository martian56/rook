import std/test { assert_eq_str }
import "./theme" { Theme, default_theme }

fun test_default_theme_is_named() {
    assert_eq_str(default_theme().name, "Rook")
}

// A theme built by hand carries its own name; the app reads whichever Theme is
// active, so swapping the value swaps the whole palette.
fun test_theme_name_is_read_from_the_value() {
    let base = default_theme()
    let custom = Theme {
        name: "Midnight",
        accent: base.accent,
        dim: base.dim,
        text: base.text,
        user: base.user,
        assistant: base.assistant,
        tool: base.tool,
        result: base.result,
        border: base.border,
        modal: base.modal,
        status: base.status,
        spinner: base.spinner,
        warn: base.warn,
        error: base.error,
    }
    assert_eq_str(custom.name, "Midnight")
}
