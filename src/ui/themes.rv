// The built-in palettes: curated Theme values for the picker, dark and light
// variants where the upstream palette defines both. Each palette maps its
// canonical colors onto the Theme roles the same way: the signature color is
// the accent (and the assistant bullet, modals, and spinner), the comment
// color is the chrome, and green, yellow, and red keep their usual jobs.

import std/string
import std/env { get_env, has_env }
import "github.com/martian56/plumage/style" { Style, Color }
import "./theme" { Theme, default_theme, from_colors }
import "../agents/dir" { roots }
import "../agents/palettes" { load_custom_themes }

// Every theme the picker offers: the built-ins (the two defaults first),
// then any user-defined palettes from .agents/themes. Built once and cached:
// the picker reads this on every frame and keystroke, and it walks the roots
// and reads/parses each custom palette from disk. Callers only read the list.
struct ThemeCache {
    ready: Bool,
    themes: List<Theme>,
}

let THEME_CACHE: ThemeCache = _new_theme_cache()

fun _new_theme_cache() -> ThemeCache {
    let themes: List<Theme> = []
    return ThemeCache { ready: false, themes }
}

fun all_themes() -> List<Theme> {
    if !THEME_CACHE.ready {
        THEME_CACHE.themes = merge_custom(builtin_themes(), load_custom_themes(roots()))
        THEME_CACHE.ready = true
    }
    return THEME_CACHE.themes
}

// The curated built-ins. The order here is the picker's order.
fun builtin_themes() -> List<Theme> {
    return [
        default_theme(),
        rook_light(),
        dracula(),
        gruvbox_dark(),
        gruvbox_light(),
        nord(),
        solarized_dark(),
        solarized_light(),
        catppuccin_mocha(),
        catppuccin_latte(),
        tokyo_night(),
    ]
}

// Append the custom palettes, skipping any whose name collides with an
// existing theme (built-ins keep their names).
fun merge_custom(base: List<Theme>, customs: List<Theme>) -> List<Theme> {
    let i = 0
    while i < customs.len() {
        if !_has_name(base, customs[i].name) {
            base.push(customs[i])
        }
        i = i + 1
    }
    return base
}

fun _has_name(themes: List<Theme>, name: String) -> Bool {
    let want = name.to_lower()
    let i = 0
    while i < themes.len() {
        if themes[i].name.to_lower() == want {
            return true
        }
        i = i + 1
    }
    return false
}

// The theme to start with: the remembered choice when it names a built-in,
// else the dark or light default matching the terminal background.
fun startup_theme(saved: String) -> Theme {
    let idx = theme_index(saved)
    if idx >= 0 {
        return all_themes()[idx]
    }
    if background_is_light() {
        return rook_light()
    }
    return default_theme()
}

// Whether the terminal background looks light. The COLORFGBG variable, set by
// several terminals, ends in the background color index; 7 (white) or 15
// (bright white) means light. Absent or unparsable means dark, the common
// case.
fun background_is_light() -> Bool {
    if !has_env("COLORFGBG") {
        return false
    }
    return light_from_colorfgbg(get_env("COLORFGBG"))
}

// The pure half of the detection, split out for tests: parse a COLORFGBG
// value like "15;0" or "0;default;15" and judge its background field.
fun light_from_colorfgbg(v: String) -> Bool {
    let parts = v.split(";")
    if parts.len() < 2 {
        return false
    }
    return match parts[parts.len() - 1].trim().parse_int() {
        Some(bg) -> bg == 7 || bg == 15,
        None -> false,
    }
}

// Look a theme up by name; unknown names fall back to the default.
fun theme_by_name(name: String) -> Theme {
    let idx = theme_index(name)
    if idx < 0 {
        return default_theme()
    }
    return all_themes()[idx]
}

// The position of a theme in all_themes, matched without regard to case so
// "/theme dracula" finds Dracula. -1 when no built-in has that name.
fun theme_index(name: String) -> Int {
    let want = name.to_lower()
    let themes = all_themes()
    let i = 0
    while i < themes.len() {
        if themes[i].name.to_lower() == want {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

// The light counterpart of the default: the coral deepened to stay readable
// on a white background, with darker chrome and inks to match.
fun rook_light() -> Theme {
    return from_colors(
        "Rook Light",
        Color.Rgb(180, 70, 38),
        Color.Rgb(115, 115, 115),
        Color.Rgb(50, 48, 47),
        Color.Rgb(0, 128, 0),
        Color.Rgb(176, 121, 0),
        Color.Rgb(205, 49, 49),
    )
}

