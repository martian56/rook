// Conversation entries and how they turn into styled display lines. This is
// the visual identity of rook: muted "> " user prompts, coral "● " replies,
// green "● " tool calls with an indented result, red notices.

import std/string
import "github.com/martian56/plumage/style" { Style, Color }
import "github.com/martian56/plumage/text" { Span, Line, wrap }
import "./theme" { Theme }

enum Entry {
    UserMsg(String),
    BotMsg(String),
    ToolMsg(String, String),
    Notice(String),
    // A subagent block header: the agent's name and its status line.
    AgentHeader(String, String),
    // One tool a subagent ran, nested under its header: agent, label, result.
    AgentTool(String, String, String),
}

// Where a running subagent's block sits in the entries, so new tool rows
// insert under the right header and the block can collapse when it ends.
// A running subagent's rows in the transcript. `id` is the dispatch's unique
// tool-call id, so two dispatches of the same subagent name stay separate
// blocks instead of collapsing into each other.
struct AgentBlock {
    id: String,
    name: String,
    header: Int,
    tools: Int,
}

// One entry's laid-out lines, cached so a finished entry is wrapped once and
// reused every frame instead of re-wrapped ~22x/second. `valid` false means
// the slot must be recomputed (a fresh, changed, or invalidated entry).
struct EntryLines {
    valid: Bool,
    lines: List<Line>,
}

// An empty, invalid cache slot.
fun empty_entry_lines() -> EntryLines {
    let none: List<Line> = []
    return EntryLines { valid: false, lines: none }
}

// Lay the conversation out as lines wrapped to w columns, styled by the theme.
// Recomputes everything; assemble_cached is the per-frame path.
fun build_lines(entries: List<Entry>, w: Int, theme: Theme) -> List<Line> {
    let out: List<Line> = []
    let i = 0
    while i < entries.len() {
        _append(out, entry_lines(entries[i], w, theme))
        if !_binds_to_next(entries, i) {
            out.push(Line.raw(""))
        }
        i = i + 1
    }
    return out
}

// Assemble the transcript from a per-entry line cache: recompute only the
// slots marked invalid (a new or changed entry), reuse the rest. `cache` is
// index-aligned with `entries` (the caller keeps it so) and is filled in
// place. Separators are applied here, not cached, so a neighbor changing type
// costs only the O(1) _binds_to_next check, not a re-wrap.
fun assemble_cached(
    entries: List<Entry>,
    cache: List<EntryLines>,
    w: Int,
    theme: Theme,
) -> List<Line> {
    let out: List<Line> = []
    let i = 0
    while i < entries.len() {
        if !cache[i].valid {
            cache[i] = EntryLines { valid: true, lines: entry_lines(entries[i], w, theme) }
        }
        _append(out, cache[i].lines)
        if !_binds_to_next(entries, i) {
            out.push(Line.raw(""))
        }
        i = i + 1
    }
    return out
}

// Validate every cache slot (wrapping only the invalid ones) and return the
// total display-line count, separators included. The caller uses the total to
// clamp scrolling before drawing only the visible window.
fun validate_and_count(entries: List<Entry>, cache: List<EntryLines>, w: Int, theme: Theme) -> Int {
    let total = 0
    let i = 0
    while i < entries.len() {
        if !cache[i].valid {
            cache[i] = EntryLines { valid: true, lines: entry_lines(entries[i], w, theme) }
        }
        total = total + cache[i].lines.len()
        if !_binds_to_next(entries, i) {
            total = total + 1
        }
        i = i + 1
    }
    return total
}

// The lines in the window [top, top + count) of the assembled transcript.
// Slots are already valid (validate_and_count ran), so this only walks the
// entries and copies the visible lines: O(entries + count), not O(total
// lines). This is the virtualized per-frame path, so scrolled-off history is
// never materialized.
fun window_lines(
    entries: List<Entry>,
    cache: List<EntryLines>,
    top: Int,
    count: Int,
) -> List<Line> {
    let out: List<Line> = []
    let line_no = 0
    let i = 0
    while i < entries.len() && out.len() < count {
        let el = cache[i].lines
        // Skip entries that sit entirely above the window without walking their
        // lines, so the cost stays O(entries + count) instead of O(total lines
        // above the window). Without this, a long scrolled-down transcript is
        // re-counted line by line on every frame.
        if line_no + el.len() <= top {
            line_no = line_no + el.len()
        } else {
            let j = 0
            while j < el.len() {
                if line_no >= top && out.len() < count {
                    out.push(el[j])
                }
                line_no = line_no + 1
                j = j + 1
            }
        }
        if !_binds_to_next(entries, i) {
            if line_no >= top && out.len() < count {
                out.push(Line.raw(""))
            }
            line_no = line_no + 1
        }
        i = i + 1
    }
    return out
}

// The styled lines for one entry, without the trailing separator.
fun entry_lines(entry: Entry, w: Int, theme: Theme) -> List<Line> {
    let out: List<Line> = []
    let body = w - 2
    if body < 8 {
        body = 8
    }
    match entry {
        UserMsg(t) -> {
            _push_wrapped(out, t, body, "> ", theme.user, theme.user)
        },
        BotMsg(t) -> {
            _push_wrapped(out, t, body, "● ", theme.assistant, theme.text)
        },
        ToolMsg(name, result) -> {
            // A failed call gets the error color on its bullet and result, so
            // failures stand out when scanning a transcript instead of looking
            // exactly like successes.
            let bullet = theme.tool
            let res_style = theme.result
            if result.starts_with("error") {
                bullet = theme.error
                res_style = theme.error
            }
            out.push(Line.from_spans([Span.styled("● ", bullet), Span.styled(name, theme.text.bold())]))
            // The first line sits behind the elbow; any further lines are a
            // diff, colored by their -/+ prefix.
            let rows = result.lines()
            let first = ""
            if rows.len() > 0 {
                first = rows[0]
            }
            out.push(Line.from_spans([Span.styled("  ⎿  ", res_style), Span.styled(first, res_style)]))
            let r = 1
            while r < rows.len() {
                out.push(Line.styled("     ${rows[r]}", _diff_style(rows[r], theme)))
                r = r + 1
            }
        },
        Notice(t) -> {
            out.push(Line.styled("  ${t}", _notice_style(t, theme)))
        },
        AgentHeader(name, status) -> {
            out.push(
                Line.from_spans(
                    [
                        Span.styled("◆ ", theme.assistant),
                        Span.styled("${name} agent", theme.text.bold()),
                        Span.styled("  ${status}", theme.dim),
                    ],
                ),
            )
        },
        AgentTool(agent, name, result) -> {
            let a_bullet = theme.tool
            let a_res = theme.result
            if result.starts_with("error") {
                a_bullet = theme.error
                a_res = theme.error
            }
            out.push(
                Line.from_spans([Span.styled("  ● ", a_bullet), Span.styled(name, theme.text.bold())]),
            )
            out.push(Line.from_spans([Span.styled("    ⎿  ", a_res), Span.styled(result, a_res)]))
        },
    }
    return out
}

fun _append(out: List<Line>, more: List<Line>) {
    let i = 0
    while i < more.len() {
        out.push(more[i])
        i = i + 1
    }
    return
}

// The plain text of one line: its spans' text joined, no styling.
fun plain_of(line: Line) -> String {
    let out = ""
    let i = 0
    while i < line.spans.len() {
        out = out.concat(line.spans[i].text)
        i = i + 1
    }
    return out
}

// The plain text of every assembled transcript line, in order. Used to
// extract a mouse selection; O(total) but only on release, not per frame.
fun transcript_texts(
    entries: List<Entry>,
    cache: List<EntryLines>,
    w: Int,
    theme: Theme,
) -> List<String> {
    let lines = assemble_cached(entries, cache, w, theme)
    let out: List<String> = []
    let i = 0
    while i < lines.len() {
        out.push(plain_of(lines[i]))
        i = i + 1
    }
    return out
}

// The style of one diff line: removals in the error color, additions in
// the tool green, context dim.
// Notices carry both failures and routine confirmations ("theme set to x",
// the per-turn usage line), so only error-shaped text gets the error color;
// everything else renders dim. Confirmations after every successful turn
// should not read as alarms.
fun _notice_style(t: String, theme: Theme) -> Style {
    let low = t.to_lower()
    if low.starts_with("error") || low.contains("error:") || low.starts_with("could not") || low.starts_with(
        "failed",
    ) {
        return theme.error
    }
    return theme.dim
}

fun _diff_style(line: String, theme: Theme) -> Style {
    if line.starts_with("- ") {
        return theme.error
    }
    if line.starts_with("+ ") {
        return theme.tool
    }
    return theme.dim
}

// Whether the entry at i should sit flush against the next one: a header
// above its tools, or a tool row followed by another.
fun _binds_to_next(entries: List<Entry>, i: Int) -> Bool {
    if i + 1 >= entries.len() {
        return false
    }
    let here_block = false
    match entries[i] {
        AgentHeader(n, s) -> {
            here_block = true
        },
        AgentTool(a, n, r) -> {
            here_block = true
        },
        _ -> {},
    }
    if !here_block {
        return false
    }
    let next_tool = false
    match entries[i + 1] {
        AgentTool(a, n, r) -> {
            next_tool = true
        },
        _ -> {},
    }
    return next_tool
}

// Wrap t to the body width and push its rows: the first behind the lead
// marker, the rest indented to line up under it.
fun _push_wrapped(
    out: List<Line>,
    t: String,
    body: Int,
    lead: String,
    lead_style: Style,
    text_style: Style,
) {
    let rows = wrap(t, body)
    if rows.len() == 0 {
        out.push(Line.from_spans([Span.styled(lead, lead_style)]))
        return
    }
    let r = 0
    while r < rows.len() {
        if r == 0 {
            out.push(Line.from_spans([Span.styled(lead, lead_style), Span.styled(rows[r], text_style)]))
        } else {
            out.push(Line.from_spans([Span.styled("  ", text_style), Span.styled(rows[r], text_style)]))
        }
        r = r + 1
    }
    return
}
