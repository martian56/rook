// Conversation entries and how they turn into styled display lines. This is
// the visual identity of rook: muted "> " user prompts, coral "● " replies,
// green "● " tool calls with an indented result, red notices.

import std/string
import "github.com/martian56/plumage/style" { Style, Color }
import "github.com/martian56/plumage/text" { Span, Line, wrap }
import "./theme" { Theme }

enum Entry {
    UserMsg(String),
    BotMsg(String),
    ToolMsg(String, String),
    Notice(String),
}

// Lay the conversation out as lines wrapped to w columns, styled by the theme.
fun build_lines(entries: List<Entry>, w: Int, theme: Theme) -> List<Line> {
    let out: List<Line> = []
    let body = w - 2
    if body < 8 {
        body = 8
    }
    let i = 0
    while i < entries.len() {
        match entries[i] {
            UserMsg(t) -> {
                _push_wrapped(out, t, body, "> ", theme.user, theme.user)
            },
            BotMsg(t) -> {
                _push_wrapped(out, t, body, "● ", theme.assistant, theme.text)
            },
            ToolMsg(name, result) -> {
                out.push(
                    Line.from_spans([Span.styled("● ", theme.tool), Span.styled(name, theme.text.bold())]),
                )
                out.push(
                    Line.from_spans([Span.styled("  ⎿  ", theme.result), Span.styled(result, theme.result)]),
                )
            },
            Notice(t) -> {
                out.push(Line.styled("  ${t}", theme.error))
            },
        }
        out.push(Line.raw(""))
        i = i + 1
    }
    return out
}

// Wrap t to the body width and push its rows: the first behind the lead
// marker, the rest indented to line up under it.
fun _push_wrapped(
    out: List<Line>,
    t: String,
    body: Int,
    lead: String,
    lead_style: Style,
    text_style: Style,
) {
    let rows = wrap(t, body)
    if rows.len() == 0 {
        out.push(Line.from_spans([Span.styled(lead, lead_style)]))
        return
    }
    let r = 0
    while r < rows.len() {
        if r == 0 {
            out.push(Line.from_spans([Span.styled(lead, lead_style), Span.styled(rows[r], text_style)]))
        } else {
            out.push(Line.from_spans([Span.styled("  ", text_style), Span.styled(rows[r], text_style)]))
        }
        r = r + 1
    }
    return
}
