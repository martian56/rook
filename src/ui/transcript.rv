// Conversation entries and how they turn into styled display lines. This is
// the visual identity of rook: muted "> " user prompts, coral "● " replies,
// green "● " tool calls with an indented result, red notices.

import std/string
import "github.com/martian56/plumage/style" { Style, Color }
import "github.com/martian56/plumage/text" { Span, Line, wrap }
import "./theme" { Theme }

enum Entry {
    UserMsg(String),
    BotMsg(String),
    ToolMsg(String, String),
    Notice(String),
    // A subagent block header: the agent's name and its status line.
    AgentHeader(String, String),
    // One tool a subagent ran, nested under its header: agent, label, result.
    AgentTool(String, String, String),
}

// Where a running subagent's block sits in the entries, so new tool rows
// insert under the right header and the block can collapse when it ends.
struct AgentBlock {
    name: String,
    header: Int,
    tools: Int,
}

// Lay the conversation out as lines wrapped to w columns, styled by the theme.
fun build_lines(entries: List<Entry>, w: Int, theme: Theme) -> List<Line> {
    let out: List<Line> = []
    let body = w - 2
    if body < 8 {
        body = 8
    }
    let i = 0
    while i < entries.len() {
        match entries[i] {
            UserMsg(t) -> {
                _push_wrapped(out, t, body, "> ", theme.user, theme.user)
            },
            BotMsg(t) -> {
                _push_wrapped(out, t, body, "● ", theme.assistant, theme.text)
            },
            ToolMsg(name, result) -> {
                out.push(
                    Line.from_spans([Span.styled("● ", theme.tool), Span.styled(name, theme.text.bold())]),
                )
                // The first line sits behind the elbow; any further lines
                // are a diff, colored by their -/+ prefix.
                let rows = result.lines()
                let first = ""
                if rows.len() > 0 {
                    first = rows[0]
                }
                out.push(
                    Line.from_spans([Span.styled("  ⎿  ", theme.result), Span.styled(first, theme.result)]),
                )
                let r = 1
                while r < rows.len() {
                    out.push(Line.styled("     ${rows[r]}", _diff_style(rows[r], theme)))
                    r = r + 1
                }
            },
            Notice(t) -> {
                out.push(Line.styled("  ${t}", theme.error))
            },
            AgentHeader(name, status) -> {
                out.push(
                    Line.from_spans(
                        [
                            Span.styled("◆ ", theme.assistant),
                            Span.styled("${name} agent", theme.text.bold()),
                            Span.styled("  ${status}", theme.dim),
                        ],
                    ),
                )
            },
            AgentTool(agent, name, result) -> {
                out.push(
                    Line.from_spans([Span.styled("  ● ", theme.tool), Span.styled(name, theme.text.bold())]),
                )
                out.push(
                    Line.from_spans(
                        [Span.styled("    ⎿  ", theme.result), Span.styled(result, theme.result)],
                    ),
                )
            },
        }
        // Rows inside an agent block sit tight; everything else gets a blank
        // separator.
        if !_binds_to_next(entries, i) {
            out.push(Line.raw(""))
        }
        i = i + 1
    }
    return out
}

// The style of one diff line: removals in the error color, additions in
// the tool green, context dim.
fun _diff_style(line: String, theme: Theme) -> Style {
    if line.starts_with("- ") {
        return theme.error
    }
    if line.starts_with("+ ") {
        return theme.tool
    }
    return theme.dim
}

// Whether the entry at i should sit flush against the next one: a header
// above its tools, or a tool row followed by another.
fun _binds_to_next(entries: List<Entry>, i: Int) -> Bool {
    if i + 1 >= entries.len() {
        return false
    }
    let here_block = false
    match entries[i] {
        AgentHeader(n, s) -> {
            here_block = true
        },
        AgentTool(a, n, r) -> {
            here_block = true
        },
        _ -> {},
    }
    if !here_block {
        return false
    }
    let next_tool = false
    match entries[i + 1] {
        AgentTool(a, n, r) -> {
            next_tool = true
        },
        _ -> {},
    }
    return next_tool
}

// Wrap t to the body width and push its rows: the first behind the lead
// marker, the rest indented to line up under it.
fun _push_wrapped(
    out: List<Line>,
    t: String,
    body: Int,
    lead: String,
    lead_style: Style,
    text_style: Style,
) {
    let rows = wrap(t, body)
    if rows.len() == 0 {
        out.push(Line.from_spans([Span.styled(lead, lead_style)]))
        return
    }
    let r = 0
    while r < rows.len() {
        if r == 0 {
            out.push(Line.from_spans([Span.styled(lead, lead_style), Span.styled(rows[r], text_style)]))
        } else {
            out.push(Line.from_spans([Span.styled("  ", text_style), Span.styled(rows[r], text_style)]))
        }
        r = r + 1
    }
    return
}
