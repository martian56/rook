import std/string
import std/test { assert_eq_str, assert_true }
import "github.com/martian56/perch/keys" { Key, MouseEvent, MouseKind }
import "github.com/martian56/plumage" { Event }
import "github.com/martian56/plumage/widgets/input" { TextInput }
import "./model" { Chat, chat_init }
import "./update" { apply_events, chat_update, _apply_loaded, _run, _after_model_set, ensure_catalog, refresh_pick }
import "../agent/state" { DisplayEvent }
import "../ui/transcript" { Entry }
import "../config/sessions" { load_session }

fun tag(e: Entry) -> String {
    return match e {
        UserMsg(t) -> "u",
        BotMsg(t) -> "b",
        ToolMsg(n, r) -> "t:${n}",
        Notice(t) -> "n",
        AgentHeader(name, status) -> "h:${name}:${status}",
        AgentTool(agent, n, r) -> "a:${agent}:${n}",
    }
}

fun tags(m: Chat) -> String {
    let out = ""
    let i = 0
    while i < m.entries.len() {
        out = "${out}|${tag(m.entries[i])}"
        i = i + 1
    }
    return out
}

fun notice_text(e: Entry) -> String {
    return match e {
        Notice(t) -> t,
        _ -> "",
    }
}

fun bot_text(e: Entry) -> String {
    return match e {
        BotMsg(t) -> t,
        _ -> "",
    }
}

fun test_parallel_agent_rows_group_under_their_own_headers() {
    let m = chat_init()
    apply_events(
        m,
        [
            DisplayEvent.AgentStarted("e1", "explorer"),
            DisplayEvent.AgentStarted("r1", "reviewer"),
            DisplayEvent.AgentTool("e1", "explorer", "grep(x)", "2 hits"),
            DisplayEvent.AgentTool("r1", "reviewer", "read_file(a)", "ok"),
            DisplayEvent.AgentTool("e1", "explorer", "read_file(b)", "ok"),
        ],
    )
    // Interleaved events, but each agent's rows sit under its own header.
    assert_eq_str(
        tags(m),
        "|h:explorer:working…|a:explorer:grep(x)|a:explorer:read_file(b)|h:reviewer:working…|a:reviewer:read_file(a)",
    )
}

fun test_finished_agents_collapse_to_their_header() {
    let m = chat_init()
    apply_events(
        m,
        [
            DisplayEvent.AgentStarted("e1", "explorer"),
            DisplayEvent.AgentStarted("r1", "reviewer"),
            DisplayEvent.AgentTool("e1", "explorer", "grep(x)", "2 hits"),
            DisplayEvent.AgentTool("r1", "reviewer", "read_file(a)", "ok"),
            DisplayEvent.AgentTool("e1", "explorer", "read_file(b)", "ok"),
            DisplayEvent.AgentFinished("e1", "explorer", 2),
            DisplayEvent.AgentFinished("r1", "reviewer", 1),
        ],
    )
    assert_eq_str(tags(m), "|h:explorer:done · 2 tools|h:reviewer:done · 1 tool")
    assert_true(m.open_agents.len() == 0)
}

fun test_same_name_parallel_subagents_keep_separate_blocks() {
    let m = chat_init()
    apply_events(
        m,
        [
            DisplayEvent.AgentStarted("d1", "researcher"),
            DisplayEvent.AgentStarted("d2", "researcher"),
            DisplayEvent.AgentTool("d1", "researcher", "grep(a)", "hit"),
            DisplayEvent.AgentTool("d2", "researcher", "read(b)", "ok"),
            DisplayEvent.AgentFinished("d1", "researcher", 1),
            DisplayEvent.AgentFinished("d2", "researcher", 1),
        ],
    )
    // Two dispatches of the same subagent name are matched by id, so each keeps
    // its own block and collapses to its own header instead of one swallowing
    // the other's rows.
    assert_eq_str(tags(m), "|h:researcher:done · 1 tool|h:researcher:done · 1 tool")
    assert_true(m.open_agents.len() == 0)
}

fun test_model_picker_caches_and_filters() {
    let m = chat_init()
    ensure_catalog(m)
    // The cache is built once and its three arms stay index-aligned.
    assert_true(m.catalog.ids.len() > 0)
    assert_true(m.catalog.ids.len() == m.catalog.labels.len())
    assert_true(m.catalog.ids.len() == m.catalog.lower.len())
    // An empty search shows the whole catalog.
    m.pick_input = TextInput.new()
    refresh_pick(m)
    assert_true(m.catalog.pick_ids.len() == m.catalog.ids.len())
    assert_true(m.catalog.pick_labels.len() == m.catalog.ids.len())
    // A query narrows to a strict subset, with ids and labels still aligned.
    m.pick_input = TextInput.with_value("openrouter/")
    refresh_pick(m)
    assert_true(m.catalog.pick_ids.len() > 0)
    assert_true(m.catalog.pick_ids.len() < m.catalog.ids.len())
    assert_true(m.catalog.pick_ids.len() == m.catalog.pick_labels.len())
}

fun test_streamed_chunks_accumulate_into_one_bubble() {
    let m = chat_init()
    apply_events(
        m,
        [
            DisplayEvent.Started,
            DisplayEvent.Chunk("Hel"),
            DisplayEvent.Chunk("lo, "),
            DisplayEvent.Chunk("world"),
        ],
    )
    // A batch of deltas folds into a single bubble carrying the full text.
    assert_eq_str(tags(m), "|b")
    assert_eq_str(m.stream_text, "Hello, world")
    assert_eq_str(bot_text(m.entries[m.entries.len() - 1]), "Hello, world")
}

fun test_chunks_flush_before_a_tool_row_and_reset_on_restart() {
    let m = chat_init()
    apply_events(
        m,
        [
            DisplayEvent.Started,
            DisplayEvent.Chunk("first"),
            DisplayEvent.ToolRan("read_file(a)", "ok"),
            DisplayEvent.Started,
            DisplayEvent.Chunk("second"),
        ],
    )
    // The pending text is flushed into the first bubble before the tool row,
    // and a new Started opens a fresh bubble.
    assert_eq_str(tags(m), "|b|t:read_file(a)|b")
    assert_eq_str(bot_text(m.entries[0]), "first")
    assert_eq_str(m.stream_text, "second")
    assert_eq_str(bot_text(m.entries[m.entries.len() - 1]), "second")
}

fun test_the_dispatch_row_lands_after_the_collapsed_block() {
    let m = chat_init()
    apply_events(
        m,
        [
            DisplayEvent.AgentStarted("e1", "explorer"),
            DisplayEvent.AgentTool("e1", "explorer", "grep(x)", "2 hits"),
            DisplayEvent.AgentFinished("e1", "explorer", 1),
            DisplayEvent.ToolRan("dispatch(explorer)", "found it in src/x.rv"),
        ],
    )
    assert_eq_str(tags(m), "|h:explorer:done · 1 tool|t:dispatch(explorer)")
}

fun test_resume_error_is_a_notice() {
    // Resume now reads off the UI thread and _tick applies the result, so the
    // notice-on-error path lives in _apply_loaded. Feed it a failed load
    // directly (a missing id resolves to an error without a heavy read).
    let m = chat_init()
    m.entries.push(Entry.UserMsg("keep this"))
    let failed = load_session("no-such-session-id")
    _apply_loaded(m, "no-such-session-id", failed)
    assert_eq_str(tags(m), "|u|n")
}

fun test_text_only_model_selection_warns_without_reverting() {
    let m = chat_init()
    let selected = "openrouter/perceptron/perceptron-mk1"
    m.model = selected
    _after_model_set(m)
    assert_eq_str(m.model, selected)
    assert_true(m.entries.len() >= 2)
    let warning = notice_text(m.entries[m.entries.len() - 1])
    assert_true(warning.contains("does not advertise tool calling"))
    assert_true(warning.contains("Rook will use it"))
}

fun test_permissions_command_opens_and_esc_closes_the_panel() {
    let m = chat_init()
    m.entry = TextInput.with_value("/permissions")
    let opened = chat_update(m, Event.KeyPress(Key.Enter)).model
    assert_true(opened.permissions_open)
    assert_true(opened.permissions_items.len() == 5)
    let closed = chat_update(opened, Event.KeyPress(Key.Esc)).model
    assert_true(!closed.permissions_open)
}

fun test_active_ticks_preserve_manual_scroll_until_the_user_returns_to_bottom() {
    let m = chat_init()
    m.active = true
    m.agent.begin()

    let scrolled = chat_update(m, Event.KeyPress(Key.PageUp)).model
    assert_true(scrolled.scroll_up == 5)
    let after_tick = chat_update(scrolled, Event.Tick).model
    assert_true(after_tick.scroll_up == 5)

    let following = chat_update(after_tick, Event.KeyPress(Key.PageDown)).model
    assert_true(following.scroll_up == 0)
    let following_tick = chat_update(following, Event.Tick).model
    assert_true(following_tick.scroll_up == 0)
}

fun test_active_ticks_preserve_mouse_wheel_scroll() {
    let m = chat_init()
    m.active = true
    m.agent.begin()
    let wheel = MouseEvent { kind: MouseKind.ScrollUp, button: 0 - 1, x: 0, y: 0 }
    let scrolled = chat_update(m, Event.Mouse(wheel)).model
    assert_true(scrolled.scroll_up == 3)
    let after_tick = chat_update(scrolled, Event.Tick).model
    assert_true(after_tick.scroll_up == 3)
}

fun test_starting_a_new_command_returns_to_live_tail() {
    let m = chat_init()
    m.scroll_up = 12
    let updated = _run(m, "/plan").model
    assert_true(updated.scroll_up == 0)
}

fun test_malformed_mcp_prompt_arguments_are_visible() {
    let m = chat_init()
    let updated = _run(m, "/mcp prompt docs summarize query=\"unterminated").model
    assert_true(updated.entries.len() == 2)
    match updated.entries[1] {
        Notice(text) -> assert_true(text.contains("unterminated")),
        _ -> assert_true(false),
    }
}
