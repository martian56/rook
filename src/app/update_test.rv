import std/string
import std/test { assert_eq_str, assert_true }
import "github.com/martian56/perch/keys" { Key, MouseEvent, MouseKind }
import "github.com/martian56/plumage" { Event }
import "github.com/martian56/plumage/widgets/input" { TextInput }
import "./model" { Chat, chat_init }
import "./update" { apply_events, chat_update, _resume, _run }
import "../agent/state" { DisplayEvent }
import "../ui/transcript" { Entry }

fun tag(e: Entry) -> String {
    return match e {
        UserMsg(t) -> "u",
        BotMsg(t) -> "b",
        ToolMsg(n, r) -> "t:${n}",
        Notice(t) -> "n",
        AgentHeader(name, status) -> "h:${name}:${status}",
        AgentTool(agent, n, r) -> "a:${agent}:${n}",
    }
}

fun tags(m: Chat) -> String {
    let out = ""
    let i = 0
    while i < m.entries.len() {
        out = "${out}|${tag(m.entries[i])}"
        i = i + 1
    }
    return out
}

fun test_parallel_agent_rows_group_under_their_own_headers() {
    let m = chat_init()
    apply_events(
        m,
        [
            DisplayEvent.AgentStarted("explorer"),
            DisplayEvent.AgentStarted("reviewer"),
            DisplayEvent.AgentTool("explorer", "grep(x)", "2 hits"),
            DisplayEvent.AgentTool("reviewer", "read_file(a)", "ok"),
            DisplayEvent.AgentTool("explorer", "read_file(b)", "ok"),
        ],
    )
    // Interleaved events, but each agent's rows sit under its own header.
    assert_eq_str(
        tags(m),
        "|h:explorer:working…|a:explorer:grep(x)|a:explorer:read_file(b)|h:reviewer:working…|a:reviewer:read_file(a)",
    )
}

fun test_finished_agents_collapse_to_their_header() {
    let m = chat_init()
    apply_events(
        m,
        [
            DisplayEvent.AgentStarted("explorer"),
            DisplayEvent.AgentStarted("reviewer"),
            DisplayEvent.AgentTool("explorer", "grep(x)", "2 hits"),
            DisplayEvent.AgentTool("reviewer", "read_file(a)", "ok"),
            DisplayEvent.AgentTool("explorer", "read_file(b)", "ok"),
            DisplayEvent.AgentFinished("explorer", 2),
            DisplayEvent.AgentFinished("reviewer", 1),
        ],
    )
    assert_eq_str(tags(m), "|h:explorer:done · 2 tools|h:reviewer:done · 1 tool")
    assert_true(m.open_agents.len() == 0)
}

fun test_the_dispatch_row_lands_after_the_collapsed_block() {
    let m = chat_init()
    apply_events(
        m,
        [
            DisplayEvent.AgentStarted("explorer"),
            DisplayEvent.AgentTool("explorer", "grep(x)", "2 hits"),
            DisplayEvent.AgentFinished("explorer", 1),
            DisplayEvent.ToolRan("dispatch(explorer)", "found it in src/x.rv"),
        ],
    )
    assert_eq_str(tags(m), "|h:explorer:done · 1 tool|t:dispatch(explorer)")
}

fun test_resume_error_is_a_notice() {
    let m = chat_init()
    m.entries.push(Entry.UserMsg("keep this"))
    _resume(m, "no-such-session-id")
    assert_eq_str(tags(m), "|u|n")
}

fun test_permissions_command_opens_and_esc_closes_the_panel() {
    let m = chat_init()
    m.entry = TextInput.with_value("/permissions")
    let opened = chat_update(m, Event.KeyPress(Key.Enter)).model
    assert_true(opened.permissions_open)
    assert_true(opened.permissions_items.len() == 5)
    let closed = chat_update(opened, Event.KeyPress(Key.Esc)).model
    assert_true(!closed.permissions_open)
}

fun test_active_ticks_preserve_manual_scroll_until_the_user_returns_to_bottom() {
    let m = chat_init()
    m.active = true
    m.agent.begin()

    let scrolled = chat_update(m, Event.KeyPress(Key.PageUp)).model
    assert_true(scrolled.scroll_up == 5)
    let after_tick = chat_update(scrolled, Event.Tick).model
    assert_true(after_tick.scroll_up == 5)

    let following = chat_update(after_tick, Event.KeyPress(Key.PageDown)).model
    assert_true(following.scroll_up == 0)
    let following_tick = chat_update(following, Event.Tick).model
    assert_true(following_tick.scroll_up == 0)
}

fun test_active_ticks_preserve_mouse_wheel_scroll() {
    let m = chat_init()
    m.active = true
    m.agent.begin()
    let wheel = MouseEvent { kind: MouseKind.ScrollUp, button: 0 - 1, x: 0, y: 0 }
    let scrolled = chat_update(m, Event.Mouse(wheel)).model
    assert_true(scrolled.scroll_up == 3)
    let after_tick = chat_update(scrolled, Event.Tick).model
    assert_true(after_tick.scroll_up == 3)
}

fun test_starting_a_new_command_returns_to_live_tail() {
    let m = chat_init()
    m.scroll_up = 12
    let updated = _run(m, "/plan").model
    assert_true(updated.scroll_up == 0)
}

fun test_malformed_mcp_prompt_arguments_are_visible() {
    let m = chat_init()
    let updated = _run(m, "/mcp prompt docs summarize query=\"unterminated").model
    assert_true(updated.entries.len() == 2)
    match updated.entries[1] {
        Notice(text) -> assert_true(text.contains("unterminated")),
        _ -> assert_true(false),
    }
}
