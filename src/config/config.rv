// Which model and theme to use, the model's API key, and how all three
// persist.
//
// Model resolution at startup (highest first): the --model flag, ROOK_MODEL,
// a project ./rook.json "model", the project .agents/settings.json, a global
// ~/.config/rook/rook.json "model", the global ~/.agents/settings.json, the
// last model picked in a previous session, then a built-in default. The
// theme and base_url resolve through the same chain (minus the flag).
//
// The API key for a provider comes from its environment variable, else from
// ~/.rook/auth.json (written when you enter a key with /key). A model whose
// provider has no key runs nothing until one is supplied.

import std/string
import std/env { get_env, has_env, args }
import std/fs { read, write, exists, create_dir_all }
import std/json { JsonValue, parse, stringify }
import "github.com/martian56/aviary/jsonutil" { Obj }
import "../agents/dir" { project_root, global_root }
import "../agents/settings" { setting_str }

// The model used when nothing else selects one. A "provider/model" string.
const DEFAULT_MODEL: String = "openrouter/anthropic/claude-sonnet-5"

fun resolve_model() -> String {
    let a = args()
    let i = 0
    while i < a.len() {
        if a[i] == "--model" && i + 1 < a.len() {
            return a[i + 1]
        }
        i = i + 1
    }
    if has_env("ROOK_MODEL") {
        let v = get_env("ROOK_MODEL")
        if v != "" {
            return v
        }
    }
    let proj = _json_str(_read_opt("rook.json"), "model")
    if proj != "" {
        return proj
    }
    let ps = setting_str(project_root(), "model")
    if ps != "" {
        return ps
    }
    let h = _home()
    if h != "" {
        let glob = _json_str(_read_opt("${h}/.config/rook/rook.json"), "model")
        if glob != "" {
            return glob
        }
    }
    let gs = setting_str(global_root(), "model")
    if gs != "" {
        return gs
    }
    let last = last_used()
    if last != "" {
        return last
    }
    return DEFAULT_MODEL
}

// A custom OpenAI-compatible endpoint, from ROOK_BASE_URL, rook.json, or the
// .agents settings. Empty means use the provider's default endpoint.
fun resolve_base() -> String {
    if has_env("ROOK_BASE_URL") {
        let v = get_env("ROOK_BASE_URL")
        if v != "" {
            return v
        }
    }
    let proj = _json_str(_read_opt("rook.json"), "base_url")
    if proj != "" {
        return proj
    }
    let ps = setting_str(project_root(), "base_url")
    if ps != "" {
        return ps
    }
    return setting_str(global_root(), "base_url")
}

// The theme to start with: a project ./rook.json "theme", the project
// .agents settings, a global ~/.config/rook/rook.json "theme", the global
// .agents settings, the last theme picked in a previous session, else ""
// (the caller falls back to the default palette).
fun resolve_theme() -> String {
    let proj = _json_str(_read_opt("rook.json"), "theme")
    if proj != "" {
        return proj
    }
    let ps = setting_str(project_root(), "theme")
    if ps != "" {
        return ps
    }
    let h = _home()
    if h != "" {
        let glob = _json_str(_read_opt("${h}/.config/rook/rook.json"), "theme")
        if glob != "" {
            return glob
        }
    }
    let gs = setting_str(global_root(), "theme")
    if gs != "" {
        return gs
    }
    if h != "" {
        return _read_opt("${h}/.rook/last-theme").trim()
    }
    return ""
}

// Remember `name` as the theme for the next session.
fun save_theme(name: String) {
    let h = _home()
    if h == "" {
        return
    }
    let dir = "${h}/.rook"
    create_dir_all(dir)
    write("${dir}/last-theme", name)
    return
}

// The last model picked in a previous session, or "" when none was saved.
fun last_used() -> String {
    let p = _state_path()
    if p == "" {
        return ""
    }
    return _read_opt(p).trim()
}

// Remember `model` as the last-used choice for the next session.
fun save_model(model: String) {
    let h = _home()
    if h == "" {
        return
    }
    let dir = "${h}/.rook"
    create_dir_all(dir)
    write("${dir}/last-model", model)
    return
}

// The API key for a model's provider: its environment variable if set, else
// the stored key from ~/.rook/auth.json, else "".
fun resolve_key(model: String) -> String {
    let p = provider_of(model)
    let env = key_env(p)
    if env != "" && has_env(env) {
        let v = get_env(env)
        if v != "" {
            return v
        }
    }
    return stored_key(p)
}

fun stored_key(provider: String) -> String {
    if provider == "" {
        return ""
    }
    return _json_str(_read_opt(_auth_path()), provider)
}

// Store `key` for `provider` in ~/.rook/auth.json, merging with any keys
// already saved for other providers.
fun save_key(provider: String, key: String) {
    let h = _home()
    if h == "" {
        return
    }
    let dir = "${h}/.rook"
    create_dir_all(dir)
    let path = "${dir}/auth.json"
    write(path, _merge_auth(_read_opt(path), provider, key))
    return
}

// Whether a model can run: its provider has a key, or needs none (Ollama).
fun key_present(model: String) -> Bool {
    if provider_of(model) == "ollama" {
        return true
    }
    return resolve_key(model) != ""
}

// Whether a model is missing the key it needs.
fun key_needed(model: String) -> Bool {
    if provider_of(model) == "ollama" {
        return false
    }
    return resolve_key(model) == ""
}

// The provider part of a "provider/model" string, or "" when malformed.
fun provider_of(model: String) -> String {
    let slash = model.index_of("/")
    if slash < 0 {
        return ""
    }
    return model.substring(0, slash)
}

// The environment variable holding a provider's API key, or "" when the
// provider needs none (Ollama) or is unknown.
fun key_env(provider: String) -> String {
    if provider == "openai" {
        return "OPENAI_API_KEY"
    }
    if provider == "anthropic" || provider == "claude" {
        return "ANTHROPIC_API_KEY"
    }
    if provider == "gemini" || provider == "google" {
        return "GEMINI_API_KEY"
    }
    if provider == "groq" {
        return "GROQ_API_KEY"
    }
    if provider == "mistral" {
        return "MISTRAL_API_KEY"
    }
    if provider == "deepseek" {
        return "DEEPSEEK_API_KEY"
    }
    if provider == "openrouter" {
        return "OPENROUTER_API_KEY"
    }
    if provider == "cohere" {
        return "COHERE_API_KEY"
    }
    if provider == "xai" || provider == "grok" {
        return "XAI_API_KEY"
    }
    return ""
}

fun _home() -> String {
    if has_env("HOME") {
        let h = get_env("HOME")
        if h != "" {
            return h
        }
    }
    if has_env("USERPROFILE") {
        return get_env("USERPROFILE")
    }
    return ""
}

fun _state_path() -> String {
    let h = _home()
    if h == "" {
        return ""
    }
    return "${h}/.rook/last-model"
}

fun _auth_path() -> String {
    let h = _home()
    if h == "" {
        return ""
    }
    return "${h}/.rook/auth.json"
}

// Read a file, returning "" when it is missing or unreadable.
fun _read_opt(path: String) -> String {
    if path == "" {
        return ""
    }
    if !exists(path) {
        return ""
    }
    return match read(path) {
        Ok(s) -> s,
        Err(e) -> "",
    }
}

// Rebuild the auth JSON object with `provider` set to `key`, preserving any
// other providers already present.
fun _merge_auth(existing: String, provider: String, key: String) -> String {
    let obj = Obj.new()
    match parse(existing) {
        Ok(j) -> {
            let ks = j.keys()
            let i = 0
            while i < ks.len() {
                if ks[i] != provider {
                    obj = obj.str(ks[i], _field_str(j, ks[i]))
                }
                i = i + 1
            }
        },
        Err(e) -> {},
    }
    obj = obj.str(provider, key)
    return stringify(obj.build())
}

// A string field from a JSON config document, or "" when absent.
fun _json_str(text: String, key: String) -> String {
    if text.trim() == "" {
        return ""
    }
    return match parse(text) {
        Ok(j) -> _field_str(j, key),
        Err(e) -> "",
    }
}

fun _field_str(j: JsonValue, key: String) -> String {
    return match j.get(key) {
        Some(v) -> _as_str(v),
        None -> "",
    }
}

fun _as_str(v: JsonValue) -> String {
    return match v.as_string() {
        Some(s) -> s,
        None -> "",
    }
}
