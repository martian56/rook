// Session persistence: each conversation is saved to ~/.rook/sessions as a
// JSON file (id, created time, model, a title, the transcript entries, and
// the model-visible message history), rewritten after every turn, so work
// survives a restart. /sessions lists the saved ones newest first and resumes
// one: the transcript is restored for display, and the model-visible history
// (tool calls, tool results, and compacted summaries) is restored so the
// model picks up with the same context it had. Sessions saved before the
// message history existed fall back to a text-only rebuild.

import std/string
import std/env { get_env, has_env }
import std/fs { read, write, exists, create_dir_all, list_dir }
import std/json { JsonValue, parse, stringify }
import std/time { now, now_millis }
import "github.com/martian56/aviary/jsonutil" { Obj, field, as_str, as_list }
import "github.com/martian56/aviary/message" { Message, ToolCall, Role, role_str }
import "../ui/transcript" { Entry }

// A saved session's headline, for the picker.
struct SessionMeta {
    id: String,
    created: Int,
    model: String,
    title: String,
}

struct SessionList {
    sessions: List<SessionMeta>,
    error: String,
}

// The restored contents of a session: the display transcript and the
// model-visible history. `messages` is empty for sessions saved before the
// history was persisted, in which case the caller rebuilds a text-only
// context from `entries`.
struct Loaded {
    model: String,
    entries: List<Entry>,
    messages: List<Message>,
    // The session's running token totals, restored so the usage indicator
    // reflects the resumed session instead of resetting to zero.
    usage_prompt: Int,
    usage_completion: Int,
    error: String,
}

// A fresh session id, unique to the millisecond.
fun new_session_id() -> String {
    return "${now_millis()}"
}

// Write the session. A session with no entries is not saved (nothing to
// resume). Overwrites the same file as the conversation grows. `messages` is
// the model-visible history, saved alongside the display transcript so a
// resumed session restores the same model context, not just the visible rows.
// `usage_prompt`/`usage_completion` are the session's running token totals, so
// the usage indicator survives a resume.
fun save_session(
    id: String,
    model: String,
    entries: List<Entry>,
    messages: List<Message>,
    usage_prompt: Int,
    usage_completion: Int,
) -> String {
    if entries.len() == 0 {
        return ""
    }
    let dir = _sessions_dir()
    if dir == "" {
        return "session error: no home directory for sessions"
    }
    return save_session_to(dir, id, model, entries, messages, usage_prompt, usage_completion)
}

fun save_session_to(
    dir: String,
    id: String,
    model: String,
    entries: List<Entry>,
    messages: List<Message>,
    usage_prompt: Int,
    usage_completion: Int,
) -> String {
    if entries.len() == 0 {
        return ""
    }
    if dir == "" {
        return "session error: no session directory"
    }
    match create_dir_all(dir) {
        Ok(ok) -> {},
        Err(e) -> {
            return "session error: could not create session directory: ${e.message}"
        },
    }
    let arr: List<JsonValue> = []
    let i = 0
    while i < entries.len() {
        arr.push(_entry_json(entries[i]))
        i = i + 1
    }
    let msgs: List<JsonValue> = []
    let m = 0
    while m < messages.len() {
        msgs.push(_msg_json(messages[m]))
        m = m + 1
    }
    let doc = Obj.new().str("id", id).str("model", model).str("title", _title(entries))
    doc = doc.str("created", "${now()}").set("entries", JsonValue.Array(arr))
    doc = doc.set("messages", JsonValue.Array(msgs))
    doc = doc.str("usage_prompt", "${usage_prompt}").str("usage_completion", "${usage_completion}")
    return match write("${dir}/${id}.json", stringify(doc.build())) {
        Ok(ok) -> "",
        Err(e) -> "session error: could not save session ${id}: ${e.message}",
    }
}

// Every saved session, newest first.
fun list_sessions() -> List<SessionMeta> {
    return list_sessions_result().sessions
}

fun list_sessions_result() -> SessionList {
    let out: List<SessionMeta> = []
    let dir = _sessions_dir()
    if dir == "" {
        return SessionList { sessions: out, error: "session error: no home directory for sessions" }
    }
    return list_sessions_from(dir)
}

fun list_sessions_from(dir: String) -> SessionList {
    let out: List<SessionMeta> = []
    if dir == "" {
        return SessionList { sessions: out, error: "session error: no session directory" }
    }
    let names: List<String> = []
    match list_dir(dir) {
        Ok(ns) -> {
            names = ns
        },
        Err(e) -> {
            return SessionList {
                sessions: out,
                error: "session error: could not list sessions: ${e.message}",
            }
        },
    }
    let i = 0
    while i < names.len() {
        if names[i].ends_with(".json") {
            let fallback_id = _id_from_filename(names[i])
            match read("${dir}/${names[i]}") {
                Ok(text) -> {
                    match parse(text) {
                        Ok(j) -> {
                            out.push(_meta_from_json(j, fallback_id))
                        },
                        Err(e) -> {
                            out.push(
                                SessionMeta {
                                    id: fallback_id,
                                    created: 0,
                                    model: "",
                                    title: "error: invalid session file: ${names[i]}",
                                },
                            )
                        },
                    }
                },
                Err(e) -> {
                    out.push(
                        SessionMeta {
                            id: fallback_id,
                            created: 0,
                            model: "",
                            title: "error: could not read session file: ${names[i]}",
                        },
                    )
                },
            }
        }
        i = i + 1
    }
    return SessionList { sessions: _sort_newest(out), error: "" }
}

// Restore a session by id.
fun load_session(id: String) -> Loaded {
    let dir = _sessions_dir()
    if dir == "" {
        return _empty_loaded("session error: no home directory for sessions")
    }
    return load_session_from(dir, id)
}

fun load_session_from(dir: String, id: String) -> Loaded {
    if dir == "" {
        return _empty_loaded("session error: no session directory")
    }
    let path = "${dir}/${id}.json"
    if !exists(path) {
        return _empty_loaded("session error: no saved session '${id}'")
    }
    let text = ""
    match read(path) {
        Ok(s) -> {
            text = s
        },
        Err(e) -> {
            return _empty_loaded("session error: could not read session '${id}': ${e.message}")
        },
    }
    return parse_loaded(text, id)
}

fun parse_loaded(text: String, id: String) -> Loaded {
    return match parse(text) {
        Ok(j) -> _loaded_from_json(j),
        Err(e) -> _empty_loaded("session error: invalid JSON in session '${id}': ${e.message}"),
    }
}

fun _loaded_from_json(j: JsonValue) -> Loaded {
    let entries: List<Entry> = []
    let arr = as_list(field(j, "entries"))
    let i = 0
    while i < arr.len() {
        entries.push(_json_entry(arr[i]))
        i = i + 1
    }
    let messages: List<Message> = []
    let marr = as_list(field(j, "messages"))
    let k = 0
    while k < marr.len() {
        messages.push(_json_msg(marr[k]))
        k = k + 1
    }
    return Loaded {
        model: as_str(field(j, "model")),
        entries,
        messages,
        usage_prompt: _int_field(j, "usage_prompt"),
        usage_completion: _int_field(j, "usage_completion"),
        error: "",
    }
}

fun _empty_loaded(error: String) -> Loaded {
    let empty: List<Entry> = []
    let no_msgs: List<Message> = []
    return Loaded {
        model: "",
        entries: empty,
        messages: no_msgs,
        usage_prompt: 0,
        usage_completion: 0,
        error,
    }
}

// An integer stored as a string field, 0 when missing or unparseable (older
// sessions have no usage totals).
fun _int_field(j: JsonValue, key: String) -> Int {
    return match as_str(field(j, key)).parse_int() {
        Some(n) -> n,
        None -> 0,
    }
}

fun _entry_json(e: Entry) -> JsonValue {
    return match e {
        UserMsg(t) -> Obj.new().str("k", "user").str("a", t).build(),
        BotMsg(t) -> Obj.new().str("k", "bot").str("a", t).build(),
        ToolMsg(name, result) -> Obj.new().str("k", "tool").str("a", name).str("b", result).build(),
        Notice(t) -> Obj.new().str("k", "notice").str("a", t).build(),
        AgentHeader(name, status) -> Obj.new().str("k", "ahdr").str("a", name).str("b", status).build(),
        AgentTool(agent, name, result) -> Obj.new().str("k", "atool").str("a", agent).str("b", name).str(
            "c",
            result,
        ).build(),
    }
}

fun _json_entry(j: JsonValue) -> Entry {
    let k = as_str(field(j, "k"))
    let a = as_str(field(j, "a"))
    let b = as_str(field(j, "b"))
    if k == "user" {
        return Entry.UserMsg(a)
    }
    if k == "bot" {
        return Entry.BotMsg(a)
    }
    if k == "tool" {
        return Entry.ToolMsg(a, b)
    }
    if k == "ahdr" {
        return Entry.AgentHeader(a, b)
    }
    if k == "atool" {
        return Entry.AgentTool(a, b, as_str(field(j, "c")))
    }
    return Entry.Notice(a)
}

// One model-visible message to JSON: role and content, plus the tool calls
// on an assistant turn and the tool_call_id/name on a tool result, so the
// exact structure round-trips.
fun _msg_json(m: Message) -> JsonValue {
    let calls: List<JsonValue> = []
    let i = 0
    while i < m.tool_calls.len() {
        let c = m.tool_calls[i]
        calls.push(Obj.new().str("id", c.id).str("name", c.name).str("args", c.arguments).build())
        i = i + 1
    }
    return Obj.new().str("role", role_str(m.role)).str("content", m.content).set(
        "calls",
        JsonValue.Array(calls),
    ).str("tool_call_id", m.tool_call_id).str("name", m.name).build()
}

fun _json_msg(j: JsonValue) -> Message {
    let calls: List<ToolCall> = []
    let arr = as_list(field(j, "calls"))
    let i = 0
    while i < arr.len() {
        calls.push(
            ToolCall {
                id: as_str(field(arr[i], "id")),
                name: as_str(field(arr[i], "name")),
                arguments: as_str(field(arr[i], "args")),
            },
        )
        i = i + 1
    }
    return Message {
        role: _role_of(as_str(field(j, "role"))),
        content: as_str(field(j, "content")),
        tool_calls: calls,
        tool_call_id: as_str(field(j, "tool_call_id")),
        name: as_str(field(j, "name")),
    }
}

// A stored role name back to a Role; unknown names fall back to User.
fun _role_of(s: String) -> Role {
    if s == "system" {
        return Role.System
    }
    if s == "assistant" {
        return Role.Assistant
    }
    if s == "tool" {
        return Role.Tool
    }
    return Role.User
}

// The session title: the first user message, trimmed to one short line.
fun _title(entries: List<Entry>) -> String {
    let i = 0
    while i < entries.len() {
        let t = match entries[i] {
            UserMsg(txt) -> txt,
            _ -> "",
        }
        if t != "" {
            let line = t
            let nl = line.index_of("\n")
            if nl >= 0 {
                line = line.substring(0, nl)
            }
            if line.length() > 60 {
                line = line.substring(0, 60)
            }
            return line
        }
        i = i + 1
    }
    return "(no messages)"
}

fun _sort_newest(xs: List<SessionMeta>) -> List<SessionMeta> {
    // Small lists; a simple selection sort by created, descending.
    let out = xs
    let i = 0
    while i < out.len() {
        let best = i
        let j = i + 1
        while j < out.len() {
            if out[j].created > out[best].created {
                best = j
            }
            j = j + 1
        }
        if best != i {
            let tmp = out[i]
            out[i] = out[best]
            out[best] = tmp
        }
        i = i + 1
    }
    return out
}

fun _meta_from_json(j: JsonValue, fallback_id: String) -> SessionMeta {
    let id = as_str(field(j, "id"))
    if id == "" {
        id = fallback_id
    }
    return SessionMeta {
        id,
        created: _created(j),
        model: as_str(field(j, "model")),
        title: as_str(field(j, "title")),
    }
}

// The created timestamp, stored as a string.
fun _created(j: JsonValue) -> Int {
    return match as_str(field(j, "created")).parse_int() {
        Some(n) -> n,
        None -> 0,
    }
}

fun _id_from_filename(name: String) -> String {
    if name.ends_with(".json") {
        return name.substring(0, name.length() - 5)
    }
    return name
}

fun _sessions_dir() -> String {
    let h = _home()
    if h == "" {
        return ""
    }
    return "${h}/.rook/sessions"
}

fun _home() -> String {
    if has_env("HOME") {
        let h = get_env("HOME")
        if h != "" {
            return h
        }
    }
    if has_env("USERPROFILE") {
        return get_env("USERPROFILE")
    }
    return ""
}
