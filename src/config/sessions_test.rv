import std/string
import std/test { assert_eq_str, assert_eq_int, assert_true }
import std/fs { write, create_dir_all, remove_file, remove_dir }
import std/env { get_env, has_env }
import "./sessions" { SessionMeta, Loaded, new_session_id, save_session, save_session_to, list_sessions, list_sessions_from, load_session, load_session_from }
import "github.com/martian56/aviary/message" { Message, ToolCall, role_str }
import "../ui/transcript" { Entry }

fun _no_msgs() -> List<Message> {
    let m: List<Message> = []
    return m
}

fun _entry_tag(e: Entry) -> String {
    return match e {
        UserMsg(t) -> "u:${t}",
        BotMsg(t) -> "b:${t}",
        ToolMsg(n, r) -> "t:${n}:${r}",
        Notice(t) -> "n:${t}",
        AgentHeader(n, s) -> "h:${n}:${s}",
        AgentTool(a, n, r) -> "a:${a}:${n}:${r}",
    }
}

fun test_save_list_load_round_trip() {
    let id = new_session_id()
    let entries = [
        Entry.UserMsg("fix the parser"),
        Entry.BotMsg("looking now"),
        Entry.ToolMsg("read_file(x)", "ok"),
        Entry.AgentHeader("explorer", "done"),
    ]
    assert_eq_str(save_session(id, "openai/gpt-5.5", entries, _no_msgs(), 0, 0), "")

    // The session appears in the list with its title and model.
    let all = list_sessions()
    let found = _find(all, id)
    assert_true(found.id == id)
    assert_eq_str(found.title, "fix the parser")
    assert_eq_str(found.model, "openai/gpt-5.5")
    assert_true(found.created > 0)

    // Loading restores the model and every entry, in order.
    let loaded = load_session(id)
    assert_eq_str(loaded.model, "openai/gpt-5.5")
    assert_eq_int(loaded.entries.len(), 4)
    assert_eq_str(_entry_tag(loaded.entries[0]), "u:fix the parser")
    assert_eq_str(_entry_tag(loaded.entries[1]), "b:looking now")
    assert_eq_str(_entry_tag(loaded.entries[2]), "t:read_file(x):ok")
    assert_eq_str(_entry_tag(loaded.entries[3]), "h:explorer:done")

    _cleanup(id)
    return
}

fun test_title_uses_the_first_user_message() {
    let id = new_session_id()
    assert_eq_str(
        save_session(
            id,
            "m",
            [Entry.Notice("hi"), Entry.UserMsg("second line here")],
            _no_msgs(),
            0,
            0,
        ),
        "",
    )
    assert_eq_str(_find(list_sessions(), id).title, "second line here")
    _cleanup(id)
    return
}

fun test_empty_session_is_not_saved() {
    let id = new_session_id()
    let none: List<Entry> = []
    assert_eq_str(save_session(id, "m", none, _no_msgs(), 0, 0), "")
    assert_true(_find(list_sessions(), id).id != id)
}

fun test_unknown_id_loads_empty() {
    let loaded = load_session("no-such-session-id")
    assert_eq_int(loaded.entries.len(), 0)
    assert_eq_str(loaded.model, "")
    assert_eq_int(loaded.messages.len(), 0)
    assert_eq_int(loaded.usage_prompt, 0)
    assert_eq_int(loaded.usage_completion, 0)
    assert_true(loaded.error.contains("no saved session"))
}

// The model-visible history round-trips with full structure: an assistant
// turn's tool calls and a tool result's id, name, and content all survive, so
// a resumed session gives the model back the same context, not just the
// visible user and assistant lines.
fun test_model_history_round_trips() {
    let id = new_session_id()
    let entries = [Entry.UserMsg("read x"), Entry.BotMsg("done")]
    let call = ToolCall { id: "c1", name: "read_file", arguments: "{\"path\":\"x\"}" }
    let msgs = [
        Message.user("read x"),
        Message.assistant_calls("reading it", [call]),
        Message.tool_result("c1", "read_file", "the file contents"),
        Message.assistant("done"),
    ]
    assert_eq_str(save_session(id, "m", entries, msgs, 1200, 340), "")

    let loaded = load_session(id)
    assert_eq_int(loaded.messages.len(), 4)
    assert_eq_str(role_str(loaded.messages[0].role), "user")
    assert_eq_str(loaded.messages[0].content, "read x")
    // The assistant turn keeps its tool call.
    assert_eq_str(role_str(loaded.messages[1].role), "assistant")
    assert_eq_int(loaded.messages[1].tool_calls.len(), 1)
    assert_eq_str(loaded.messages[1].tool_calls[0].id, "c1")
    assert_eq_str(loaded.messages[1].tool_calls[0].name, "read_file")
    assert_eq_str(loaded.messages[1].tool_calls[0].arguments, "{\"path\":\"x\"}")
    // The tool result keeps the id it answers, its name, and its content.
    assert_eq_str(role_str(loaded.messages[2].role), "tool")
    assert_eq_str(loaded.messages[2].tool_call_id, "c1")
    assert_eq_str(loaded.messages[2].name, "read_file")
    assert_eq_str(loaded.messages[2].content, "the file contents")
    // The running token totals round-trip too, so a resume keeps the usage.
    assert_eq_int(loaded.usage_prompt, 1200)
    assert_eq_int(loaded.usage_completion, 340)

    _cleanup(id)
    return
}

fun test_save_session_reports_write_failures() {
    let root = "_rook_session_fail_${new_session_id()}"
    let id = "blocked"
    create_dir_all(root)
    create_dir_all("${root}/${id}.json")

    let err = save_session_to(root, id, "m", [Entry.UserMsg("hello")], _no_msgs(), 0, 0)
    assert_true(err.starts_with("session error: could not save session blocked"))

    remove_dir("${root}/${id}.json")
    remove_dir(root)
    return
}

fun test_malformed_session_files_are_listed_and_load_reports_error() {
    let root = "_rook_session_bad_${new_session_id()}"
    let id = "broken"
    create_dir_all(root)
    write("${root}/${id}.json", "{\"entries\":")

    let listed = list_sessions_from(root)
    assert_eq_str(listed.error, "")
    let found = _find(listed.sessions, id)
    assert_eq_str(found.id, id)
    assert_true(found.title.starts_with("error: invalid session file"))

    let loaded = load_session_from(root, id)
    assert_eq_int(loaded.entries.len(), 0)
    assert_true(loaded.error.starts_with("session error: invalid JSON in session"))

    remove_file("${root}/${id}.json")
    remove_dir(root)
    return
}

fun test_session_list_reports_directory_errors() {
    let path = "_rook_session_list_file_${new_session_id()}"
    write(path, "not a directory")

    let listed = list_sessions_from(path)
    assert_eq_int(listed.sessions.len(), 0)
    assert_true(listed.error.starts_with("session error: could not list sessions"))

    remove_file(path)
    return
}

fun _find(xs: List<SessionMeta>, id: String) -> SessionMeta {
    let i = 0
    while i < xs.len() {
        if xs[i].id == id {
            return xs[i]
        }
        i = i + 1
    }
    return SessionMeta { id: "", created: 0, model: "", title: "" }
}

fun _cleanup(id: String) {
    let home = _home()
    if home == "" {
        return
    }
    remove_file("${home}/.rook/sessions/${id}.json")
    return
}

fun _home() -> String {
    if has_env("HOME") {
        let h = get_env("HOME")
        if h != "" {
            return h
        }
    }
    if has_env("USERPROFILE") {
        return get_env("USERPROFILE")
    }
    return ""
}
