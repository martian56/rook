// The models the /model picker offers. The complete generated OpenRouter
// snapshot comes first, followed by curated direct-provider choices.
// This is a convenience list, not a limit: /model <provider/model> accepts
// any string aviary can route, so a newly released model is still reachable
// by typing it before the next catalog refresh.

import std/string
import "./openrouter_catalog" { openrouter_catalog, openrouter_models_without_tools }
import "./direct_catalog" { direct_catalog }

fun catalog() -> List<String> {
    let items = openrouter_catalog()
    let direct = direct_catalog()
    let i = 0
    while i < direct.len() {
        items.push(direct[i])
        i = i + 1
    }
    return items
}

// The catalog narrowed to entries containing `query`, ignoring case. An
// empty query is the whole catalog. Feeds the picker's search bar.
fun filter_catalog(items: List<String>, query: String) -> List<String> {
    let q = query.trim().to_lower()
    if q == "" {
        return items
    }
    let out: List<String> = []
    let i = 0
    while i < items.len() {
        if items[i].to_lower().contains(q) {
            out.push(items[i])
        }
        i = i + 1
    }
    return out
}

// A lowercased copy of each entry, built once so the picker can filter on
// every keystroke without lowercasing the whole catalog each time.
fun catalog_lower(items: List<String>) -> List<String> {
    let out: List<String> = []
    let i = 0
    while i < items.len() {
        out.push(items[i].to_lower())
        i = i + 1
    }
    return out
}

// The picker label keeps capability text separate from the real model ID, so
// searching and selection still operate on the provider/model string.
fun catalog_label(model: String) -> String {
    if supports_tools(model) {
        return "[tools] ${model}"
    }
    return "[no tools] ${model}"
}

fun catalog_labels(items: List<String>) -> List<String> {
    let labels: List<String> = []
    let without = openrouter_models_without_tools()
    let i = 0
    while i < items.len() {
        if _supports_tools(items[i], without) {
            labels.push("[tools] ${items[i]}")
        } else {
            labels.push("[no tools] ${items[i]}")
        }
        i = i + 1
    }
    return labels
}

// Direct choices are curated for agent use. OpenRouter publishes capability
// metadata, so its generated no-tools list is authoritative for those rows.
fun supports_tools(model: String) -> Bool {
    return _supports_tools(model, openrouter_models_without_tools())
}

fun _supports_tools(model: String, without: List<String>) -> Bool {
    if !model.starts_with("openrouter/") {
        return true
    }
    let i = 0
    while i < without.len() {
        if without[i] == model {
            return false
        }
        i = i + 1
    }
    return true
}

// Selecting a text-only model is allowed, but normal Rook turns may need
// function calls to inspect, edit, or test a project.
fun model_capability_warning(model: String) -> String {
    if supports_tools(model) {
        return ""
    }
    return "warning: ${model} does not advertise tool calling; Rook will use it, but normal agent turns may not work"
}

// The index of `model` in the catalog, or 0 when it is not listed (so the
// picker opens at the top rather than out of range).
fun index_of(model: String) -> Int {
    let items = catalog()
    let i = 0
    while i < items.len() {
        if items[i] == model {
            return i
        }
        i = i + 1
    }
    return 0
}
