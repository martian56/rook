// The models the /model picker offers. The complete generated OpenRouter
// snapshot comes first, followed by curated direct-provider choices.
// This is a convenience list, not a limit: /model <provider/model> accepts
// any string aviary can route, so a newly released model is still reachable
// by typing it before the next catalog refresh.

import std/string
import "./openrouter_catalog" { openrouter_catalog }
import "./direct_catalog" { direct_catalog }

fun catalog() -> List<String> {
    let items = openrouter_catalog()
    let direct = direct_catalog()
    let i = 0
    while i < direct.len() {
        items.push(direct[i])
        i = i + 1
    }
    return items
}

// The catalog narrowed to entries containing `query`, ignoring case. An
// empty query is the whole catalog. Feeds the picker's search bar.
fun filter_catalog(items: List<String>, query: String) -> List<String> {
    let q = query.trim().to_lower()
    if q == "" {
        return items
    }
    let out: List<String> = []
    let i = 0
    while i < items.len() {
        if items[i].to_lower().contains(q) {
            out.push(items[i])
        }
        i = i + 1
    }
    return out
}

// The index of `model` in the catalog, or 0 when it is not listed (so the
// picker opens at the top rather than out of range).
fun index_of(model: String) -> Int {
    let items = catalog()
    let i = 0
    while i < items.len() {
        if items[i] == model {
            return i
        }
        i = i + 1
    }
    return 0
}
