// The models the /model picker offers, OpenRouter first since that is the
// common testing path. Refreshed for mid-2026: the current flagships and the
// models topping the OpenRouter usage leaderboard. This is a convenience
// list, not a limit: /model <provider/model> accepts any string aviary can
// route, so a model missing here is still reachable by typing it.

import std/string

fun catalog() -> List<String> {
    return [
        "openrouter/anthropic/claude-sonnet-5",
        "openrouter/anthropic/claude-fable-5",
        "openrouter/anthropic/claude-opus-4.8",
        "openrouter/anthropic/claude-sonnet-4.6",
        "openrouter/anthropic/claude-haiku-4.5",
        "openrouter/openai/gpt-5.5",
        "openrouter/openai/gpt-5.1",
        "openrouter/google/gemini-3.1-pro",
        "openrouter/google/gemini-3.1-flash",
        "openrouter/deepseek/deepseek-v4-flash",
        "openrouter/deepseek/deepseek-v4-pro",
        "openrouter/deepseek/deepseek-v4",
        "openrouter/moonshotai/kimi-k2.7-code",
        "openrouter/moonshotai/kimi-k2.6",
        "openrouter/minimax/minimax-m3",
        "openrouter/z-ai/glm-5.2",
        "openrouter/meta-llama/llama-5",
        "openrouter/qwen/qwen3.7-max",
        "openrouter/qwen/qwen3.6-27b",
        "openrouter/x-ai/grok-4.1",
