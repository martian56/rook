        "ollama/llama3",
    ]
}

// The catalog narrowed to entries containing `query`, ignoring case. An
// empty query is the whole catalog. Feeds the picker's search bar.
fun filter_catalog(items: List<String>, query: String) -> List<String> {
    let q = query.trim().to_lower()
    if q == "" {
        return items
    }
    let out: List<String> = []
    let i = 0
    while i < items.len() {
        if items[i].to_lower().contains(q) {
            out.push(items[i])
        }
        i = i + 1
    }
    return out
}

// The index of `model` in the catalog, or 0 when it is not listed (so the
// picker opens at the top rather than out of range).
fun index_of(model: String) -> Int {
    let items = catalog()
    let i = 0
    while i < items.len() {
        if items[i] == model {
            return i
        }
        i = i + 1
    }
    return 0
}
