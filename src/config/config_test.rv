import std/string
import std/test { assert_eq_str, assert_true, assert_false }
import std/fs { read, write, remove_file, exists }
import "./config" { provider_of, key_env, key_present, key_needed, key_needed_with, auth_with_key, save_key_to_path, _check_rook_json, _attribution_of }
import "./catalog" { catalog, filter_catalog, index_of, catalog_label, catalog_labels, supports_tools, model_capability_warning }
import "./direct_catalog" { direct_catalog }
import "./openrouter_catalog" { openrouter_catalog, openrouter_models_without_tools }

fun test_provider_of() {
    assert_eq_str(provider_of("openai/gpt-4o"), "openai")
    assert_eq_str(provider_of("openrouter/anthropic/claude-3.5-sonnet"), "openrouter")
    assert_eq_str(provider_of("nomodel"), "")
}

fun test_key_env_mapping() {
    assert_eq_str(key_env("anthropic"), "ANTHROPIC_API_KEY")
    assert_eq_str(key_env("claude"), "ANTHROPIC_API_KEY")
    assert_eq_str(key_env("openai"), "OPENAI_API_KEY")
    assert_eq_str(key_env("grok"), "XAI_API_KEY")
    assert_eq_str(key_env("together"), "TOGETHER_API_KEY")
    assert_eq_str(key_env("fireworks"), "FIREWORKS_API_KEY")
    assert_eq_str(key_env("perplexity"), "PERPLEXITY_API_KEY")
    assert_eq_str(key_env("deepinfra"), "DEEPINFRA_API_KEY")
    assert_eq_str(key_env("nebius"), "NEBIUS_API_KEY")
    assert_eq_str(key_env("moonshot"), "MOONSHOT_API_KEY")
    assert_eq_str(key_env("sakana"), "SAKANA_API_KEY")
    assert_eq_str(key_env("azure"), "AZURE_API_KEY")
    assert_eq_str(key_env("custom"), "AVIARY_API_KEY")
    assert_eq_str(key_env("unknown"), "")
}

fun test_ollama_needs_no_key() {
    assert_true(key_present("ollama/llama3"))
    assert_false(key_needed("ollama/llama3"))
}

fun test_custom_endpoint_key_is_optional() {
    assert_true(key_present("custom/local-model"))
    assert_false(key_needed("custom/local-model"))
}

fun test_unknown_provider_has_no_key() {
    assert_false(key_present("mystery/model"))
}

fun test_auth_with_key_creates_a_new_auth_object() {
    let updated = auth_with_key("", "openai", "new-key")
    assert_true(updated.ok)
    assert_true(updated.text.contains("\"openai\":\"new-key\""))
}

fun test_auth_with_key_preserves_other_provider_keys() {
    let existing = "{\"anthropic\":\"old-a\",\"openai\":\"old-o\"}"
    let updated = auth_with_key(existing, "openai", "new-o")
    assert_true(updated.ok)
    assert_true(updated.text.contains("\"anthropic\":\"old-a\""))
    assert_true(updated.text.contains("\"openai\":\"new-o\""))
    assert_true(!updated.text.contains("old-o"))
}

fun test_auth_with_key_rejects_malformed_json() {
    let updated = auth_with_key("{\"anthropic\":", "openai", "new-o")
    assert_true(!updated.ok)
    assert_true(updated.error.contains("not valid JSON"))
    assert_eq_str(updated.text, "")
}

fun test_save_key_to_path_does_not_overwrite_malformed_auth() {
    write("_rook_auth_bad.json", "{\"anthropic\":")
    let err = save_key_to_path("_rook_auth_bad.json", "openai", "new-o")
    assert_true(err.contains("not valid JSON"))
    match read("_rook_auth_bad.json") {
        Ok(text) -> assert_eq_str(text, "{\"anthropic\":"),
        Err(e) -> assert_true(false),
    }
    remove_file("_rook_auth_bad.json")
    return
}

fun test_save_key_to_path_creates_missing_auth_file() {
    if exists("_rook_auth_new.json") {
        match remove_file("_rook_auth_new.json") {
            Ok(ok) -> {},
            Err(e) -> {},
        }
    }
    let err = save_key_to_path("_rook_auth_new.json", "openai", "new-o")
    assert_eq_str(err, "")
    match read("_rook_auth_new.json") {
        Ok(text) -> assert_true(text.contains("\"openai\":\"new-o\"")),
        Err(e) -> assert_true(false),
    }
    remove_file("_rook_auth_new.json")
    return
}

fun test_catalog_index_round_trips() {
    let items = catalog()
    assert_true(items.len() > 440)
    let pick = "openrouter/deepseek/deepseek-v4-flash"
    assert_eq_str(items[index_of(pick)], pick)
}

fun test_catalog_index_of_unlisted_is_zero() {
    assert_true(index_of("not/in/the/list") == 0)
}

fun test_catalog_carries_the_2026_flagships() {
    let all = ""
    let items = catalog()
    let i = 0
    while i < items.len() {
        all = "${all} ${items[i]}"
        i = i + 1
    }
    assert_true(all.contains("claude-sonnet-5"))
    assert_true(all.contains("claude-fable-5"))
    assert_true(all.contains("openai/gpt-5.6-sol"))
    assert_true(all.contains("gpt-5.6-sol"))
    assert_true(all.contains("google/gemini-3.5-flash"))
    assert_true(all.contains("kimi-k2.7"))
    assert_true(all.contains("moonshot/kimi-k3"))
    assert_true(all.contains("moonshotai/kimi-k3"))
    assert_true(all.contains("glm-5.2"))
    assert_true(all.contains("xai/grok-4.5"))
    assert_true(all.contains("sakana/fugu"))
    assert_true(all.contains("sakana/fugu-ultra"))
}

fun test_direct_catalog_covers_every_static_picker_provider() {
    let items = direct_catalog()
    let all = ""
    let i = 0
    while i < items.len() {
        all = "${all} ${items[i]}"
        i = i + 1
    }
    let providers = [
        "openai/",
        "anthropic/",
        "google/",
        "cohere/",
        "groq/",
        "mistral/",
        "deepseek/",
        "xai/",
        "together/",
        "fireworks/",
        "perplexity/",
        "deepinfra/",
        "nebius/",
        "moonshot/",
        "sakana/",
        "ollama/",
    ]
    i = 0
    while i < providers.len() {
        assert_true(all.contains(providers[i]))
        i = i + 1
    }
}

fun test_direct_catalog_has_no_duplicate_ids() {
    let items = direct_catalog()
    assert_true(items.len() >= 100)
    let i = 0
    while i < items.len() {
        let j = i + 1
        while j < items.len() {
            assert_true(items[i] != items[j])
            j = j + 1
        }
        i = i + 1
    }
}

fun test_direct_catalog_excludes_retiring_aliases() {
    let all = ""
    let items = direct_catalog()
    let i = 0
    while i < items.len() {
        all = "${all} ${items[i]}"
        i = i + 1
    }
    assert_false(all.contains("deepseek/deepseek-chat"))
    assert_false(all.contains("deepseek/deepseek-reasoner"))
    assert_false(all.contains("groq/llama-3.1-8b-instant"))
    assert_false(all.contains("groq/llama-3.3-70b-versatile"))
}

fun test_openrouter_catalog_contains_the_complete_snapshot() {
    let items = openrouter_catalog()
    assert_true(items.len() >= 342)
    let all = ""
    let i = 0
    while i < items.len() {
        assert_true(items[i].starts_with("openrouter/"))
        all = "${all} ${items[i]}"
        i = i + 1
    }
    assert_true(all.contains("openrouter/sakana/fugu-ultra"))
    assert_true(all.contains("openrouter/openai/gpt-5.6-sol"))
    assert_true(all.contains("openrouter/anthropic/claude-sonnet-5"))
    assert_true(all.contains("openrouter/google/gemini-3.5-flash"))
    assert_true(all.contains("openrouter/qwen/qwen3.7-max"))
}

fun test_openrouter_catalog_has_no_duplicate_ids() {
    let items = openrouter_catalog()
    let i = 0
    while i < items.len() {
        let j = i + 1
        while j < items.len() {
            assert_true(items[i] != items[j])
            j = j + 1
        }
        i = i + 1
    }
}

fun test_openrouter_catalog_preserves_tool_capabilities() {
    let without = openrouter_models_without_tools()
    assert_true(without.len() >= 75)
    assert_true(supports_tools("openrouter/openai/gpt-5.6-sol"))
    assert_false(supports_tools("openrouter/perceptron/perceptron-mk1"))
    assert_true(supports_tools("sakana/fugu-ultra"))
}

fun test_catalog_labels_distinguish_tool_support() {
    assert_eq_str(
        catalog_label("openrouter/openai/gpt-5.6-sol"),
        "[tools] openrouter/openai/gpt-5.6-sol",
    )
    assert_eq_str(
        catalog_label("openrouter/perceptron/perceptron-mk1"),
        "[no tools] openrouter/perceptron/perceptron-mk1",
    )
    let labels = catalog_labels(
        ["openrouter/openai/gpt-5.6-sol", "openrouter/perceptron/perceptron-mk1"],
    )
    assert_true(labels.len() == 2)
    assert_true(labels[0].starts_with("[tools]"))
    assert_true(labels[1].starts_with("[no tools]"))
}

fun test_model_capability_warning_does_not_block_selection() {
    assert_eq_str(model_capability_warning("openrouter/openai/gpt-5.6-sol"), "")
    let warning = model_capability_warning("openrouter/perceptron/perceptron-mk1")
    assert_true(warning.contains("does not advertise tool calling"))
    assert_true(warning.contains("Rook will use it"))
}

fun test_filter_narrows_by_substring_ignoring_case() {
    let items = catalog()
    assert_true(filter_catalog(items, "").len() == items.len())
    let hits = filter_catalog(items, "DeepSeek")
    assert_true(hits.len() >= 3)
    assert_true(hits[0].contains("deepseek"))
    assert_true(filter_catalog(items, "no such model").len() == 0)
    let fable = filter_catalog(items, "fable")
    assert_true(fable.len() >= 2)
    let sakana = filter_catalog(items, "SAKANA")
    assert_true(sakana.len() >= 1)
    assert_true(sakana[0].to_lower().contains("sakana"))
}

fun test_key_needed_with_uses_the_given_key() {
    // Key-optional providers never need a key, even with an empty one.
    assert_false(key_needed_with("ollama/llama3", ""))
    assert_false(key_needed_with("custom/local", ""))
    // Others need a key only when the given one is empty.
    assert_false(key_needed_with("openai/gpt-5.6", "sk-abc"))
    assert_true(key_needed_with("openai/gpt-5.6", ""))
}

fun test_malformed_rook_json_is_flagged() {
    write("_rook_cfg_bad.json", "{\"model\": ")
    let bad: List<String> = []
    _check_rook_json("_rook_cfg_bad.json", bad)
    assert_true(bad.len() == 1)
    assert_true(bad[0].contains("invalid JSON"))
    remove_file("_rook_cfg_bad.json")

    write("_rook_cfg_ok.json", "{\"model\": \"openai/gpt-5.6\"}")
    let ok: List<String> = []
    _check_rook_json("_rook_cfg_ok.json", ok)
    assert_true(ok.len() == 0)
    remove_file("_rook_cfg_ok.json")

    // A missing file is not an error.
    let none: List<String> = []
    _check_rook_json("_rook_cfg_absent.json", none)
    assert_true(none.len() == 0)
}

fun test_attribution_flag_parses_from_json() {
    // 0 unset, 1 enabled, 2 disabled.
    assert_true(_attribution_of("") == 0)
    assert_true(_attribution_of("{}") == 0)
    assert_true(_attribution_of("{\"attribution\": true}") == 1)
    assert_true(_attribution_of("{\"attribution\": false}") == 2)
    assert_true(_attribution_of("not json") == 0)
}
