import std/string
import std/test { assert_eq_str, assert_true, assert_false }
import std/fs { read, write, remove_file, exists }
import "./config" { provider_of, key_env, key_present, auth_with_key, save_key_to_path }
import "./catalog" { catalog, filter_catalog, index_of }

fun test_provider_of() {
    assert_eq_str(provider_of("openai/gpt-4o"), "openai")
    assert_eq_str(provider_of("openrouter/anthropic/claude-3.5-sonnet"), "openrouter")
    assert_eq_str(provider_of("nomodel"), "")
}

fun test_key_env_mapping() {
    assert_eq_str(key_env("anthropic"), "ANTHROPIC_API_KEY")
    assert_eq_str(key_env("claude"), "ANTHROPIC_API_KEY")
    assert_eq_str(key_env("openai"), "OPENAI_API_KEY")
    assert_eq_str(key_env("grok"), "XAI_API_KEY")
    assert_eq_str(key_env("unknown"), "")
}

fun test_ollama_needs_no_key() {
    assert_true(key_present("ollama/llama3"))
}

fun test_unknown_provider_has_no_key() {
    assert_false(key_present("mystery/model"))
}

fun test_auth_with_key_creates_a_new_auth_object() {
    let updated = auth_with_key("", "openai", "new-key")
    assert_true(updated.ok)
    assert_true(updated.text.contains("\"openai\":\"new-key\""))
}

fun test_auth_with_key_preserves_other_provider_keys() {
    let existing = "{\"anthropic\":\"old-a\",\"openai\":\"old-o\"}"
    let updated = auth_with_key(existing, "openai", "new-o")
    assert_true(updated.ok)
    assert_true(updated.text.contains("\"anthropic\":\"old-a\""))
    assert_true(updated.text.contains("\"openai\":\"new-o\""))
    assert_true(!updated.text.contains("old-o"))
}

fun test_auth_with_key_rejects_malformed_json() {
    let updated = auth_with_key("{\"anthropic\":", "openai", "new-o")
    assert_true(!updated.ok)
    assert_true(updated.error.contains("not valid JSON"))
    assert_eq_str(updated.text, "")
}

fun test_save_key_to_path_does_not_overwrite_malformed_auth() {
    write("_rook_auth_bad.json", "{\"anthropic\":")
    let err = save_key_to_path("_rook_auth_bad.json", "openai", "new-o")
    assert_true(err.contains("not valid JSON"))
    match read("_rook_auth_bad.json") {
        Ok(text) -> assert_eq_str(text, "{\"anthropic\":"),
        Err(e) -> assert_true(false),
    }
    remove_file("_rook_auth_bad.json")
    return
}

fun test_save_key_to_path_creates_missing_auth_file() {
    if exists("_rook_auth_new.json") {
        match remove_file("_rook_auth_new.json") {
            Ok(ok) -> {},
            Err(e) -> {},
        }
    }
    let err = save_key_to_path("_rook_auth_new.json", "openai", "new-o")
    assert_eq_str(err, "")
    match read("_rook_auth_new.json") {
        Ok(text) -> assert_true(text.contains("\"openai\":\"new-o\"")),
        Err(e) -> assert_true(false),
    }
    remove_file("_rook_auth_new.json")
    return
}

fun test_catalog_index_round_trips() {
    let items = catalog()
    assert_true(items.len() > 30)
    let pick = "openrouter/deepseek/deepseek-v4-flash"
    assert_eq_str(items[index_of(pick)], pick)
}

fun test_catalog_index_of_unlisted_is_zero() {
    assert_true(index_of("not/in/the/list") == 0)
}

fun test_catalog_carries_the_2026_flagships() {
    let all = ""
    let items = catalog()
    let i = 0
    while i < items.len() {
        all = "${all} ${items[i]}"
        i = i + 1
    }
    assert_true(all.contains("claude-sonnet-5"))
    assert_true(all.contains("claude-fable-5"))
    assert_true(all.contains("gpt-5.5"))
    assert_true(all.contains("gemini-3.1-pro"))
    assert_true(all.contains("kimi-k2.7"))
    assert_true(all.contains("llama-5"))
    assert_true(all.contains("glm-5.2"))
    assert_true(all.contains("grok-4.1"))
}

fun test_filter_narrows_by_substring_ignoring_case() {
    let items = catalog()
    assert_true(filter_catalog(items, "").len() == items.len())
    let hits = filter_catalog(items, "DeepSeek")
    assert_true(hits.len() >= 3)
    assert_true(hits[0].contains("deepseek"))
    assert_true(filter_catalog(items, "no such model").len() == 0)
    let fable = filter_catalog(items, "fable")
    assert_true(fable.len() == 2)
}
