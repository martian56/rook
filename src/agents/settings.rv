// Settings: the .agents/settings.json read alongside rook.json. The schema:
//
//   {
//     "model": "provider/model",
//     "theme": "Nord",
//     "base_url": "http://localhost:11434/v1",
//     "permissions": { ... },
//     "tools": { ... },
//     "mcp": { ... }
//   }
//
// The three string fields are consumed by config resolution. The object
// sections configure permissions, tools, and MCP servers. A project
// settings.json outranks the global one, and each sits below the same root's
// rook.json in the overall resolution order.

import std/string
import std/fs { read, exists }
import std/json { JsonValue, parse }

struct SettingsLoad {
    path: String,
    present: Bool,
    text: String,
    error: String,
}

// A top-level string field from the settings.json under `root`, "" when the
// root is empty, the file is absent or unreadable, or the field is not a
// string.
fun setting_str(root: String, key: String) -> String {
    let loaded = load_settings(root)
    if !loaded.present || loaded.error != "" {
        return ""
    }
    return setting_from(loaded.text, key)
}

// The pure half: pull one string field out of a settings document.
fun setting_from(text: String, key: String) -> String {
    if text.trim() == "" {
        return ""
    }
    return match parse(text) {
        Ok(j) -> _field_str(j, key),
        Err(e) -> "",
    }
}

// A top-level object section (permissions, tools, mcp) from the settings
// under `root`, for the features that consume them. None when absent.
fun setting_section(root: String, key: String) -> Option<JsonValue> {
    let loaded = load_settings(root)
    if !loaded.present || loaded.error != "" || loaded.text.trim() == "" {
        return None
    }
    return match parse(loaded.text) {
        Ok(j) -> j.get(key),
        Err(e) -> None,
    }
}

// Read one root's settings file while preserving the distinction between a
// missing file and a file that exists but cannot be read.
fun load_settings(root: String) -> SettingsLoad {
    let path = ""
    if root != "" {
        path = "${root}/settings.json"
    }
    if path == "" || !exists(path) {
        return SettingsLoad { path, present: false, text: "", error: "" }
    }
    return match read(path) {
        Ok(s) -> SettingsLoad { path, present: true, text: s, error: "" },
        Err(e) -> SettingsLoad {
            path,
            present: true,
            text: "",
            error: "settings error: could not read ${path}: ${e.message}",
        },
    }
}

// The error for one settings root, if the file exists but cannot be used.
fun settings_error_for(root: String) -> Option<String> {
    let loaded = load_settings(root)
    if loaded.error != "" {
        return Some(loaded.error)
    }
    if loaded.present && loaded.text.trim() != "" {
        return match parse(loaded.text) {
            Ok(j) -> None,
            Err(e) -> Some("settings error: invalid JSON in ${loaded.path}: ${e.message}"),
        }
    }
    return None
}

// Human-readable diagnostics for settings files that exist but cannot be
// used. Missing files stay quiet.
fun settings_errors_from(rs: List<String>) -> List<String> {
    let out: List<String> = []
    let i = 0
    while i < rs.len() {
        match settings_error_for(rs[i]) {
            Some(msg) -> out.push(msg),
            None -> {},
        }
        i = i + 1
    }
    return out
}

fun _field_str(j: JsonValue, key: String) -> String {
    return match j.get(key) {
        Some(v) -> match v.as_string() {
            Some(s) -> s,
            None -> "",
        },
        None -> "",
    }
}
