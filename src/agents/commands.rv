// Custom slash commands: prompt templates under .agents/commands/, one
// <name>.md per command, registered as /name. The file is optional
// frontmatter (a one-line description shown in /help) over a markdown body,
// the template. "$ARGUMENTS" in the template is replaced by whatever the
// user typed after the command name; a template without the placeholder gets
// the arguments appended instead.

import std/string
import std/sync { Mutex, mutex }
import std/fs { read, is_file }
import "./dir" { merged_names, path_of }
import "./front" { Front, parse_front, front_get }
import "../commands" { CmdInfo }

// The loaded commands, cached so running a custom command does not re-walk
// and re-read every command file. Invalidated when a plugin changes and at
// the end of every turn (a turn can create command files); a file added
// externally mid-session appears after the next turn ends.
struct CommandCache {
    lock: Mutex,
    ready: Bool,
    cmds: List<CustomCommand>,
}

let COMMAND_CACHE: CommandCache = _new_command_cache()

fun _new_command_cache() -> CommandCache {
    let cmds: List<CustomCommand> = []
    return CommandCache { lock: mutex(), ready: false, cmds }
}

// The commands under `rs`, from the cache when it is warm.
fun cached_commands(rs: List<String>) -> List<CustomCommand> {
    COMMAND_CACHE.lock.lock()
    if !COMMAND_CACHE.ready {
        COMMAND_CACHE.cmds = load_commands(rs)
        COMMAND_CACHE.ready = true
    }
    let out = COMMAND_CACHE.cmds
    COMMAND_CACHE.lock.unlock()
    return out
}

// Drop the cache so the next lookup re-reads the command files.
fun invalidate_commands() {
    COMMAND_CACHE.lock.lock()
    COMMAND_CACHE.ready = false
    COMMAND_CACHE.lock.unlock()
    return
}

struct CustomCommand {
    name: String,
    description: String,
    template: String,
}

// Load every command under the roots' commands/ folders, project shadowing
// global by file name. Only .md files count; the file stem is the name.
fun load_commands(rs: List<String>) -> List<CustomCommand> {
    let out: List<CustomCommand> = []
    let names = merged_names(rs, "commands")
    let i = 0
    while i < names.len() {
        if names[i].ends_with(".md") {
            let p = path_of(rs, "commands", names[i])
            if p != "" && is_file(p) {
                match read(p) {
                    Ok(text) -> {
                        out.push(parse_command_file(text, names[i].substring(0, names[i].length() - 3)))
                    },
                    Err(e) -> {},
                }
            }
        }
        i = i + 1
    }
    return out
}

// Parse one command file: frontmatter between "---" lines may set the
// description; the rest is the template.
fun parse_command_file(text: String, name: String) -> CustomCommand {
    let fm = parse_front(text)
    return CustomCommand { name, description: front_get(fm, "description"), template: fm.body }
}

// Expand typed input like "/release 1.2" against the commands. "" when the
// input is not a slash command or no command matches, so the caller falls
// through to its unknown-command handling.
fun find_expansion(cmds: List<CustomCommand>, text: String) -> String {
    if !text.starts_with("/") {
        return ""
    }
    let rest = text.substring(1, text.length())
    let name = rest
    let args = ""
    let sp = rest.index_of(" ")
    if sp >= 0 {
        name = rest.substring(0, sp)
        args = rest.substring(sp + 1, rest.length()).trim()
    }
    let want = name.to_lower()
    let i = 0
    while i < cmds.len() {
        if cmds[i].name.to_lower() == want {
            return expand(cmds[i].template, args)
        }
        i = i + 1
    }
    return ""
}

// Fill a template with the arguments: replace "$ARGUMENTS" where present,
// else append non-empty arguments after a blank line.
fun expand(template: String, args: String) -> String {
    if template.contains("$ARGUMENTS") {
        return template.replace("$ARGUMENTS", args)
    }
    if args == "" {
        return template
    }
    return "${template}\n\n${args}"
}

// The custom commands as menu entries, for the slash menu and /help.
fun command_infos(cmds: List<CustomCommand>) -> List<CmdInfo> {
    let out: List<CmdInfo> = []
    let i = 0
    while i < cmds.len() {
        let d = cmds[i].description
        if d == "" {
            d = "custom command"
        }
        out.push(CmdInfo { name: cmds[i].name, desc: d })
        i = i + 1
    }
    return out
}
