import std/string
import std/test { assert_eq_str, assert_eq_int, assert_true }
import std/fs { write, create_dir_all, remove_file, remove_dir }
import "./settings" { setting_str, setting_from, setting_section, settings_errors_from }

const DOC: String = "{\"model\": \"openai/gpt-4o\", \"theme\": \"Nord\", \"permissions\": {\"allow\": [\"read_file\"]}}"

fun test_setting_from_reads_string_fields() {
    assert_eq_str(setting_from(DOC, "model"), "openai/gpt-4o")
    assert_eq_str(setting_from(DOC, "theme"), "Nord")
    assert_eq_str(setting_from(DOC, "base_url"), "")
}

fun test_setting_from_tolerates_bad_input() {
    assert_eq_str(setting_from("", "model"), "")
    assert_eq_str(setting_from("not json", "model"), "")
    assert_eq_str(setting_from(DOC, "permissions"), "")
}

fun test_setting_str_reads_a_root() {
    create_dir_all("_rook_set")
    write("_rook_set/settings.json", DOC)
    assert_eq_str(setting_str("_rook_set", "theme"), "Nord")
    assert_eq_str(setting_str("_rook_set", "missing"), "")
    assert_eq_str(setting_str("_rook_set_absent", "theme"), "")
    assert_eq_str(setting_str("", "theme"), "")
    remove_file("_rook_set/settings.json")
    remove_dir("_rook_set")
    return
}

fun test_setting_section_finds_objects() {
    create_dir_all("_rook_sec")
    write("_rook_sec/settings.json", DOC)
    let found = false
    match setting_section("_rook_sec", "permissions") {
        Some(v) -> {
            found = true
        },
        None -> {},
    }
    assert_true(found)
    let absent = true
    match setting_section("_rook_sec", "mcp") {
        Some(v) -> {
            absent = false
        },
        None -> {},
    }
    assert_true(absent)
    remove_file("_rook_sec/settings.json")
    remove_dir("_rook_sec")
    return
}

fun test_settings_errors_report_invalid_project_and_global_files() {
    create_dir_all("_rook_bad_project")
    create_dir_all("_rook_bad_global")
    write("_rook_bad_project/settings.json", "{\"permissions\":")
    write("_rook_bad_global/settings.json", "{\"mcp\":")
    let errors = settings_errors_from(["_rook_bad_project", "_rook_bad_global"])
    assert_eq_int(errors.len(), 2)
    assert_true(errors[0].contains("_rook_bad_project/settings.json"))
    assert_true(errors[0].contains("invalid JSON"))
    assert_true(errors[1].contains("_rook_bad_global/settings.json"))
    assert_true(errors[1].contains("invalid JSON"))
    assert_eq_str(setting_str("_rook_bad_project", "model"), "")
    let section_missing = true
    match setting_section("_rook_bad_project", "permissions") {
        Some(v) -> {
            section_missing = false
        },
        None -> {},
    }
    assert_true(section_missing)
    remove_file("_rook_bad_project/settings.json")
    remove_file("_rook_bad_global/settings.json")
    remove_dir("_rook_bad_project")
    remove_dir("_rook_bad_global")
    return
}

fun test_missing_settings_files_are_quiet() {
    let errors = settings_errors_from(["_rook_missing_settings"])
    assert_eq_int(errors.len(), 0)
}
