// Caps for text pulled into the model's context from project- or server-
// controlled sources (skill bodies, subagent prompts, MCP resources, MCP tool
// results). Without a bound, one oversized source can swallow the context
// window, bury the recent user intent, slow the UI, or force compaction far
// earlier than expected. Each cap leaves a source-labeled [truncated] marker
// so the model, and the reader, can see what was cut and where it came from.

import std/string

// `text` truncated to about `max` bytes, with a labeled marker when it was
// cut. `source` names where the text came from, e.g. "skill body".
fun cap_text(text: String, max: Int, source: String) -> String {
    if text.length() <= max {
        return text
    }
    return "${text.substring(0, _safe_cut(text, max))}\n[truncated: ${source}]"
}

// A one-liner clipped to about `max` bytes with an ellipsis, for index rows
// (a skill or subagent description) where a newline-marked cap would break the
// layout.
fun clip_line(text: String, max: Int) -> String {
    if text.length() <= max {
        return text
    }
    return "${text.substring(0, _safe_cut(text, max))}…"
}

// The largest cut point at or below `max` that lands on a UTF-8 character
// boundary. Raven strings are byte buffers and substring cuts on bytes, so
// slicing at `max` blindly can split a multi-byte character and emit invalid
// text; back off over any trailing continuation bytes first. The caller only
// invokes this when the text is longer than `max`, so `max` is a valid index.
// The largest cut position at or below `max` that does not split a UTF-8
// sequence. Public so other truncation sites (session titles, memory) reuse it
// instead of cutting on a raw byte boundary.
fun safe_cut(text: String, max: Int) -> Int {
    return _safe_cut(text, max)
}

fun _safe_cut(text: String, max: Int) -> Int {
    let cut = max
    while cut > 0 && _is_continuation(text.byte_at(cut)) {
        cut = cut - 1
    }
    return cut
}

// Whether a byte is a UTF-8 continuation byte (10xxxxxx), i.e. the middle of a
// multi-byte character rather than the start of one.
fun _is_continuation(b: Int) -> Bool {
    return b >= 128 && b < 192
}
