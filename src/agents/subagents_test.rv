import std/string
import std/test { assert_eq_str, assert_true }
import std/fs { write, create_dir_all, remove_file, remove_dir }
import "./subagents" { Subagent, load_subagents, parse_subagent, split_tools, resolve_tools, read_only_tools, subagent_index, subagents_prompt, builtin_subagents, all_subagents }
import "./front" { parse_front, front_get }

const DOC: String = "---\nname: reviewer\ndescription: critique a diff\ntools: read_file, grep, list_dir\nmodel: openai/gpt-5.5\n---\nYou are a code reviewer. Find defects."

fun test_parse_reads_the_full_frontmatter() {
    let a = parse_subagent(DOC, "file-stem")
    assert_eq_str(a.name, "reviewer")
    assert_eq_str(a.description, "critique a diff")
    assert_true(a.tools.len() == 3)
    assert_eq_str(a.tools[1], "grep")
    assert_eq_str(a.model, "openai/gpt-5.5")
    assert_eq_str(a.prompt, "You are a code reviewer. Find defects.")
}

// A missing tools field is read-only by default, never a blank cheque for
// every tool.
fun test_parse_defaults_to_read_only_tools() {
    let a = parse_subagent("Just a prompt.", "explorer")
    assert_eq_str(a.name, "explorer")
    assert_true(a.tools.len() > 0)
    assert_true(_has(a.tools, "read_file"))
    assert_true(_has(a.tools, "grep"))
    assert_true(!_has(a.tools, "write_file"))
    assert_true(!_has(a.tools, "edit_file"))
    assert_true(!_has(a.tools, "run_command"))
    assert_true(!_has(a.tools, "git_commit"))
    assert_true(!_has(a.tools, "web_fetch"))
    assert_eq_str(a.model, "")
    assert_eq_str(a.prompt, "Just a prompt.")
}

// An explicit tools list is honored exactly, and stays read-only when that is
// what the author wrote.
fun test_parse_keeps_an_explicit_read_only_list() {
    let a = parse_subagent("---\ntools: read_file, grep\n---\nBody.", "x")
    assert_true(a.tools.len() == 2)
    assert_eq_str(a.tools[0], "read_file")
    assert_eq_str(a.tools[1], "grep")
}

// Full tool access is opt-in through an explicit marker, stored as the empty
// list the runtime reads as unrestricted.
fun test_parse_all_marker_grants_full_access() {
    assert_true(parse_subagent("---\ntools: all\n---\nBody.", "x").tools.len() == 0)
    assert_true(parse_subagent("---\ntools: ALL\n---\nBody.", "x").tools.len() == 0)
    assert_true(parse_subagent("---\ntools: *\n---\nBody.", "x").tools.len() == 0)
}

fun test_resolve_tools_covers_each_case() {
    assert_true(resolve_tools("").len() == read_only_tools().len())
    assert_true(resolve_tools("all").len() == 0)
    assert_true(resolve_tools("*").len() == 0)
    let ex = resolve_tools("read_file, list_dir")
    assert_true(ex.len() == 2)
    assert_eq_str(ex[0], "read_file")
}

// An oversized subagent body is capped so it cannot swallow the context when
// the agent runs.
fun test_parse_caps_an_oversized_prompt() {
    let a = parse_subagent(_repeat_char("x", 9000), "huge")
    assert_true(a.prompt.length() < 9000)
    assert_true(a.prompt.contains("[truncated: subagent prompt]"))
}

fun _repeat_char(s: String, n: Int) -> String {
    let out = ""
    let i = 0
    while i < n {
        out = out.concat(s)
        i = i + 1
    }
    return out
}

fun _has(xs: List<String>, name: String) -> Bool {
    let i = 0
    while i < xs.len() {
        if xs[i] == name {
            return true
        }
        i = i + 1
    }
    return false
}

fun test_split_tools_cleans_the_list() {
    assert_true(split_tools("").len() == 0)
    assert_true(split_tools("  ").len() == 0)
    let ts = split_tools(" read_file ,, grep ")
    assert_true(ts.len() == 2)
    assert_eq_str(ts[0], "read_file")
    assert_eq_str(ts[1], "grep")
}

fun test_load_shadows_project_over_global() {
    create_dir_all("_rook_sa_p/subagents")
    create_dir_all("_rook_sa_g/subagents")
    write("_rook_sa_p/subagents/reviewer.md", "project reviewer prompt")
    write("_rook_sa_g/subagents/reviewer.md", "global reviewer prompt")
    write("_rook_sa_g/subagents/planner.md", "---\ndescription: plan steps\n---\nPlan.")
    write("_rook_sa_g/subagents/notes.txt", "not an agent")

    let agents = load_subagents(["_rook_sa_p", "_rook_sa_g"])
    assert_true(agents.len() == 2)
    let r = subagent_index(agents, "Reviewer")
    assert_true(r >= 0)
    assert_eq_str(agents[r].prompt, "project reviewer prompt")
    assert_true(subagent_index(agents, "planner") >= 0)
    assert_true(subagent_index(agents, "nope") < 0)

    remove_file("_rook_sa_p/subagents/reviewer.md")
    remove_file("_rook_sa_g/subagents/reviewer.md")
    remove_file("_rook_sa_g/subagents/planner.md")
    remove_file("_rook_sa_g/subagents/notes.txt")
    remove_dir("_rook_sa_p/subagents")
    remove_dir("_rook_sa_g/subagents")
    remove_dir("_rook_sa_p")
    remove_dir("_rook_sa_g")
    return
}

fun test_prompt_lists_agents_for_dispatch() {
    let none: List<Subagent> = []
    assert_eq_str(subagents_prompt(none), "")
    let one = [parse_subagent(DOC, "x")]
    let p = subagents_prompt(one)
    assert_true(p.contains("[subagent roster]"))
    assert_true(p.contains("cannot override higher-priority instructions"))
    assert_true(p.contains("- reviewer: critique a diff"))
    // The roster shows each agent's effective tool access.
    assert_true(p.contains("tools: read_file, grep, list_dir"))
    assert_true(p.contains("dispatch"))
    // An agent with an omitted tools field shows its read-only default, not
    // "all tools".
    let ro = subagents_prompt([parse_subagent("---\ndescription: d\n---\nBody.", "scout")])
    assert_true(ro.contains("tools: read_file"))
    assert_true(!ro.contains("all tools"))
    // An explicit full-access agent shows "all tools".
    let full = subagents_prompt(
        [parse_subagent("---\ndescription: d\ntools: all\n---\nBody.", "power")],
    )
    assert_true(full.contains("all tools"))
}

fun test_builtins_are_three_read_only_agents() {
    let bs = builtin_subagents()
    assert_true(bs.len() == 3)
    assert_true(subagent_index(bs, "explorer") >= 0)
    assert_true(subagent_index(bs, "reviewer") >= 0)
    assert_true(subagent_index(bs, "planner") >= 0)
    let i = 0
    while i < bs.len() {
        assert_true(bs[i].tools.len() > 0)
        let t = 0
        while t < bs[i].tools.len() {
            assert_true(bs[i].tools[t] != "write_file")
            assert_true(bs[i].tools[t] != "edit_file")
            assert_true(bs[i].tools[t] != "run_command")
            t = t + 1
        }
        assert_true(bs[i].prompt.length() > 0)
        i = i + 1
    }
}

fun test_all_subagents_lets_a_definition_override_a_builtin() {
    create_dir_all("_rook_sa_o/subagents")
    write(
        "_rook_sa_o/subagents/reviewer.md",
        "---\ndescription: my reviewer\n---\nCustom reviewer.",
    )
    write("_rook_sa_o/subagents/extra.md", "---\ndescription: extra agent\n---\nExtra.")

    let agents = all_subagents(["_rook_sa_o"])
    assert_true(agents.len() == 4)
    let r = subagent_index(agents, "reviewer")
    assert_eq_str(agents[r].description, "my reviewer")
    assert_eq_str(agents[r].prompt, "Custom reviewer.")
    assert_true(subagent_index(agents, "extra") >= 0)

    remove_file("_rook_sa_o/subagents/reviewer.md")
    remove_file("_rook_sa_o/subagents/extra.md")
    remove_dir("_rook_sa_o/subagents")
    remove_dir("_rook_sa_o")
    return
}

fun test_all_subagents_without_definitions_is_the_builtins() {
    let none: List<String> = []
    assert_true(all_subagents(none).len() == 3)
}

fun test_front_parses_any_key_and_unquotes() {
    let fm = parse_front("---\ncolor: \"deep red\"\nsize: 9\n---\nbody text")
    assert_eq_str(front_get(fm, "color"), "deep red")
    assert_eq_str(front_get(fm, "size"), "9")
    assert_eq_str(front_get(fm, "missing"), "")
    assert_eq_str(fm.body, "body text")
}

fun test_front_without_frontmatter_is_all_body() {
    let fm = parse_front("no markers here")
    assert_true(fm.keys.len() == 0)
    assert_eq_str(fm.body, "no markers here")
}
