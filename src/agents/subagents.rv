// Subagent definitions: one <name>.md per agent under .agents/subagents/,
// in the shape other coding agents read. The frontmatter names the agent
// and scopes it (a one-line description, an optional comma-separated tools
// allowlist, an optional model override); the markdown body is the
// subagent's system prompt. This module is only the registry; running one
// is the subagent runtime's job.

import std/string
import std/fs { read, is_file }
import "./dir" { merged_names, path_of }
import "./front" { Front, parse_front, front_get }

struct Subagent {
    name: String,
    description: String,
    // Tool names this agent may call; empty means every tool.
    tools: List<String>,
    // A "provider/model" override; "" means the session's model.
    model: String,
    // The agent's system prompt.
    prompt: String,
}

// Load every definition under the roots' subagents/ folders, project
// shadowing global by file name. Only .md files count; the file stem is the
// fallback name.
fun load_subagents(rs: List<String>) -> List<Subagent> {
    let out: List<Subagent> = []
    let names = merged_names(rs, "subagents")
    let i = 0
    while i < names.len() {
        if names[i].ends_with(".md") {
            let p = path_of(rs, "subagents", names[i])
            if p != "" && is_file(p) {
                match read(p) {
                    Ok(text) -> {
                        out.push(parse_subagent(text, names[i].substring(0, names[i].length() - 3)))
                    },
                    Err(e) -> {},
                }
            }
        }
        i = i + 1
    }
    return out
}

// Parse one definition file.
fun parse_subagent(text: String, fallback_name: String) -> Subagent {
    let fm = parse_front(text)
    let name = front_get(fm, "name")
    if name == "" {
        name = fallback_name
    }
    return Subagent {
        name,
        description: front_get(fm, "description"),
        tools: split_tools(front_get(fm, "tools")),
        model: front_get(fm, "model"),
        prompt: fm.body,
    }
}

// A comma-separated tools value into clean names; "" means no restriction
// and comes back empty.
fun split_tools(v: String) -> List<String> {
    let out: List<String> = []
    if v.trim() == "" {
        return out
    }
    let parts = v.split(",")
    let i = 0
    while i < parts.len() {
        let t = parts[i].trim()
        if t != "" {
            out.push(t)
        }
        i = i + 1
    }
    return out
}

// The ready-made agents, available without any .agents file: a read-only
// scout, a read-only critic, and a read-only planner. A user definition
// with the same name replaces the built-in.
fun builtin_subagents() -> List<Subagent> {
    let read_only = ["read_file", "list_dir", "grep"]
    return [
        Subagent {
            name: "explorer",
            description: "explores the codebase read-only and reports what it finds",
            tools: read_only,
            model: "",
            prompt: "You are the explorer, a read-only scout. Investigate the codebase to answer the task: list directories, read the relevant files, and search for the names involved. Be thorough but do not guess; every claim should come from something you read. Reply with a compact report: what you found, where it lives (paths and names), and anything surprising. You cannot edit files or run commands.",
        },
        Subagent {
            name: "reviewer",
            description: "reviews code or a change and reports defects and risks",
            tools: read_only,
            model: "",
            prompt: "You are the reviewer, a careful critic. Read the code named in the task (and enough surrounding code to judge it fairly) and look for real defects: broken logic, unhandled edge cases, mismatched assumptions between callers and callees, and risky patterns. Do not pad the review; a short list of true problems beats a long list of nitpicks. Reply with each finding as location, what is wrong, and why it matters, then an overall verdict. You cannot edit files or run commands.",
        },
        Subagent {
            name: "planner",
            description: "studies the code and produces a step-by-step plan",
            tools: read_only,
            model: "",
            prompt: "You are the planner. Study the code involved in the task until you understand the current shape, then produce a concrete implementation plan: ordered steps, each naming the files to touch and what changes, plus the tests that should prove it. Note risks and open questions at the end. Do not write the code itself and do not modify anything. Reply with only the plan.",
        },
    ]
}

// Everything dispatch can target: the built-ins, each replaced by a user
// definition of the same name, then the remaining user definitions.
fun all_subagents(rs: List<String>) -> List<Subagent> {
    let customs = load_subagents(rs)
    let out: List<Subagent> = []
    let builtins = builtin_subagents()
    let i = 0
    while i < builtins.len() {
        let idx = subagent_index(customs, builtins[i].name)
        if idx >= 0 {
            out.push(customs[idx])
        } else {
            out.push(builtins[i])
        }
        i = i + 1
    }
    let c = 0
    while c < customs.len() {
        if subagent_index(builtins, customs[c].name) < 0 {
            out.push(customs[c])
        }
        c = c + 1
    }
    return out
}

// The index the model sees in its system prompt, so it knows what it can
// delegate to. "" when no subagents are defined.
fun subagents_prompt(agents: List<Subagent>) -> String {
    if agents.len() == 0 {
        return ""
    }
    let out = " The project defines subagents you can delegate a scoped task to with the dispatch tool. Available subagents:"
    let i = 0
    while i < agents.len() {
        let d = agents[i].description
        if d == "" {
            d = "no description"
        }
        out = "${out}\n- ${agents[i].name}: ${d}"
        i = i + 1
    }
    return "${out}\nDispatch when a self-contained piece of work (a broad search, a review, a plan) can run on its own; give the agent the full context in the task."
}

// The position of `name` in the registry, ignoring case; -1 when unknown.
fun subagent_index(agents: List<Subagent>, name: String) -> Int {
    let want = name.to_lower()
    let i = 0
    while i < agents.len() {
        if agents[i].name.to_lower() == want {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}
