import std/string
import std/test { assert_eq_str, assert_true }
import std/fs { write, create_dir_all, remove_file, remove_dir }
import "./manage" { run_plugins_command, contrib, removal_error }

fun test_router_usage_and_unknown() {
    assert_true(run_plugins_command("bogus").starts_with("unknown /plugins command"))
    assert_true(run_plugins_command("add").contains("usage"))
    assert_true(run_plugins_command("remove").contains("usage"))
    assert_true(run_plugins_command("update").contains("usage"))
}

fun test_remove_and_update_of_a_missing_plugin() {
    assert_true(run_plugins_command("remove not-installed-xyz").starts_with("no plugin named"))
    assert_true(run_plugins_command("update not-installed-xyz").starts_with("no plugin named"))
}

fun test_remove_and_update_reject_unsafe_plugin_names() {
    assert_true(run_plugins_command("remove ..").starts_with("error: unsafe plugin name"))
    assert_true(run_plugins_command("update ..").starts_with("error: unsafe plugin name"))
    assert_true(run_plugins_command("remove has/slash").starts_with("error: unsafe plugin name"))
    assert_true(run_plugins_command("update CON").starts_with("error: unsafe plugin name"))
}

fun test_contrib_counts_the_bundle_subfolders() {
    create_dir_all("_rook_contrib/skills/a")
    create_dir_all("_rook_contrib/skills/b")
    create_dir_all("_rook_contrib/commands")
    write("_rook_contrib/commands/x.md", "cmd")
    write("_rook_contrib/skills/a/SKILL.md", "s")
    write("_rook_contrib/skills/b/SKILL.md", "s")

    let c = contrib("_rook_contrib")
    assert_true(c.contains("2 skills"))
    assert_true(c.contains("1 commands"))
    // No subagents or themes folders, so they are omitted.
    assert_true(!c.contains("subagents"))

    // A path with no bundle folders contributes nothing.
    assert_eq_str(contrib("_rook_contrib_absent"), "")

    remove_file("_rook_contrib/commands/x.md")
    remove_file("_rook_contrib/skills/a/SKILL.md")
    remove_file("_rook_contrib/skills/b/SKILL.md")
    remove_dir("_rook_contrib/commands")
    remove_dir("_rook_contrib/skills/a")
    remove_dir("_rook_contrib/skills/b")
    remove_dir("_rook_contrib/skills")
    remove_dir("_rook_contrib")
    return
}

fun test_removal_error_reports_directory_that_still_exists() {
    create_dir_all("_rook_remove_failed")
    let err = removal_error("_rook_remove_failed", "rm: permission denied")
    assert_true(err.contains("directory still exists after removal"))
    assert_true(err.contains("_rook_remove_failed"))
    assert_true(err.contains("permission denied"))
    remove_dir("_rook_remove_failed")
    return
}
