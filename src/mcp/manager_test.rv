import std/string
import std/json { parse, JsonValue }
import std/test { assert_eq_str, assert_eq_int, assert_true }
import "./client" { McpClient, McpTool, McpResource, McpPrompt }
import "./config" { ServerSpec }
import "./manager" { Route, exposed_name, tools_from, route_in, format_tool_result, is_mcp_tool, format_resource, format_prompt, status_from, resource_route }

fun _client() -> McpClient {
    let tools = [
        McpTool { name: "read_file", description: "read a file", schema: "{\"type\": \"object\"}" },
        McpTool { name: "weird name!", description: "", schema: "null" },
    ]
    let resources: List<McpResource> = []
    let prompts: List<McpPrompt> = []
    return McpClient {
        name: "fs",
        server_name: "filesystem",
        server_version: "1.0",
        tools,
        resources,
        prompts,
        ok: true,
        error: "",
        conn: None,
    }
}

fun _tool_client(server: String, tool: String) -> McpClient {
    let tools = [McpTool { name: tool, description: "", schema: "null" }]
    let resources: List<McpResource> = []
    let prompts: List<McpPrompt> = []
    return McpClient {
        name: server,
        server_name: "",
        server_version: "",
        tools,
        resources,
        prompts,
        ok: true,
        error: "",
        conn: None,
    }
}

fun _resource_client(server: String, uri: String) -> McpClient {
    let tools: List<McpTool> = []
    let resources = [McpResource { uri, name: "doc", description: "", mime: "text/plain" }]
    let prompts: List<McpPrompt> = []
    return McpClient {
        name: server,
        server_name: "",
        server_version: "",
        tools,
        resources,
        prompts,
        ok: true,
        error: "",
        conn: None,
    }
}

fun test_exposed_name_namespaces_and_sanitizes() {
    assert_eq_str(exposed_name("fs", "read_file"), "mcp__fs__read_file")
    // A space and punctuation become underscores so the name is valid.
    assert_eq_str(exposed_name("fs", "weird name!"), "mcp__fs__weird_name_")
    assert_true(is_mcp_tool(exposed_name("fs", "read_file")))
}

fun test_tools_from_builds_a_def_per_tool() {
    let defs = tools_from([_client()])
    assert_eq_int(defs.len(), 2)
    assert_eq_str(defs[0].name, "mcp__fs__read_file")
    // A tool with no description still gets one.
    assert_true(defs[1].description.contains("weird name!"))
}

fun test_tools_from_skips_colliding_exposed_names() {
    let clients = [
        _tool_client("a.b", "read"),
        _tool_client("a_b", "read"),
        _tool_client("safe", "read"),
    ]
    let defs = tools_from(clients)
    assert_eq_int(defs.len(), 1)
    assert_eq_str(defs[0].name, "mcp__safe__read")
}

fun test_tools_from_skips_a_failed_client() {
    let empty: List<McpTool> = []
    let no_res: List<McpResource> = []
    let no_pr: List<McpPrompt> = []
    let dead = McpClient {
        name: "down",
        server_name: "",
        server_version: "",
        tools: empty,
        resources: no_res,
        prompts: no_pr,
        ok: false,
        error: "boom",
        conn: None,
    }
    assert_eq_int(tools_from([dead]).len(), 0)
}

fun test_format_resource_joins_text_contents() {
    assert_eq_str(
        format_resource(
            _json(
                "{\"contents\": [{\"uri\": \"file:///a\", \"text\": \"line one\"}, {\"uri\": \"file:///a\", \"text\": \"line two\"}]}",
            ),
        ),
        "line one\nline two",
    )
    assert_true(format_resource(_json("{\"contents\": []}")).contains("no text contents"))
}

fun test_resource_route_allows_unique_uri_without_server() {
    let route = resource_route(
        [_resource_client("docs", "file:///README.md")],
        "",
        "file:///README.md",
    )
    assert_true(route.ok)
    assert_eq_str(route.server, "docs")
}

fun test_resource_route_reports_missing_uri() {
    let route = resource_route(
        [_resource_client("docs", "file:///README.md")],
        "",
        "file:///missing.md",
    )
    assert_true(!route.ok)
    assert_true(route.error.contains("no connected MCP server exposes"))
}

fun test_resource_route_reports_duplicate_uri_without_server() {
    let route = resource_route(
        [
            _resource_client("docs", "file:///README.md"),
            _resource_client("cache", "file:///README.md"),
        ],
        "",
        "file:///README.md",
    )
    assert_true(!route.ok)
    assert_true(route.error.contains("ambiguous"))
    assert_true(route.error.contains("docs"))
    assert_true(route.error.contains("cache"))
    assert_true(route.error.contains("server argument"))
}

fun test_resource_route_validates_explicit_server_uri() {
    let route = resource_route(
        [_resource_client("docs", "file:///README.md")],
        "docs",
        "file:///missing.md",
    )
    assert_true(!route.ok)
    assert_true(route.error.contains("does not expose"))
}

fun test_status_from_shows_each_server_state() {
    let no_res: List<McpResource> = []
    let no_pr: List<McpPrompt> = []
    let no_tools: List<McpTool> = []
    let ok_tools = [McpTool { name: "read", description: "", schema: "null" }]
    let connected = McpClient {
        name: "fs",
        server_name: "fs-srv",
        server_version: "1.0",
        tools: ok_tools,
        resources: no_res,
        prompts: no_pr,
        ok: true,
        error: "",
        conn: None,
    }
    let failed = McpClient {
        name: "bad",
        server_name: "",
        server_version: "",
        tools: no_tools,
        resources: no_res,
        prompts: no_pr,
        ok: false,
        error: "boom",
        conn: None,
    }
    let no_args: List<String> = []
    let specs = [
        ServerSpec { name: "fs", command: "x", args: no_args, env: no_args },
        ServerSpec { name: "bad", command: "y", args: no_args, env: no_args },
        ServerSpec { name: "later", command: "z", args: no_args, env: no_args },
        ServerSpec {
            name: "invalid",
            command: "z",
            args: no_args,
            env: ["TOKEN_WITHOUT_VALUE"],
        },
    ]
    let text = status_from(specs, [connected, failed])
    assert_true(text.contains("fs: connected (fs-srv 1.0)"))
    assert_true(text.contains("tools: read"))
    assert_true(text.contains("bad: failed to connect"))
    assert_true(text.contains("boom"))
    assert_true(text.contains("later: configured, not connected yet"))
    assert_true(text.contains("invalid: invalid configuration"))
    assert_true(text.contains("expected KEY=value"))
    assert_true(!text.contains("TOKEN_WITHOUT_VALUE"))
}

fun test_status_from_reports_tool_name_collisions() {
    let no_args: List<String> = []
    let specs = [
        ServerSpec { name: "a.b", command: "x", args: no_args, env: no_args },
        ServerSpec { name: "a_b", command: "y", args: no_args, env: no_args },
    ]
    let text = status_from(specs, [_tool_client("a.b", "read"), _tool_client("a_b", "read")])
    assert_true(text.contains("warning: MCP tool name collision"))
    assert_true(text.contains("mcp__a_b__read"))
    assert_true(text.contains("a.b/read"))
    assert_true(text.contains("a_b/read"))
    assert_true(text.contains("colliding tools are not exposed"))
}

fun test_status_from_with_no_servers() {
    let no_specs: List<ServerSpec> = []
    let no_clients: List<McpClient> = []
    assert_true(status_from(no_specs, no_clients).contains("no MCP servers configured"))
}

fun test_format_prompt_flattens_messages() {
    // Content may be an object with a text field, or a bare string.
    assert_eq_str(
        format_prompt(
            _json(
                "{\"messages\": [{\"role\": \"user\", \"content\": {\"type\": \"text\", \"text\": \"do the thing\"}}, {\"role\": \"assistant\", \"content\": \"okay\"}]}",
            ),
        ),
        "do the thing\n\nokay",
    )
}

fun test_route_in_maps_the_exposed_name_back() {
    let clients = [_client()]
    match route_in(clients, "mcp__fs__read_file") {
        Some(r) -> {
            assert_eq_str(r.server, "fs")
            assert_eq_str(r.tool, "read_file")
        },
        None -> {
            assert_true(false)
        },
    }
    // The sanitized name routes back to the original bare tool name.
    match route_in(clients, "mcp__fs__weird_name_") {
        Some(r) -> {
            assert_eq_str(r.tool, "weird name!")
        },
        None -> {
            assert_true(false)
        },
    }
    // An unknown tool does not route.
    assert_true(_is_none(route_in(clients, "mcp__fs__nope")))
}

fun test_route_in_rejects_ambiguous_separator_collision() {
    let clients = [_tool_client("a", "b__c"), _tool_client("a__b", "c")]
    assert_eq_int(tools_from(clients).len(), 0)
    assert_true(_is_none(route_in(clients, "mcp__a__b__c")))
}

fun test_format_tool_result_joins_text_and_flags_errors() {
    assert_eq_str(
        format_tool_result(
            _json(
                "{\"content\": [{\"type\": \"text\", \"text\": \"hello\"}, {\"type\": \"text\", \"text\": \"world\"}]}",
            ),
        ),
        "hello\nworld",
    )
    assert_eq_str(
        format_tool_result(
            _json("{\"content\": [{\"type\": \"text\", \"text\": \"boom\"}], \"isError\": true}"),
        ),
        "error: boom",
    )
    assert_true(format_tool_result(_json("{\"content\": []}")).contains("no text content"))
}

// A server's resource and tool text is untrusted and unbounded; it is capped
// before it reaches the model, with a source-labeled marker.
fun test_format_resource_caps_oversized_text() {
    let big = _repeat("z", 9000)
    let out = format_resource(_json("{\"contents\": [{\"text\": \"${big}\"}]}"))
    assert_true(out.length() < 9000)
    assert_true(out.contains("[truncated: MCP resource]"))
}

fun test_format_tool_result_caps_oversized_text() {
    let big = _repeat("z", 9000)
    let out = format_tool_result(
        _json("{\"content\": [{\"type\": \"text\", \"text\": \"${big}\"}]}"),
    )
    assert_true(out.length() < 9000)
    assert_true(out.contains("[truncated: MCP tool result]"))
}

fun _repeat(s: String, n: Int) -> String {
    let out = ""
    let i = 0
    while i < n {
        out = out.concat(s)
        i = i + 1
    }
    return out
}

fun _is_none(o: Option<Route>) -> Bool {
    return match o {
        Some(r) -> false,
        None -> true,
    }
}

fun _json(text: String) -> JsonValue {
    return match parse(text) {
        Ok(j) -> j,
        Err(e) -> JsonValue.Null,
    }
}
