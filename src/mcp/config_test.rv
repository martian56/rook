import std/string
import std/json { parse, JsonValue }
import std/test { assert_eq_str, assert_eq_int, assert_true }
import std/fs { write, create_dir_all, remove_file, remove_dir }
import "./config" { ServerSpec, parse_servers, configured_servers_from_with_project_trust }

const SECTION: String = "{\"servers\": [{\"name\": \"fs\", \"command\": \"npx\", \"args\": [\"-y\", \"server-fs\", \".\"], \"env\": [\"K=v\"]}, {\"name\": \"nocmd\"}, {\"command\": \"noname\"}, {\"name\": \"git\", \"command\": \"mcp-git\"}]}"

fun test_parse_servers_reads_valid_entries() {
    let specs = parse_servers(_json(SECTION))
    // The entries missing a name or a command are dropped.
    assert_eq_int(specs.len(), 2)
    assert_eq_str(specs[0].name, "fs")
    assert_eq_str(specs[0].command, "npx")
    assert_eq_int(specs[0].args.len(), 3)
    assert_eq_str(specs[0].args[1], "server-fs")
    assert_eq_int(specs[0].env.len(), 1)
    assert_eq_str(specs[0].env[0], "K=v")
    // A server may have no args or env.
    assert_eq_str(specs[1].name, "git")
    assert_eq_int(specs[1].args.len(), 0)
}

fun test_parse_servers_tolerates_a_missing_array() {
    assert_eq_int(parse_servers(_json("{}")).len(), 0)
}

fun test_project_mcp_servers_are_ignored_until_trusted() {
    create_dir_all(".agents")
    write(
        ".agents/settings.json",
        "{\"mcp\": {\"servers\": [{\"name\": \"fs\", \"command\": \"mcp-fs\"}]}}",
    )

    assert_eq_int(configured_servers_from_with_project_trust([".agents"], false).len(), 0)
    assert_eq_int(configured_servers_from_with_project_trust([".agents"], true).len(), 1)

    remove_file(".agents/settings.json")
    remove_dir(".agents")
    return
}

fun _json(text: String) -> JsonValue {
    return match parse(text) {
        Ok(j) -> j,
        Err(e) -> JsonValue.Null,
    }
}
