// End-to-end subagent runs against an in-process server posing as a
// non-streaming OpenAI endpoint: a full tool round-trip, the allowlist
// refusing an off-limits tool, and the parent conversation staying clean.

import std/string
import std/http { Server, Request, Response }
import std/sync { sleep_millis }
import std/fs { write as fs_write, remove_file }
import std/test { assert_true, assert_eq_str, assert_eq_int }
import "./state" { AgentState, DisplayEvent, Snapshot }
import "./subturn" { run_subagent }
import "../agents/subagents" { Subagent }

let read_hits = 0
let scoped_hits = 0

// Round 1: ask to read a file. Round 2: answer.
fun sub_read_handler(req: Request) -> Response {
    read_hits = read_hits + 1
    if read_hits == 1 {
        return Response.text(
            "{\"choices\":[{\"message\":{\"role\":\"assistant\",\"content\":\"\",\"tool_calls\":[{\"id\":\"s1\",\"type\":\"function\",\"function\":{\"name\":\"read_file\",\"arguments\":\"{\\\"path\\\":\\\"_rook_sub.txt\\\"}\"}}]},\"finish_reason\":\"tool_calls\"}],\"usage\":{\"prompt_tokens\":11,\"completion_tokens\":3}}",
        )
    }
    return Response.text(
        "{\"choices\":[{\"message\":{\"role\":\"assistant\",\"content\":\"The notes say ship it.\"},\"finish_reason\":\"stop\"}],\"usage\":{\"prompt_tokens\":13,\"completion_tokens\":5}}",
    )
}

// Round 1: ask for read_file, which this agent is not allowed. Round 2:
// acknowledge the refusal.
fun sub_scoped_handler(req: Request) -> Response {
    scoped_hits = scoped_hits + 1
    if scoped_hits == 1 {
        return Response.text(
            "{\"choices\":[{\"message\":{\"role\":\"assistant\",\"content\":\"\",\"tool_calls\":[{\"id\":\"s2\",\"type\":\"function\",\"function\":{\"name\":\"read_file\",\"arguments\":\"{\\\"path\\\":\\\"_rook_sub.txt\\\"}\"}}]},\"finish_reason\":\"tool_calls\"}]}",
        )
    }
    return Response.text(
        "{\"choices\":[{\"message\":{\"role\":\"assistant\",\"content\":\"I could not read the file.\"},\"finish_reason\":\"stop\"}]}",
    )
}

fun serve_sub_read() {
    let app = Server.new()
    app.post("/v1/chat/completions", sub_read_handler)
    app.listen("127.0.0.1:8463")
}

fun serve_sub_scoped() {
    let app = Server.new()
    app.post("/v1/chat/completions", sub_scoped_handler)
    app.listen("127.0.0.1:8464")
}

fun open_agent(name: String) -> Subagent {
    let all: List<String> = []
    return Subagent {
        name,
        description: "test agent",
        tools: all,
        model: "",
        prompt: "You are a test agent.",
    }
}

fun test_subagent_runs_a_tool_round_and_returns_only_the_answer() {
    fs_write("_rook_sub.txt", "ship it")
    spawn(fun() -> Unit {
        serve_sub_read()
    })
    sleep_millis(200)
    let st = AgentState.new()
    let got = run_subagent(
        st,
        "d1",
        open_agent("explorer"),
        "what do the notes say?",
        "custom/local",
        "",
        "http://127.0.0.1:8463/v1",
    )
    assert_eq_str(got, "The notes say ship it.")
    // The parent conversation stayed clean; the tool activity surfaced as a
    // labeled display event.
    assert_eq_int(st.messages().len(), 0)
    let tokens = st.turn_tokens()
    assert_eq_int(tokens.prompt, 24)
    assert_eq_int(tokens.completion, 8)
    let snap = st.drain()
    assert_eq_int(snap.sess_prompt, 24)
    assert_eq_int(snap.sess_completion, 8)
    let seen = ""
    let i = 0
    while i < snap.events.len() {
        match snap.events[i] {
            AgentStarted(id, name) -> {
                seen = "${seen}[start ${name}]"
            },
            AgentTool(id, agent, name, result) -> {
                seen = "${seen}[${agent} › ${name}]"
            },
            AgentFinished(id, name, used) -> {
                seen = "${seen}[done ${name} ${used}]"
            },
            _ -> {},
        }
        i = i + 1
    }
    assert_true(seen.contains("[start explorer]"))
    assert_true(seen.contains("explorer › read_file(_rook_sub.txt)"))
    assert_true(seen.contains("[done explorer 1]"))
    remove_file("_rook_sub.txt")
    return
}

fun test_allowlist_refuses_an_off_limits_tool() {
    spawn(fun() -> Unit {
        serve_sub_scoped()
    })
    sleep_millis(200)
    let st = AgentState.new()
    let scoped = Subagent {
        name: "searcher",
        description: "grep only",
        tools: ["grep"],
        model: "",
        prompt: "You may only search.",
    }
    let got = run_subagent(
        st,
        "d2",
        scoped,
        "read the notes",
        "custom/local",
        "",
        "http://127.0.0.1:8464/v1",
    )
    assert_eq_str(got, "I could not read the file.")
    let snap = st.drain()
    let seen = ""
    let i = 0
    while i < snap.events.len() {
        match snap.events[i] {
            AgentTool(id, agent, name, result) -> {
                seen = "${seen}[${agent} › ${name} => ${result}]"
            },
            _ -> {},
        }
        i = i + 1
    }
    assert_true(seen.contains("not available to this agent"))
    return
}
