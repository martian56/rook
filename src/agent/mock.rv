// The offline fallback brain. When no provider key is set, rook still runs:
// this rotates a few canned replies and the turn loop streams them word by
// word so the UI behaves exactly as it does with a real model.

import std/string

// The verb shown while a turn is in flight.
fun thinking_word(index: Int) -> String {
    let words = ["Thinking", "Pondering", "Brewing", "Musing", "Tinkering", "Percolating"]
    return words[index % words.len()]
}

// The pulsing marker in front of the verb.
fun pulse(tick: Int) -> String {
    let frames = ["·", "✢", "✳", "✻", "✽", "✻", "✳", "✢"]
    return frames[tick % frames.len()]
}

// A canned reply, chosen by turn index. The real brain uses the prompt; the
// mock ignores it and just rotates.
fun mock_reply(prompt: String, index: Int) -> String {
    let n = index % 3
    if n == 0 {
        return "This is the offline mock brain: no API key is set, so I am not calling a real model. Set OPENAI_API_KEY or ANTHROPIC_API_KEY (or run /model to pick a provider), and I will stream real answers here instead."
    }
    if n == 1 {
        return "Still offline. Everything else works: the transcript, streaming, scrolling, and the input box are all real. Only the words are canned."
    }
    return "Once a key is present, rook reads files, searches, edits, and runs commands through the model, asking you to approve anything that changes the repo."
}
