// End-to-end turn tests against an in-process std/http server posing as an
// OpenAI streaming endpoint. They exercise the whole path with no real
// provider: stream, tool call, execution, feed-back, final answer, and the
// approval handshake, using the base_url override to reach the local server.

import std/string
import std/http { Server, Request, Response }
import std/sync { sleep_millis }
import std/fs { write as fs_write, remove_file, remove_dir, create_dir_all, exists }
import std/test { assert_true, assert_eq_str, assert_eq_int }
import "./state" { AgentState, DisplayEvent, Snapshot }
import "./turn" { run_turn }

let read_hits = 0
let write_hits = 0
let dispatch_hits = 0
let fanout_hits = 0
let ask_hits = 0
let perm_hits = 0
let plan_hits = 0

// Round 1: ask to read a file. Round 2: answer.
fun read_handler(req: Request) -> Response {
    read_hits = read_hits + 1
    if read_hits == 1 {
        return Response.text(
            "data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"id\":\"c1\",\"function\":{\"name\":\"read_file\",\"arguments\":\"{\\\"path\\\":\\\"_rook_e2e.txt\\\"}\"}}]}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"tool_calls\"}]}\n\ndata: [DONE]\n\n",
        )
    }
    return Response.text(
        "data: {\"choices\":[{\"delta\":{\"content\":\"The file says hello.\"}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"stop\"}]}\n\ndata: [DONE]\n\n",
    )
}

// Round 1: ask to write a file (needs approval). Round 2: confirm.
fun write_handler(req: Request) -> Response {
    write_hits = write_hits + 1
    if write_hits == 1 {
        return Response.text(
            "data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"id\":\"w1\",\"function\":{\"name\":\"write_file\",\"arguments\":\"{\\\"path\\\":\\\"_rook_e2e_out.txt\\\",\\\"content\\\":\\\"written by rook\\\"}\"}}]}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"tool_calls\"}]}\n\ndata: [DONE]\n\n",
        )
    }
    return Response.text(
        "data: {\"choices\":[{\"delta\":{\"content\":\"Done, wrote the file.\"}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"stop\"}]}\n\ndata: [DONE]\n\n",
    )
}

// Round 1: ask to write a file a deny rule blocks. Round 2: confirm.
fun perm_handler(req: Request) -> Response {
    perm_hits = perm_hits + 1
    if perm_hits == 1 {
        return Response.text(
            "data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"id\":\"p1\",\"function\":{\"name\":\"write_file\",\"arguments\":\"{\\\"path\\\":\\\"_rook_e2e_perm.txt\\\",\\\"content\\\":\\\"written by rook\\\"}\"}}]}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"tool_calls\"}]}\n\ndata: [DONE]\n\n",
        )
    }
    return Response.text(
        "data: {\"choices\":[{\"delta\":{\"content\":\"The permission rule blocked the write.\"}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"stop\"}]}\n\ndata: [DONE]\n\n",
    )
}

// Round 1: try to write a file (blocked in plan mode). Round 2: concede.
fun plan_handler(req: Request) -> Response {
    plan_hits = plan_hits + 1
    if plan_hits == 1 {
        return Response.text(
            "data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"id\":\"pl1\",\"function\":{\"name\":\"write_file\",\"arguments\":\"{\\\"path\\\":\\\"_rook_e2e_plan.txt\\\",\\\"content\\\":\\\"should not exist\\\"}\"}}]}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"tool_calls\"}]}\n\ndata: [DONE]\n\n",
        )
    }
    return Response.text(
        "data: {\"choices\":[{\"delta\":{\"content\":\"Here is my plan instead.\"}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"stop\"}]}\n\ndata: [DONE]\n\n",
    )
}

fun serve_plan() {
    let app = Server.new()
    app.post("/v1/chat/completions", plan_handler)
    app.listen("127.0.0.1:8469")
}

// One server plays both sides of a dispatch: the subagent's requests carry
// its own system prompt ("echo agent") and get a plain non-streaming
// answer; the parent's streaming requests get a dispatch call first, then
// the final answer.
fun dispatch_handler(req: Request) -> Response {
    if req.body.contains("echo agent") {
        return Response.text(
            "{\"choices\":[{\"message\":{\"role\":\"assistant\",\"content\":\"echo done\"},\"finish_reason\":\"stop\"}]}",
        )
    }
    dispatch_hits = dispatch_hits + 1
    if dispatch_hits == 1 {
        return Response.text(
            "data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"id\":\"d1\",\"function\":{\"name\":\"dispatch\",\"arguments\":\"{\\\"agent\\\":\\\"echoer\\\",\\\"task\\\":\\\"say echo done\\\"}\"}}]}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"tool_calls\"}]}\n\ndata: [DONE]\n\n",
        )
    }
    return Response.text(
        "data: {\"choices\":[{\"delta\":{\"content\":\"The agent said: echo done.\"}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"stop\"}]}\n\ndata: [DONE]\n\n",
    )
}

fun serve_read() {
    let app = Server.new()
    app.post("/v1/chat/completions", read_handler)
    app.listen("127.0.0.1:8461")
}

fun serve_perm() {
    let app = Server.new()
    app.post("/v1/chat/completions", perm_handler)
    app.listen("127.0.0.1:8468")
}

fun serve_dispatch() {
    let app = Server.new()
    app.post("/v1/chat/completions", dispatch_handler)
    app.listen("127.0.0.1:8465")
}

// The fan-out server: the parent's first streaming request gets TWO
// dispatch calls in one batch; each subagent (told apart by its own system
// prompt) answers non-streaming; the parent's second request closes.
fun fanout_handler(req: Request) -> Response {
    if req.body.contains("echo agent") {
        return Response.text(
            "{\"choices\":[{\"message\":{\"role\":\"assistant\",\"content\":\"echo done\"},\"finish_reason\":\"stop\"}]}",
        )
    }
    if req.body.contains("shout agent") {
        return Response.text(
            "{\"choices\":[{\"message\":{\"role\":\"assistant\",\"content\":\"SHOUT DONE\"},\"finish_reason\":\"stop\"}]}",
        )
    }
    fanout_hits = fanout_hits + 1
    if fanout_hits == 1 {
        return Response.text(
            "data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"id\":\"f1\",\"function\":{\"name\":\"dispatch\",\"arguments\":\"{\\\"agent\\\":\\\"echoer\\\",\\\"task\\\":\\\"say it\\\"}\"}},{\"index\":1,\"id\":\"f2\",\"function\":{\"name\":\"dispatch\",\"arguments\":\"{\\\"agent\\\":\\\"shouter\\\",\\\"task\\\":\\\"shout it\\\"}\"}}]}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"tool_calls\"}]}\n\ndata: [DONE]\n\n",
        )
    }
    return Response.text(
        "data: {\"choices\":[{\"delta\":{\"content\":\"Both agents reported.\"}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"stop\"}]}\n\ndata: [DONE]\n\n",
    )
}

// Round 1: ask the user a question. Round 2: acknowledge the pick.
fun ask_handler(req: Request) -> Response {
    ask_hits = ask_hits + 1
    if ask_hits == 1 {
        return Response.text(
            "data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"id\":\"q1\",\"function\":{\"name\":\"ask_user\",\"arguments\":\"{\\\"question\\\":\\\"Which path?\\\",\\\"options\\\":\\\"fast, safe\\\"}\"}}]}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"tool_calls\"}]}\n\ndata: [DONE]\n\n",
        )
    }
    return Response.text(
        "data: {\"choices\":[{\"delta\":{\"content\":\"Going the safe way.\"}}]}\n\ndata: {\"choices\":[{\"delta\":{},\"finish_reason\":\"stop\"}]}\n\ndata: [DONE]\n\n",
    )
}

fun serve_ask() {
    let app = Server.new()
    app.post("/v1/chat/completions", ask_handler)
    app.listen("127.0.0.1:8467")
}

fun serve_fanout() {
    let app = Server.new()
    app.post("/v1/chat/completions", fanout_handler)
    app.listen("127.0.0.1:8466")
}

fun serve_write() {
    let app = Server.new()
    app.post("/v1/chat/completions", write_handler)
    app.listen("127.0.0.1:8462")
}

fun e2e_replay(events: List<DisplayEvent>) -> String {
    let out = ""
    let i = 0
    while i < events.len() {
        match events[i] {
            Started -> {
                out = out.concat("")
            },
            Chunk(d) -> {
                out = out.concat(d)
            },
            ToolRan(name, result) -> {
                out = out.concat("[${name} => ${result}]")
            },
            Info(t) -> {
                out = out.concat("[info ${t}]")
            },
            AgentStarted(name) -> {
                out = out.concat("[agent ${name} started]")
            },
            AgentTool(agent, name, result) -> {
                out = out.concat("[${agent} › ${name} => ${result}]")
            },
            AgentFinished(name, used) -> {
                out = out.concat("[agent ${name} done ${used}]")
            },
        }
        i = i + 1
    }
    return out
}

fun e2e_drain(st: AgentState) -> String {
    let acc = ""
    let tries = 0
    while tries < 400 {
        let snap = st.drain()
        acc = acc.concat(e2e_replay(snap.events))
        if snap.done {
            return acc
        }
        sleep_millis(10)
        tries = tries + 1
    }
    return acc
}

fun test_full_read_tool_turn() {
    fs_write("_rook_e2e.txt", "hello")
    spawn(fun() -> Unit {
        serve_read()
    })
    sleep_millis(200)
    let st = AgentState.new()
    st.push_user("what does the file say?")
    st.begin()
    spawn(fun() -> Unit {
        run_turn(st, "custom/local", "", "http://127.0.0.1:8461/v1")
    })
    let got = e2e_drain(st)
    // The read tool ran (auto, no approval) and the final answer streamed.
    assert_true(got.contains("read_file(_rook_e2e.txt)"))
    assert_true(got.contains("The file says hello."))
    // user, assistant(tool_calls), tool_result, assistant(final).
    let msgs = st.messages()
    assert_eq_int(msgs.len(), 4)
    remove_file("_rook_e2e.txt")
    return
}

fun test_write_tool_turn_goes_through_approval() {
    spawn(fun() -> Unit {
        serve_write()
    })
    sleep_millis(200)
    let st = AgentState.new()
    st.push_user("please write the file")
    st.begin()
    spawn(fun() -> Unit {
        run_turn(st, "custom/local", "", "http://127.0.0.1:8462/v1")
    })
    // Play the user: wait for the approval prompt, then allow it.
    _approve_when_pending(st)
    let got = e2e_drain(st)
    assert_true(got.contains("write_file(_rook_e2e_out.txt)"))
    assert_true(got.contains("Done, wrote the file."))
    // The approval led to a real write.
    remove_file("_rook_e2e_out.txt")
    return
}

fun test_dispatch_runs_a_subagent_and_feeds_its_answer_back() {
    create_dir_all(".agents/subagents")
    fs_write(
        ".agents/subagents/echoer.md",
        "---\ndescription: echoes things\n---\nYou are the echo agent.",
    )
    spawn(fun() -> Unit {
        serve_dispatch()
    })
    sleep_millis(200)
    let st = AgentState.new()
    st.push_user("delegate this")
    st.begin()
    spawn(fun() -> Unit {
        run_turn(st, "custom/local", "", "http://127.0.0.1:8465/v1")
    })
    let got = e2e_drain(st)
    // The dispatch ran the subagent, its answer came back as the tool
    // result, and the parent finished with its own reply.
    assert_true(got.contains("[agent echoer started]"))
    assert_true(got.contains("[agent echoer done 0]"))
    assert_true(got.contains("[dispatch(echoer) => echo done]"))
    assert_true(got.contains("The agent said: echo done."))
    // Parent conversation: user, assistant(tool_calls), tool_result,
    // assistant(final). The subagent's inner rounds never enter it.
    assert_eq_int(st.messages().len(), 4)
    remove_file(".agents/subagents/echoer.md")
    remove_dir(".agents/subagents")
    remove_dir(".agents")
    return
}

fun test_two_dispatches_fan_out_and_both_results_return() {
    create_dir_all(".agents/subagents")
    fs_write(
        ".agents/subagents/echoer.md",
        "---\ndescription: echoes things\n---\nYou are the echo agent.",
    )
    fs_write(
        ".agents/subagents/shouter.md",
        "---\ndescription: shouts things\n---\nYou are the shout agent.",
    )
    spawn(fun() -> Unit {
        serve_fanout()
    })
    sleep_millis(200)
    let st = AgentState.new()
    st.push_user("ask both agents")
    st.begin()
    spawn(fun() -> Unit {
        run_turn(st, "custom/local", "", "http://127.0.0.1:8466/v1")
    })
    let got = e2e_drain(st)
    assert_true(got.contains("[info running 2 agents in parallel…]"))
    assert_true(got.contains("[agent echoer started]"))
    assert_true(got.contains("[agent shouter started]"))
    assert_true(got.contains("[dispatch(echoer) => echo done]"))
    assert_true(got.contains("[dispatch(shouter) => SHOUT DONE]"))
    assert_true(got.contains("Both agents reported."))
    // user, assistant(two tool_calls), two tool_results, assistant(final).
    let msgs = st.messages()
    assert_eq_int(msgs.len(), 5)
    assert_eq_str(msgs[2].tool_call_id, "f1")
    assert_eq_str(msgs[3].tool_call_id, "f2")
    remove_file(".agents/subagents/echoer.md")
    remove_file(".agents/subagents/shouter.md")
    remove_dir(".agents/subagents")
    remove_dir(".agents")
    return
}

fun test_ask_user_round_trips_the_pick() {
    spawn(fun() -> Unit {
        serve_ask()
    })
    sleep_millis(200)
    let st = AgentState.new()
    st.push_user("decide for me")
    st.begin()
    spawn(fun() -> Unit {
        run_turn(st, "custom/local", "", "http://127.0.0.1:8467/v1")
    })
    // Play the user: wait for the question, pick the second option.
    spawn(fun() -> Unit {
        let tries = 0
        let answered = false
        while tries < 400 && !answered {
            if st.question_now() != "" {
                st.decide(1)
                answered = true
            }
            sleep_millis(10)
            tries = tries + 1
        }
    })
    let got = e2e_drain(st)
    assert_true(got.contains("[info you chose: safe]"))
    assert_true(got.contains("[ask_user(Which path?) => The user chose: safe]"))
    assert_true(got.contains("Going the safe way."))
    // user, assistant(tool_calls), tool_result, assistant(final).
    assert_eq_int(st.messages().len(), 4)
    return
}

fun test_a_project_deny_rule_blocks_without_approval() {
    // Deny rules from project settings still apply even though project
    // allow rules cannot skip the approval prompt without trust.
    create_dir_all(".agents")
    fs_write(
        ".agents/settings.json",
        "{\"permissions\": {\"deny\": [\"write_file(_rook_e2e_perm*)\"]}}",
    )
    spawn(fun() -> Unit {
        serve_perm()
    })
    sleep_millis(200)
    let st = AgentState.new()
    st.push_user("please write the file")
    st.begin()
    spawn(fun() -> Unit {
        run_turn(st, "custom/local", "", "http://127.0.0.1:8468/v1")
    })
    let got = e2e_drain(st)
    assert_true(got.contains("blocked by the permission rule"))
    assert_true(got.contains("The permission rule blocked the write."))
    assert_true(!exists("_rook_e2e_perm.txt"))
    remove_file(".agents/settings.json")
    remove_dir(".agents")
    return
}

fun test_plan_mode_blocks_a_write() {
    spawn(fun() -> Unit {
        serve_plan()
    })
    sleep_millis(200)
    let st = AgentState.new()
    st.push_user("change the file")
    st.set_plan(true)
    st.begin()
    spawn(fun() -> Unit {
        run_turn(st, "custom/local", "", "http://127.0.0.1:8469/v1")
    })
    let got = e2e_drain(st)
    // The write was refused, the model got the plan-mode message, and it
    // closed with its plan instead. No file was created.
    assert_true(got.contains("Plan mode is on"))
    assert_true(got.contains("Here is my plan instead."))
    assert_true(!exists("_rook_e2e_plan.txt"))
    return
}

// Poll for a pending approval and allow it once, the way the UI would. Uses
// pending_now so it never drains display events out from under e2e_drain.
fun _approve_when_pending(st: AgentState) {
    spawn(fun() -> Unit {
        let tries = 0
        let answered = false
        while tries < 400 && !answered {
            if st.pending_now() != "" {
                st.decide(1)
                answered = true
            }
            sleep_millis(10)
            tries = tries + 1
        }
    })
    return
}
