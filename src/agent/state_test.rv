import std/string
import std/sync { sleep_millis }
import std/test { assert_eq_str, assert_eq_int, assert_true }
import "./state" { AgentState, DisplayEvent, Snapshot }
import "./turn" { run_turn }

// Replay a batch of display events into one accumulated string, the way the
// UI does, so a test can assert what the goroutine produced.
fun replay(events: List<DisplayEvent>) -> String {
    let out = ""
    let i = 0
    while i < events.len() {
        match events[i] {
            Started -> {
                out = out.concat("[start]")
            },
            Chunk(d) -> {
                out = out.concat(d)
            },
            ToolRan(name, result) -> {
                out = out.concat("[tool ${name}=${result}]")
            },
            Info(t) -> {
                out = out.concat("[info ${t}]")
            },
        }
        i = i + 1
    }
    return out
}

// Drain until the turn is done, accumulating every event.
fun drain_until_done(st: AgentState) -> String {
    let acc = ""
    let tries = 0
    while tries < 300 {
        let snap = st.drain()
        acc = acc.concat(replay(snap.events))
        if snap.done {
            return acc
        }
        sleep_millis(10)
        tries = tries + 1
    }
    return acc
}

fun test_mock_turn_streams_across_goroutine() {
    // A mock turn on a background goroutine emits Started then a Chunk per
    // word; draining reassembles the full reply.
    let st = AgentState.new()
    st.push_user("hi")
    st.begin()
    spawn(fun() -> Unit {
        run_turn(st, "mock/none", "", true, "hello there friend")
    })
    let got = drain_until_done(st)
    assert_eq_str(got, "[start]hello there friend")
}

fun test_mock_reply_lands_in_the_conversation() {
    let st = AgentState.new()
    st.push_user("hi")
    st.begin()
    run_turn(st, "mock/none", "", true, "one two")
    let msgs = st.messages()
    // user + assistant.
    assert_eq_int(msgs.len(), 2)
    assert_eq_str(msgs[1].content, "one two")
}

fun test_interrupt_stops_the_mock_stream() {
    let st = AgentState.new()
    st.push_user("hi")
    st.begin()
    st.request_interrupt()
    run_turn(st, "mock/none", "", true, "a b c d e")
    assert_true(st.interrupted())
    // Nothing streamed before the interrupt check fired.
    let snap = st.drain()
    assert_eq_str(replay(snap.events), "[start]")
}

fun test_clear_convo_empties_history() {
    let st = AgentState.new()
    st.push_user("a")
    st.push_assistant("b")
    st.clear_convo()
    assert_eq_int(st.messages().len(), 0)
}
