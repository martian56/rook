import std/string
import std/test { assert_eq_str, assert_eq_int, assert_true, assert_false }
import "./state" { AgentState, DisplayEvent, Snapshot }

fun replay(events: List<DisplayEvent>) -> String {
    let out = ""
    let i = 0
    while i < events.len() {
        match events[i] {
            Started -> {
                out = out.concat("[start]")
            },
            Chunk(d) -> {
                out = out.concat(d)
            },
            ToolRan(name, result) -> {
                out = out.concat("[tool ${name}=${result}]")
            },
            Info(t) -> {
                out = out.concat("[info ${t}]")
            },
            _ -> {},
        }
        i = i + 1
    }
    return out
}

fun test_conversation_accumulates() {
    let st = AgentState.new()
    st.push_user("hi")
    st.push_assistant("hello")
    let msgs = st.messages()
    assert_eq_int(msgs.len(), 2)
    assert_eq_str(msgs[1].content, "hello")
}

fun test_clear_convo_empties_history() {
    let st = AgentState.new()
    st.push_user("a")
    st.push_assistant("b")
    st.clear_convo()
    assert_eq_int(st.messages().len(), 0)
}

fun test_events_drain_once_then_empty() {
    let st = AgentState.new()
    st.emit(DisplayEvent.Started)
    st.chunk("hel")
    st.chunk("lo")
    let s = st.drain()
    assert_eq_str(replay(s.events), "[start]hello")
    let again = st.drain()
    assert_eq_int(again.events.len(), 0)
}

fun test_begin_resets_flags_and_events() {
    let st = AgentState.new()
    st.request_interrupt()
    st.emit(DisplayEvent.Started)
    st.finish()
    st.begin()
    assert_false(st.interrupted())
    let s = st.drain()
    assert_eq_int(s.events.len(), 0)
    assert_false(s.done)
}

fun test_interrupt_flag() {
    let st = AgentState.new()
    assert_false(st.interrupted())
    st.request_interrupt()
    assert_true(st.interrupted())
}

fun test_usage_accumulates_per_turn_and_session() {
    let st = AgentState.new()
    st.add_usage(100, 40)
    st.add_usage(50, 20)
    let t = st.turn_tokens()
    assert_eq_int(t.prompt, 150)
    assert_eq_int(t.completion, 60)
    // A new turn resets the turn total but keeps the session total.
    st.begin()
    let after = st.turn_tokens()
    assert_eq_int(after.prompt, 0)
    let snap = st.drain()
    assert_eq_int(snap.sess_prompt, 150)
    assert_eq_int(snap.sess_completion, 60)
    // Clearing the conversation resets the session total.
    st.clear_convo()
    assert_eq_int(st.drain().sess_prompt, 0)
}

fun test_plan_flag_round_trips_and_survives_begin() {
    let st = AgentState.new()
    assert_false(st.plan())
    st.set_plan(true)
    assert_true(st.plan())
    // A new turn keeps plan mode (it is a session toggle, not per-turn).
    st.begin()
    assert_true(st.plan())
    st.set_plan(false)
    assert_false(st.plan())
}

fun test_interrupt_cancels_the_stream_token() {
    let st = AgentState.new()
    assert_false(st.token().canceled())
    st.request_interrupt()
    assert_true(st.token().canceled())
    // A new turn gets a fresh token.
    st.begin()
    assert_false(st.token().canceled())
}

fun test_pending_is_readable_without_draining_events() {
    let st = AgentState.new()
    st.emit(DisplayEvent.Started)
    // pending_now must not consume the queued event.
    assert_eq_str(st.pending_now(), "")
    let s = st.drain()
    assert_eq_int(s.events.len(), 1)
}
