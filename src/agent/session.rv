// The conversation as aviary messages, and how a request is assembled from
// it. The transcript (Entry list) is the display; this is what the model
// actually sees.

import "github.com/martian56/aviary/request" { ChatRequest }
import "github.com/martian56/aviary/message" { Message }
import "../agents/dir" { roots }
import "../agents/skills" { load_skills, skills_prompt }
import "../agents/subagents" { all_subagents, subagents_prompt }
import "../agents/memory" { memory_prompt }
import "../tools/shells" { shells_note }

const SYSTEM_PROMPT: String = "You are rook, a coding assistant working in the user's current directory. You have tools: read_file, list_dir, file_tree, grep, write_file, edit_file, run_command, run_background, read_shell, list_shells, and kill_shell. Inspect the project with the read-only tools before answering, and use write_file, edit_file, and run_command to make changes and run builds or tests. Prefer edit_file for small changes. Use run_background for anything long-running (a dev server, a watcher): it returns a shell id immediately instead of blocking; read_shell shows what it printed since your last look, list_shells shows what is running, and kill_shell stops one. Writes and commands need the user's approval, so say what you intend before doing it. When a decision is the user's to make and guessing would be wrong (which approach, which of several fixes), ask with the ask_user tool instead of assuming. For multi-step work, keep a checklist with set_todos and update it as steps finish, so the user can follow along. Keep replies concise and in plain prose."

// Build a chat request from the running history. The caller has already
// appended the user's new message to history. A non-empty base_url points at
// a custom OpenAI-compatible endpoint (also how the e2e tests reach a local
// server). The system prompt carries the AGENTS.md memory and the skill
// index from .agents when the project or the user defines them.
fun build_request(
    model: String,
    history: List<Message>,
    api_key: String,
    base_url: String,
    timeout_ms: Int,
) -> ChatRequest {
    let req = ChatRequest.new(model).system(
        "${SYSTEM_PROMPT}${memory_prompt()}${skills_prompt(load_skills(roots()))}${subagents_prompt(all_subagents(roots()))}${shells_note()}",
    )
    let i = 0
    while i < history.len() {
        req = req.message(history[i])
        i = i + 1
    }
    if api_key != "" {
        req = req.key(api_key)
    }
    if base_url != "" {
        req = req.base(base_url)
    }
    if timeout_ms > 0 {
        req = req.timeout(timeout_ms)
    }
    return req
}
