// The shared handoff between the agent goroutine and the UI loop.
//
// The turn runs on a background goroutine because aviary's complete_stream
// blocks; it never touches the display directly. Instead it emits an ordered
// log of DisplayEvents (a bubble started, a text chunk, a finished tool, a
// notice) that the UI drains and replays on every tick, and it owns the
// conversation (the model-visible message list) which persists here across
// turns. Approval is a one-slot channel: the goroutine blocks asking, the UI
// answers with an Int.
//
// The UI never starts a new turn until the current one reports done, so a
// single goroutine writes the conversation and the event log at any time.

import std/string
import std/sync { Mutex, mutex, Channel, channel_buffered }
import "github.com/martian56/aviary/message" { Message, ToolCall }
import "github.com/martian56/aviary/request" { CancelToken }

// What the goroutine tells the UI to show, in order. The Agent* events
// bracket a subagent run so the UI can render its activity as a nested
// block: started, each tool it ran, and finished (with how many tools it
// used), letting the display group and collapse the block.
enum DisplayEvent {
    Started,
    Chunk(String),
    ToolRan(String, String),
    Info(String),
    AgentStarted(String, String),
    AgentTool(String, String, String, String),
    AgentFinished(String, String, Int),
}

// A drained batch plus the turn's status, read under the lock and handed to
// the UI to apply lock-free.
struct Snapshot {
    events: List<DisplayEvent>,
    done: Bool,
    pending: String,
    // A question awaiting the user's pick, "" when none; the options ride
    // alongside.
    question: String,
    choices: List<String>,
    // Extra lines shown under the pending approval (a diff preview).
    pending_detail: String,
    // Session token totals, for the status bar.
    sess_prompt: Int,
    sess_completion: Int,
    sess_cache_read: Int,
    sess_cache_write: Int,
}

// Token counts, for reporting a turn's usage.
struct Tokens {
    prompt: Int,
    completion: Int,
    cache_read: Int,
    cache_write: Int,
}

struct AgentState {
    lock: Mutex,
    convo: List<Message>,
    events: List<DisplayEvent>,
    done: Bool,
    interrupt: Bool,
    // The tool label awaiting approval, "" when none is pending.
    pending: String,
    // The question awaiting an answer, "" when none, and its options.
    question: String,
    choices: List<String>,
    // Extra lines under the pending approval (a diff preview), "" when none.
    pending_detail: String,
    // One-slot decision channel: 0 deny, 1 allow, 2 allow all of this kind.
    decisions: Channel,
    // Serializes ask() so parallel subagents queue for the one approval
    // prompt instead of overwriting each other's pending label.
    ask_lock: Mutex,
    // The turn's stream cancel token, fresh each begin(). request_interrupt
    // cancels it so an in-flight reply stops at the next delta instead of
    // running to the end.
    cancel: CancelToken,
    // Plan mode: read-only research, mutating tools blocked. A session
    // toggle set from the UI before each turn, not reset by begin().
    plan_flag: Bool,
    // Token usage: the current turn's (reset by begin) and the session's
    // running total (reset by clear_convo).
    turn_prompt: Int,
    turn_completion: Int,
    sess_prompt: Int,
    sess_completion: Int,
    // How much of the prompt totals was served from or written to the
    // provider's prompt cache, for the discounted cost estimate.
    turn_cache_read: Int,
    turn_cache_write: Int,
    sess_cache_read: Int,
    sess_cache_write: Int,
}

impl AgentState {
    fun new() -> AgentState {
        let convo: List<Message> = []
        let events: List<DisplayEvent> = []
        let choices: List<String> = []
        return AgentState {
            lock: mutex(),
            convo,
            events,
            done: false,
            interrupt: false,
            pending: "",
            question: "",
            choices,
            pending_detail: "",
            decisions: channel_buffered(1),
            ask_lock: mutex(),
            cancel: CancelToken.new(),
            plan_flag: false,
            turn_prompt: 0,
            turn_completion: 0,
            sess_prompt: 0,
            sess_completion: 0,
            turn_cache_read: 0,
            turn_cache_write: 0,
            sess_cache_read: 0,
            sess_cache_write: 0,
        }
    }

    // Add one reply's token usage to the current turn and the session total.
    // cache_read/cache_write are the reply's prompt-cache breakdown (already
    // included in `prompt`), kept so the cost estimate can discount them.
    fun add_usage(self, prompt: Int, completion: Int, cache_read: Int, cache_write: Int) {
        self.lock.lock()
        self.turn_prompt = self.turn_prompt + prompt
        self.turn_completion = self.turn_completion + completion
        self.sess_prompt = self.sess_prompt + prompt
        self.sess_completion = self.sess_completion + completion
        self.turn_cache_read = self.turn_cache_read + cache_read
        self.turn_cache_write = self.turn_cache_write + cache_write
        self.sess_cache_read = self.sess_cache_read + cache_read
        self.sess_cache_write = self.sess_cache_write + cache_write
        self.lock.unlock()
    }

    // Set the session's running token totals, for restoring them when a saved
    // session is resumed. Does not touch the per-turn counters. Saved sessions
    // do not persist the cache breakdown, so it restarts at zero and the
    // estimate is simply conservative for the restored history.
    fun set_usage(self, prompt: Int, completion: Int) {
        self.lock.lock()
        self.sess_prompt = prompt
        self.sess_completion = completion
        self.sess_cache_read = 0
        self.sess_cache_write = 0
        self.lock.unlock()
    }

    // This turn's accumulated usage, for the end-of-turn summary.
    fun turn_tokens(self) -> Tokens {
        self.lock.lock()
        let t = Tokens {
            prompt: self.turn_prompt,
            completion: self.turn_completion,
            cache_read: self.turn_cache_read,
            cache_write: self.turn_cache_write,
        }
        self.lock.unlock()
        return t
    }

    // Set plan mode. The UI calls this before begin() when it changes.
    fun set_plan(self, on: Bool) {
        self.lock.lock()
        self.plan_flag = on
        self.lock.unlock()
    }

    // Whether the turn is in plan mode (read-only, no mutations).
    fun plan(self) -> Bool {
        self.lock.lock()
        let p = self.plan_flag
        self.lock.unlock()
        return p
    }

    // Start a fresh turn: keep the conversation, reset per-turn state.
    fun begin(self) {
        self.lock.lock()
        self.done = false
        self.interrupt = false
        self.pending = ""
        self.question = ""
        let none: List<String> = []
        self.choices = none
        let e: List<DisplayEvent> = []
        self.events = e
        self.cancel = CancelToken.new()
        self.turn_prompt = 0
        self.turn_completion = 0
        self.turn_cache_read = 0
        self.turn_cache_write = 0
        self.lock.unlock()
    }

    // The turn's stream cancel token, for attaching to requests.
    fun token(self) -> CancelToken {
        self.lock.lock()
        let t = self.cancel
        self.lock.unlock()
        return t
    }

    fun clear_convo(self) {
        self.lock.lock()
        let c: List<Message> = []
        self.convo = c
        self.turn_prompt = 0
        self.turn_completion = 0
        self.turn_cache_read = 0
        self.turn_cache_write = 0
        self.sess_prompt = 0
        self.sess_completion = 0
        self.sess_cache_read = 0
        self.sess_cache_write = 0
        self.lock.unlock()
    }

    fun push_user(self, text: String) {
        self.lock.lock()
        self.convo.push(Message.user(text))
        self.lock.unlock()
    }

    fun push_assistant(self, text: String) {
        self.lock.lock()
        self.convo.push(Message.assistant(text))
        self.lock.unlock()
    }

    fun push_assistant_calls(self, text: String, calls: List<ToolCall>) {
        self.lock.lock()
        self.convo.push(Message.assistant_calls(text, calls))
        self.lock.unlock()
    }

    fun push_tool_result(self, id: String, name: String, content: String) {
        self.lock.lock()
        self.convo.push(Message.tool_result(id, name, content))
        self.lock.unlock()
    }

    // Replace the whole conversation, for context compaction. The display
    // transcript is separate and stays intact; this only changes what the
    // model sees on the next request.
    fun replace_convo(self, msgs: List<Message>) {
        self.lock.lock()
        self.convo = msgs
        self.lock.unlock()
    }

    // A copy of the conversation, for building a request.
    fun messages(self) -> List<Message> {
        self.lock.lock()
        let out: List<Message> = []
        let i = 0
        while i < self.convo.len() {
            out.push(self.convo[i])
            i = i + 1
        }
        self.lock.unlock()
        return out
    }

    fun emit(self, ev: DisplayEvent) {
        self.lock.lock()
        self.events.push(ev)
        self.lock.unlock()
    }

    fun chunk(self, d: String) {
        self.lock.lock()
        self.events.push(DisplayEvent.Chunk(d))
        self.lock.unlock()
    }

    // Take the pending events and current status in one lock.
    fun drain(self) -> Snapshot {
        self.lock.lock()
        let evs = self.events
        let empty: List<DisplayEvent> = []
        self.events = empty
        let s = Snapshot {
            events: evs,
            done: self.done,
            pending: self.pending,
            question: self.question,
            choices: self.choices,
            pending_detail: self.pending_detail,
            sess_prompt: self.sess_prompt,
            sess_completion: self.sess_completion,
            sess_cache_read: self.sess_cache_read,
            sess_cache_write: self.sess_cache_write,
        }
        self.lock.unlock()
        return s
    }

    fun finish(self) {
        self.lock.lock()
        self.done = true
        self.lock.unlock()
    }

    // Read the pending approval without draining events, so a second reader
    // (a test's approver) can watch for it without stealing display events.
    fun pending_now(self) -> String {
        self.lock.lock()
        let p = self.pending
        self.lock.unlock()
        return p
    }

    // Stop the turn: the flag ends it at the next round boundary, and
    // canceling the token stops an in-flight stream at its next delta.
    fun request_interrupt(self) {
        self.lock.lock()
        self.interrupt = true
        let t = self.cancel
        self.lock.unlock()
        t.cancel()
    }

    fun interrupted(self) -> Bool {
        self.lock.lock()
        let v = self.interrupt
        self.lock.unlock()
        return v
    }

    // Goroutine side: publish a pending approval and block until the UI
    // answers. Returns 0 deny, 1 allow, 2 allow all of this kind. Callers
    // queue: with agents running in parallel, one approval shows at a time.
    fun ask(self, desc: String) -> Int {
        return self.ask_detail(desc, "")
    }

    // ask with extra lines (a diff preview) shown under the label.
    fun ask_detail(self, desc: String, detail: String) -> Int {
        self.ask_lock.lock()
        self.lock.lock()
        self.pending = desc
        self.pending_detail = detail
        self.lock.unlock()
        let d = self.decisions.recv()
        self.lock.lock()
        self.pending = ""
        self.pending_detail = ""
        self.lock.unlock()
        self.ask_lock.unlock()
        return d
    }

    // UI side: answer the pending approval. Clear the shared prompt state
    // before sending so the next drain sees it answered: otherwise a tick that
    // lands between this send and the goroutine clearing it would re-show the
    // just-answered prompt, and a second keypress would leak a decision into
    // the buffered channel that silently answers the following prompt.
    fun decide(self, d: Int) {
        self.lock.lock()
        self.pending = ""
        self.pending_detail = ""
        self.question = ""
        let none: List<String> = []
        self.choices = none
        self.lock.unlock()
        self.decisions.send(d)
    }

    // Goroutine side: publish a question with options and block until the
    // UI answers with the chosen index (or -1 for declined). Shares the
    // ask_lock and decision channel with approvals, so only one prompt is
    // in front of the user at a time.
    fun ask_question(self, q: String, options: List<String>) -> Int {
        self.ask_lock.lock()
        self.lock.lock()
        self.question = q
        self.choices = options
        self.lock.unlock()
        let d = self.decisions.recv()
        self.lock.lock()
        self.question = ""
        let none: List<String> = []
        self.choices = none
        self.lock.unlock()
        self.ask_lock.unlock()
        return d
    }

    // Read the pending question without draining events (for tests).
    fun question_now(self) -> String {
        self.lock.lock()
        let q = self.question
        self.lock.unlock()
        return q
    }
}
