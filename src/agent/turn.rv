// One agent turn on a background goroutine: stream a reply, and if the model
// asks for tools, run them (approving mutating ones through the UI) and feed
// the results back, until the model answers with no tool calls or the round
// cap is hit.

import std/string
import std/sync { Mutex, mutex, sleep_millis }
import "github.com/martian56/aviary" { complete_stream }
import "github.com/martian56/aviary/request" { ChatRequest, CancelToken }
import "github.com/martian56/aviary/message" { ToolCall }
import "./state" { AgentState, DisplayEvent }
import "./session" { build_request }
import "./compact" { maybe_compact }
import "./subturn" { run_subagent }
import "./ask_options" { parse_ask_options, option_labels, option_count_error }
import "../tools/registry" { tools, needs_approval, call_approval_detail, dispatch_cancelable, label }
import "../tools/preview" { change_preview, append_preview }
import "../tools/permissions" { Verdict, check_permission }
import "../tools/pricing" { usage_label }
import "../tools/args" { arg }
import "../agents/dir" { roots }
import "../agents/subagents" { Subagent, all_subagents, subagent_index }
import "../hooks/hooks" { run_pre_tool_hooks, fire_hooks }

const MAX_ROUNDS: Int = 25

fun run_turn(st: AgentState, model: String, api_key: String, base_url: String) {
    // Tool kinds the user approved for the rest of this turn.
    let allowed: List<String> = []
    let round = 0
    while round < MAX_ROUNDS {
        if st.interrupted() {
            st.emit(DisplayEvent.Info("Interrupted"))
            _end_turn(st)
            return
        }
        // Fire before every model call, so a hook can log or set up state.
        fire_hooks("pre-prompt", "", "")
        // Summarize old turns when the conversation nears the context window.
        let compacted = maybe_compact(st, model, api_key, base_url)
        if compacted > 0 {
            st.emit(
                DisplayEvent.Info(
                    "compacted ${compacted} earlier messages to stay within the context window",
                ),
            )
        }
        st.emit(DisplayEvent.Started)
        let plan = st.plan()
        let req = _with_tools(build_request(model, st.messages(), api_key, base_url, 0, plan), plan).cancelable(
            st.token(),
        )
        let on_chunk = fun(d: String) -> Unit = st.chunk(d)

        let reply_text = ""
        let calls: List<ToolCall> = []
        let finish = ""
        let err = ""
        match complete_stream(req, on_chunk) {
            Ok(reply) -> {
                reply_text = reply.content
                calls = reply.tool_calls
                finish = reply.finish_reason
                st.add_usage(reply.usage.prompt_tokens, reply.usage.completion_tokens)
            },
            Err(e) -> {
                err = e.message
            },
        }
        if err != "" {
            st.emit(DisplayEvent.Info("error: ${err}"))
            _end_turn(st)
            return
        }
        // Esc canceled the stream mid-reply: keep whatever streamed in the
        // conversation and stop here.
        if finish == "canceled" {
            if reply_text != "" {
                st.push_assistant(reply_text)
            }
            st.emit(DisplayEvent.Info("Interrupted"))
            _report_usage(st, model)
            _end_turn(st)
            return
        }
        if calls.len() == 0 {
            st.push_assistant(reply_text)
            _report_usage(st, model)
            _end_turn(st)
            return
        }

        // The model wants tools: record the request, run each call, feed the
        // results back, and loop for another round. Two or more dispatches
        // in one batch fan out to concurrent goroutines; everything else
        // runs in order on this one.
        st.push_assistant_calls(reply_text, calls)
        let fanout = _count_dispatch(calls) >= 2
        let fanout_results = ToolResults.new(calls.len())
        if fanout {
            st.emit(DisplayEvent.Info("running ${_count_dispatch(calls)} agents in parallel…"))
        }
        let i = 0
        while i < calls.len() {
            let call = calls[i]
            if fanout && call.name == "dispatch" {
                let idx = i
                let spawned_call = call
                spawn(fun() -> Unit {
                    let result = _dispatch(st, spawned_call, model, api_key, base_url)
                    st.emit(DisplayEvent.ToolRan(label(spawned_call), _short(result)))
                    fanout_results.set(idx, result)
                })
            } else {
                let result = ""
                if call.name == "dispatch" {
                    result = _dispatch(st, call, model, api_key, base_url)
                } else {
                    if call.name == "ask_user" {
                        result = _ask_user(st, call)
                    } else {
                        result = _run_one(st, call, allowed)
                    }
                }
                st.emit(DisplayEvent.ToolRan(label(call), _display(call, result)))
                if fanout {
                    fanout_results.set(i, result)
                } else {
                    st.push_tool_result(call.id, call.name, result)
                }
            }
            i = i + 1
        }
        // Every agent's result must be in the conversation before the next
        // round's request is built.
        if fanout {
            while fanout_results.count() < calls.len() {
                sleep_millis(20)
            }
            _push_tool_results(st, calls, fanout_results)
        }
        round = round + 1
    }
    st.emit(DisplayEvent.Info("stopped after ${MAX_ROUNDS} tool rounds"))
    _report_usage(st, model)
    _end_turn(st)
    return
}

// End the turn: fire the turn-end hooks, then release the UI.
fun _end_turn(st: AgentState) {
    fire_hooks("turn-end", "", "")
    st.finish()
    return
}

// Emit this turn's token usage and estimated cost, when there is any.
fun _report_usage(st: AgentState, model: String) {
    let t = st.turn_tokens()
    if t.prompt + t.completion == 0 {
        return
    }
    st.emit(DisplayEvent.Info("turn: ${usage_label(model, t.prompt, t.completion)}"))
    return
}

// Indexed fan-out results. Dispatch goroutines may finish in any order, but
// the model-visible tool results are pushed later in the original call order.
struct ToolResults {
    lock: Mutex,
    results: List<String>,
    n: Int,
}

impl ToolResults {
    fun new(size: Int) -> ToolResults {
        let results: List<String> = []
        let i = 0
        while i < size {
            results.push("")
            i = i + 1
        }
        return ToolResults { lock: mutex(), results, n: 0 }
    }

    fun set(self, idx: Int, result: String) {
        self.lock.lock()
        if idx >= 0 && idx < self.results.len() {
            self.results[idx] = result
            self.n = self.n + 1
        }
        self.lock.unlock()
    }

    fun count(self) -> Int {
        self.lock.lock()
        let c = self.n
        self.lock.unlock()
        return c
    }

    fun get(self, idx: Int) -> String {
        self.lock.lock()
        let result = ""
        if idx >= 0 && idx < self.results.len() {
            result = self.results[idx]
        }
        self.lock.unlock()
        return result
    }
}

fun _push_tool_results(st: AgentState, calls: List<ToolCall>, results: ToolResults) {
    let i = 0
    while i < calls.len() {
        st.push_tool_result(calls[i].id, calls[i].name, results.get(i))
        i = i + 1
    }
    return
}

fun _count_dispatch(calls: List<ToolCall>) -> Int {
    let c = 0
    let i = 0
    while i < calls.len() {
        if calls[i].name == "dispatch" {
            c = c + 1
        }
        i = i + 1
    }
    return c
}

// A dispatch call: look the subagent up and run it to completion inside
// this goroutine; its final answer is the tool result. Runs without its own
// approval since every mutating call the subagent makes still gates
// individually.
fun _dispatch(
    st: AgentState,
    call: ToolCall,
    model: String,
    api_key: String,
    base_url: String,
) -> String {
    let name = arg(call.arguments, "agent")
    let task = arg(call.arguments, "task")
    if task.trim() == "" {
        return "error: dispatch needs a task"
    }
    let agents = all_subagents(roots())
    let idx = subagent_index(agents, name)
    if idx < 0 {
        let names = ""
        let i = 0
        while i < agents.len() {
            if i > 0 {
                names = names.concat(", ")
            }
            names = names.concat(agents[i].name)
            i = i + 1
        }
        return "error: no subagent named '${name}'; available: ${names}"
    }
    return run_subagent(st, agents[idx], task, model, api_key, base_url)
}

// An ask_user call: publish the question and options and block until the
// user picks. The chosen option (not its index) goes back to the model, so
// the answer reads naturally in the conversation.
fun _ask_user(st: AgentState, call: ToolCall) -> String {
    let question = arg(call.arguments, "question").trim()
    if question == "" {
        return "error: ask_user needs a question"
    }
    let options = parse_ask_options(call.arguments)
    let count_error = option_count_error(options)
    if count_error != "" {
        return count_error
    }
    let labels = option_labels(options)
    let idx = st.ask_question(question, labels)
    if idx < 0 || idx >= options.len() {
        return "The user declined to pick an option; ask them in plain chat instead."
    }
    st.emit(DisplayEvent.Info("you chose: ${labels[idx]}"))
    return "The user chose: ${options[idx].value}"
}

// Run one tool call, gating a mutating one through approval unless its kind
// was already allowed for the turn.
fun _run_one(st: AgentState, call: ToolCall, allowed: List<String>) -> String {
    let approval_detail = call_approval_detail(call)
    let approval_needed = needs_approval(call.name) || approval_detail != ""
    // Plan mode blocks every mutating tool outright, even if one slips into
    // a request; the model should propose the change, not make it.
    if st.plan() && approval_needed {
        return "Plan mode is on, so ${call.name} is unavailable. Describe this change as part of your plan instead; the user will turn plan mode off to carry it out."
    }
    // A pre-tool hook may veto the call before anything runs; its reason goes
    // back to the model in place of the tool result.
    let vetoed = run_pre_tool_hooks(call.name, call.arguments)
    if vetoed != "" {
        return vetoed
    }
    // Settings rules come first: a deny blocks any tool, an allow skips the
    // prompt for a gated one.
    let denied = ""
    let pre_allowed = false
    match check_permission(call) {
        Deny(rule) -> {
            denied = rule
        },
        Allow -> {
            pre_allowed = true
        },
        Ask -> {},
    }
    if denied != "" {
        return "This action is blocked by the permission rule '${denied}' in settings. Do not retry it; find another way or ask the user."
    }
    if !approval_needed {
        return _do(st.token(), call, "")
    }
    // The diff this call would make, shown in the approval prompt and, on
    // success, under the tool row.
    let preview = approval_detail
    if preview == "" {
        preview = change_preview(call)
    }
    if pre_allowed || _contains(allowed, call.name) {
        return _do(st.token(), call, preview)
    }
    let decision = st.ask_detail(label(call), preview)
    if decision == 2 {
        allowed.push(call.name)
        return _do(st.token(), call, preview)
    }
    if decision == 1 {
        return _do(st.token(), call, preview)
    }
    return "The user denied this action. Do not retry it; ask what they would prefer."
}

// Run the tool, then fire the post-tool hooks so they observe what ran. The
// diff (when any) is appended for the transcript and the model.
fun _do(token: CancelToken, call: ToolCall, preview: String) -> String {
    let result = append_preview(dispatch_cancelable(call, token), preview)
    fire_hooks("post-tool", call.name, call.arguments)
    return result
}

// Attach the tools the model may use. In plan mode the mutating tools are
// withheld, so the model researches and proposes instead of changing
// anything.
fun _with_tools(req: ChatRequest, plan: Bool) -> ChatRequest {
    let ts = tools()
    let r = req
    let i = 0
    while i < ts.len() {
        if !plan || !needs_approval(ts[i].name) {
            r = r.tool(ts[i])
        }
        i = i + 1
    }
    return r
}

fun _contains(xs: List<String>, name: String) -> Bool {
    let i = 0
    while i < xs.len() {
        if xs[i] == name {
            return true
        }
        i = i + 1
    }
    return false
}

// What a tool row shows: the clipped first line, plus the diff lines under
// a file change so the transcript displays what changed.
fun _display(call: ToolCall, result: String) -> String {
    let head = _short(result)
    if call.name != "write_file" && call.name != "edit_file" && call.name != "multi_edit" {
        return head
    }
    let nl = result.index_of("\n")
    if nl < 0 {
        return head
    }
    return "${head}\n${result.substring(nl + 1, result.length())}"
}

// A compact one-liner for the tool bullet: the first line, clipped.
fun _short(result: String) -> String {
    let first = result
    let nl = result.index_of("\n")
    if nl >= 0 {
        first = result.substring(0, nl)
    }
    if first.length() > 60 {
        first = "${first.substring(0, 60)}…"
    }
    return first
}
