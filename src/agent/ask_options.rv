// Structured ask_user options. The model-facing schema prefers an array of
// objects with a display label and optional stable value, while the parser
// keeps the old comma-separated string format working for now.

import std/string
import std/json { JsonValue, parse }

struct AskOption {
    label: String,
    value: String,
}

fun parse_ask_options(args_json: String) -> List<AskOption> {
    let out: List<AskOption> = []
    if args_json.trim() == "" {
        return out
    }
    match parse(args_json) {
        Ok(j) -> {
            let options = _field(j, "options")
            match options {
                Array(items) -> {
                    let i = 0
                    while i < items.len() {
                        let option = _option_from_json(items[i])
                        if option.label != "" {
                            out.push(option)
                        }
                        i = i + 1
                    }
                },
                _ -> {
                    _append_comma_options(_as_str(options), out)
                },
            }
        },
        Err(e) -> {},
    }
    return out
}

fun option_labels(options: List<AskOption>) -> List<String> {
    let labels: List<String> = []
    let i = 0
    while i < options.len() {
        labels.push(options[i].label)
        i = i + 1
    }
    return labels
}

fun option_count_error(options: List<AskOption>) -> String {
    if options.len() < 2 || options.len() > 5 {
        return "error: ask_user needs two to five options"
    }
    return ""
}

fun _option_from_json(j: JsonValue) -> AskOption {
    let label = ""
    let value = ""
    match j {
        Str(s) -> {
            label = s.trim()
            value = label
        },
        Object(obj) -> {
            label = _as_str(_field(j, "label")).trim()
            value = _as_str(_field(j, "value")).trim()
            if label == "" {
                label = value
            }
            if value == "" {
                value = label
            }
        },
        _ -> {},
    }
    return AskOption { label, value }
}

fun _append_comma_options(raw: String, out: List<AskOption>) {
    let parts = raw.split(",")
    let i = 0
    while i < parts.len() {
        let label = parts[i].trim()
        if label != "" {
            out.push(AskOption { label, value: label })
        }
        i = i + 1
    }
    return
}

fun _field(j: JsonValue, key: String) -> JsonValue {
    return match j.get(key) {
        Some(v) -> v,
        None -> JsonValue.Null,
    }
}

fun _as_str(j: JsonValue) -> String {
    return match j.as_string() {
        Some(s) -> s,
        None -> "",
    }
}
