// rook: a terminal coding agent built on plumage. It streams a real model's
// reply and runs tools (read, search, edit, run commands) with your approval.
//
// Run with: rvpm run          (optionally: rvpm run -- --model openai/gpt-5.6-sol)
// Keys: type and Enter to send. Esc interrupts. ctrl+c twice quits.
// PageUp/PageDown or the mouse wheel scroll. Commands: /model /key /clear /help /quit.

import std/io { println }
import std/env { args }
import "github.com/martian56/plumage" { App, run }
import "./app/model" { Chat, chat_init }
import "./app/update" { chat_update }
import "./app/view" { chat_view }
import "./hooks/hooks" { fire_hooks }
import "./version" { version }
import "./headless" { run_print }

fun main() {
    if _wants_version() {
        println("rook ${version()}")
        return
    }
    let print_prompt = _print_prompt()
    if print_prompt != "" {
        fire_hooks("session-start", "", "")
        run_print(print_prompt)
        return
    }
    if _wants_help() {
        println("rook ${version()}: a coding agent for your terminal")
        println("")
        println("usage: rook [options]")
        println("  --model <provider/model>   use this model for the session")
        println("  --continue, -c             reopen the most recent session")
        println("  -p, --print <prompt>       run one prompt headless, stream to stdout, exit")
        println("  --version, -V              print the version and exit")
        println("  --help, -h                 this text")
        println("")
        println("Inside: type a task and press enter. / lists commands, @ attaches")
        println("a file, ! runs a shell command. Esc interrupts a turn.")
        return
    }
    // Let session-start hooks run before the UI takes over the terminal.
    fire_hooks("session-start", "", "")
    let app = App { init: chat_init, update: chat_update, view: chat_view, tick_ms: 45 }
    if !run<Chat>(app) {
        println("rook needs an interactive terminal; run it from a real console")
    }
}

// Whether the command line asks for the version, so `rook --version` (or -V)
// prints it and exits instead of starting the UI.
fun _wants_version() -> Bool {
    let a = args()
    let i = 0
    while i < a.len() {
        if a[i] == "--version" || a[i] == "-V" {
            return true
        }
        i = i + 1
    }
    return false
}

fun _wants_help() -> Bool {
    let a = args()
    let i = 0
    while i < a.len() {
        if a[i] == "--help" || a[i] == "-h" {
            return true
        }
        i = i + 1
    }
    return false
}

// The -p / --print prompt: everything after the flag, joined, "" when the
// flag is absent.
fun _print_prompt() -> String {
    let a = args()
    let i = 0
    while i < a.len() {
        if a[i] == "-p" || a[i] == "--print" {
            let out = ""
            let j = i + 1
            while j < a.len() {
                if out != "" {
                    out = "${out} "
                }
                out = out.concat(a[j])
                j = j + 1
            }
            return out
        }
        i = i + 1
    }
    return ""
}
