import std/string
import std/json { parse, JsonValue }
import std/test { assert_eq_str, assert_eq_int, assert_true }
import std/fs { write, create_dir_all, remove_file, remove_dir }
import std/process { Output }
import "./hooks" { Hook, hooks_from, hooks_for, hook_context, load_hooks_from_with_project_trust, run_pre_tool, drain_hook_notices, _shell_launch_error }

const CONFIG: String = "{\"pre-tool\": [{\"match\": \"write_file\", \"command\": \"a\", \"fail_closed\": true}, {\"command\": \"b\"}], \"turn-end\": [{\"command\": \"c\"}], \"post-tool\": [{\"match\": \"\", \"command\": \"\"}]}"

fun _section() -> JsonValue {
    return match parse(CONFIG) {
        Ok(j) -> j,
        Err(e) -> JsonValue.Null,
    }
}

fun test_hooks_from_reads_events_and_defaults_match() {
    let hs = hooks_from(_section())
    // Two pre-tool (one with a match, one defaulting to *) and one turn-end;
    // the post-tool entry has no command, so it is dropped.
    assert_eq_int(hs.len(), 3)
    let i = 0
    let starred = 0
    while i < hs.len() {
        if hs[i].command == "b" {
            assert_eq_str(hs[i].match_glob, "*")
            assert_true(!hs[i].fail_closed)
        }
        if hs[i].command == "a" {
            assert_true(hs[i].fail_closed)
        }
        if hs[i].match_glob == "*" {
            starred = starred + 1
        }
        i = i + 1
    }
    assert_eq_int(starred, 2)
}

fun test_hooks_for_filters_by_event_and_match() {
    let hooks = [
        Hook { event: "pre-tool", match_glob: "write_file", command: "a", fail_closed: false },
        Hook { event: "pre-tool", match_glob: "*", command: "b", fail_closed: false },
        Hook { event: "post-tool", match_glob: "*", command: "c", fail_closed: false },
    ]
    // write_file matches the exact glob and the wildcard.
    assert_eq_int(hooks_for(hooks, "pre-tool", "write_file").len(), 2)
    // read_file matches only the wildcard.
    assert_eq_int(hooks_for(hooks, "pre-tool", "read_file").len(), 1)
    // A different event.
    assert_eq_int(hooks_for(hooks, "post-tool", "read_file").len(), 1)
    // No hook is bound to turn-end.
    assert_eq_int(hooks_for(hooks, "turn-end", "").len(), 0)
}

fun test_project_hooks_are_ignored_until_trusted() {
    create_dir_all(".agents")
    write(".agents/settings.json", "{\"hooks\": {\"session-start\": [{\"command\": \"echo hi\"}]}}")

    assert_eq_int(load_hooks_from_with_project_trust([".agents"], false).len(), 0)
    assert_eq_int(load_hooks_from_with_project_trust([".agents"], true).len(), 1)

    remove_file(".agents/settings.json")
    remove_dir(".agents")
    return
}

fun test_pre_tool_hook_blocks_on_nonzero_exit() {
    // A non-zero exit blocks; exit 0 does not. "exit N" runs in both sh and
    // cmd, so this holds on every platform.
    let blocker = [
        Hook {
            event: "pre-tool",
            match_glob: "*",
            command: "exit 7",
            fail_closed: false,
        },
    ]
    assert_true(run_pre_tool(blocker, "write_file", "{}").starts_with("blocked by a pre-tool hook"))

    let passer = [
        Hook {
            event: "pre-tool",
            match_glob: "*",
            command: "exit 0",
            fail_closed: false,
        },
    ]
    assert_eq_str(run_pre_tool(passer, "write_file", "{}"), "")

    // With no hooks, nothing ever blocks.
    let none: List<Hook> = []
    assert_eq_str(run_pre_tool(none, "write_file", "{}"), "")
}

fun test_hook_launch_failure_is_visible_once_and_fails_open_by_default() {
    drain_hook_notices()
    let hook = [
        Hook {
            event: "pre-tool",
            match_glob: "*",
            command: "_rook_missing_hook_command --token secret-value",
            fail_closed: false,
        },
    ]

    assert_eq_str(run_pre_tool(hook, "write_file", "{}"), "")
    let notices = drain_hook_notices()
    assert_eq_int(notices.len(), 1)
    assert_true(notices[0].contains("pre-tool"))
    assert_true(notices[0].contains("_rook_missing_hook_command"))
    assert_true(notices[0].contains("not found"))
    assert_true(!notices[0].contains("secret-value"))

    assert_eq_str(run_pre_tool(hook, "write_file", "{}"), "")
    assert_eq_int(drain_hook_notices().len(), 0)
}

fun test_deliberate_block_message_is_not_a_launch_error() {
    // A guard that ran and exited non-zero with a deny reason mentioning
    // "access is denied" must be treated as a real block, not a launch failure
    // that fails open and runs the tool anyway.
    assert_eq_str(
        _shell_launch_error(Output { code: 1, stdout: "", stderr: "Access is denied: writing here is blocked" }),
        "",
    )
    // A genuinely missing command is still recognized as a launch failure.
    assert_eq_str(
        _shell_launch_error(Output { code: 127, stdout: "", stderr: "sh: hookcmd: not found" }),
        "command was not found",
    )
    assert_eq_str(
        _shell_launch_error(
            Output { code: 1, stdout: "", stderr: "'hookcmd' is not recognized as an internal or external command" },
        ),
        "command was not found",
    )
}

fun test_pre_tool_hook_launch_failure_can_fail_closed() {
    drain_hook_notices()
    let hook = [
        Hook {
            event: "pre-tool",
            match_glob: "*",
            command: "_rook_missing_required_guard --policy strict",
            fail_closed: true,
        },
    ]
    let result = run_pre_tool(hook, "run_command", "{}")
    assert_true(
        result.starts_with("blocked because pre-tool hook command '_rook_missing_required_guard'"),
    )
    assert_eq_int(drain_hook_notices().len(), 1)
}

fun test_hook_context_includes_subagent_name() {
    let ctx = hook_context("pre-tool", "worker", "write_file", "{\"path\":\"x\"}")
    assert_true(ctx.contains("\"event\":\"pre-tool\""))
    assert_true(ctx.contains("\"agent\":\"worker\""))
    assert_true(ctx.contains("\"tool\":\"write_file\""))
    assert_true(ctx.contains("\"args\":\"{\\\"path\\\":\\\"x\\\"}\""))
}
